{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["step", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [[1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 1, "\uac00\uc2b4\uc5d0 \uc0c8\uae34 \ub108 (2) - \uc2ac\ud508 \ub0a8\uc790", ["\uae40\ubbfc\uae30"], 0, "\ub7ec\ube0c\uc2a4\ud1a0\ub9ac \uc7a5\ub974\ub85c \uc0ac\uc6a9\uc790\uac00 \ud53c\ud558\ub294 '\uc608\uce21 \uac00\ub2a5\ud55c \uacb0\ub9d0\uc758 \uc5f0\uc560\uc18c\uc124'\uc5d0 \ud574\ub2f9\ud558\uba70, \ub2e8 \ud558\ub098\uc758 \uc0ac\ub791\uc5d0 \uc9d1\uc911\ud558\ub294 \uc8fc\uc81c\uac00 \uc0ac\uc6a9\uc790\uc758 disliked \ud56d\ubaa9\uacfc \uc9c1\uc811 \ucda9\ub3cc\ud55c\ub2e4.", 0, "\uc608\uce21 \uac00\ub2a5\ud55c \uacb0\ub9d0\uc758 \uc5f0\uc560\uc18c\uc124\ub85c, \uac10\uc815\uc801\uc73c\ub85c \ucda9\uc804\ud558\uae30\uc5d0\ub294 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 2, "\ubb38\ud559\uc2dc\uac04\uc5d0 \uc18c\uc124 \uc77d\uae30 1 - \uc2dc\uac04\uc5d0 \uc77d\uae30 ", ["\uc804\uad6d\uad6d\uc5b4\uad50\uc0ac\ubaa8\uc784"], 0, "", 0, ""], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 3, "\ub9cc\uc57d\uc5d0 \ud018\uc2a4\ucc9c", ["\uc774\uc740\ud558"], 0, "\uc18c\uac1c\uae00\uc5d0\uc11c '\uc5b4\ub460\uacfc \uc0c1\ucc98', '\ube44\ud604\uc2e4\uc801 \uc9c8\ubb38', '\uc774\uc9c8\uc801\uc73c\ub85c \ub2e4\uac00\uc62c \uac83' \ub4f1\uc73c\ub85c \ud45c\ud604\ub418\uc5b4 \uc0ac\uc6a9\uc790\uac00 \ud53c\ud558\ub294 '\ub108\ubb34 \ubb34\uac70\uc6b4 \uc8fc\uc81c'\uc5d0 \ud574\ub2f9\ud558\uace0, \ubcf5\uc7a1\ud55c \uc11c\uc220 \ubc29\uc2dd\uc774 \uc77d\uae30 \ubd80\ub2f4\uc744 \uc904 \uc218 \uc788\ub2e4.", 1, "\uc8fc\uc778\uacf5\uc758 \uc0c1\ucc98\uc640 \uc790\uc544\ub97c \ucc3e\ub294 \uacfc\uc815\uc744 \ud1b5\ud574 \uac10\uc815\uc801\uc73c\ub85c \uae4a\uc774 \uc788\ub294 \uacbd\ud5d8\uc744 \ud560 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 4, "\ub784\ub784\ub77c \ucc45 - \ucc45\uc73c\ub85c \uc131\uc7a5\ud558\ub294 \uccad\ucd98\uc758 \ubaa8\uc2b5", ["\ucc45 \uc77d\ub294 \uccad\ucd98"], 0, "\ub300\ud559\uc0dd \uccad\ucd98\uc758 \uc131\uc7a5 \uc774\uc57c\uae30\ub85c \uc0ac\uc6a9\uc790\uc758 \ub098\uc774\ub300(40\uc138)\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \uc5d0\uc138\uc774/\ud1a0\ub860 \uae30\ub85d \ud615\uc2dd\uc73c\ub85c \uc0ac\uc6a9\uc790\uac00 \uc120\ud638\ud558\ub294 '\uc11c\uc0ac\uac00 \uc788\uace0 \ubab0\uc785\ud560 \uc218 \uc788\ub294 \uae00'\uacfc \uac70\ub9ac\uac00 \uc788\ub2e4.", 0, "\uccad\ucd98\uc758 \uc774\uc57c\uae30\ub85c \ub2e4\uc18c \uac00\ubcbc\uc6b4 \uc8fc\uc81c\uc77c \uc218 \uc788\uc5b4, \uac10\uc815\uc801\uc73c\ub85c \ucda9\uc804\ud558\uae30\uc5d0\ub294 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 5, "\ucca0\ud5599\ub2e8\uc758 \ud790\ub9c1\ub178\ud2b8 - \uc0b6\uc758 \uc5f4\uc815\uacfc \uc9c0\ud61c\uc640 \ud589\ubcf5\uc744 \uc8fc\ub294", ["\uc774\ucc3d\ud638"], 0, "\uc778\ubb38\ud559 \uc5d0\uc138\uc774\ub85c \ud55c\uad6d\ubb38\ud559 \uc7a5\ub974 \uc120\ud638\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \uc18c\uac1c\uae00\uc758 '\ub0c9\ucca0\ud55c \uc774\uc131', '\uac01\uc131\uacfc \uacf5\uac10' \ub4f1\uc774 \uc554\uc2dc\ud558\ub294 \ubb34\uac70\uc6b4 \ucca0\ud559\uc801 \uc8fc\uc81c\uac00 \uc0ac\uc6a9\uc790\uc758 difficulty_level \uae30\uc900\uc744 \ucd08\uacfc\ud55c\ub2e4.", 0, "\uc778\ubb38\uc11c\ub85c\uc11c \uac10\uc815\uc801\uc778 \ucda9\uc804\ubcf4\ub2e4\ub294 \uc9c0\uc801\uc778 \uc790\uadf9\uc774 \ub354 \uac15\ud560 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 6, "\uc0c8\ub294 \ub0a0\uace0", ["\uae40\uc8fc\ud604"], 1, "\ud55c\uad6d\ubb38\ud559 \uc791\uac00\uc758 \uc18c\uc124\ub85c \uc8fc\uc778\uacf5 \uc911\uc2ec\uc758 \uc2ec\ub9ac \ubb18\uc0ac\uc640 \uc194\uc9c1\ud55c \uc790\uae30\uc131\ucc30\uc774 \ubab0\uc785\uac10 \uc788\ub294 \uc11c\uc0ac\ub97c \uc81c\uacf5\ud558\uba70, \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ub09c\uc774\ub3c4\ub85c \uc8fc\ub9d0 \uc5ec\uc720\ub85c\uc6b4 \ub3c5\uc11c\uc5d0 \uc801\ud569\ud558\ub2e4.", 1, "\uc8fc\uc778\uacf5\uc758 \uc0dd\uac01\uacfc \uac10\uc815\uc744 \uae4a\uc774 \ud0d0\uad6c\ud558\ub294 \uc11c\uc0ac\uac00 \uc788\uc5b4, \uac10\uc815\uc801\uc73c\ub85c \ucda9\uc804\ud560 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 7, "\uc138\uacc4\ubb38\ud559, \uadf8 \ub108\uba38 - \ud0c8\uad6c\ubbf8\uc911\uc2ec\uc8fc\uc758\u318d\uacbd\uacc4\u318d\ud574\ubc29\uc758 \uc0c1\uc0c1\ub825", ["\uace0\uba85\ucca0"], 0, "\ud559\uc220\uc801 \ube44\ud3c9\uc11c\ub85c \ud55c\uad6d\ubb38\ud559 \uc18c\uc124 \uc120\ud638\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \uc18c\uac1c\uae00\uc758 '\uc804\ubb38\ud654', '\ube44\ud310\uc801 \ubb38\uc81c\uc758\uc2dd' \ub4f1\uc774 \uc554\uc2dc\ud558\ub294 \ubcf5\uc7a1\ud55c \uc774\ub860\uc11c\uac00 \uc0ac\uc6a9\uc790\uac00 \ud53c\ud558\ub294 '\ub108\ubb34 \ubcf5\uc7a1\ud55c \uacfc\ud559\uc11c\uc801' \ubc94\uc8fc\uc5d0 \ud574\ub2f9\ud55c\ub2e4.", 0, ""], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 8, "\uc6b0\ub9ac\ub294 \uc774\uc5b4\uc838 \uc788\ub2e4 - \u2018\ub0a8\uc131 \ud398\ubbf8\ub2c8\uc2a4\ud2b8\u2019\ub77c\ub294 \ub9d0\uc744 \ub118\uc5b4\uc11c", ["\uc548\ud76c\uc81c", "\uc774\uc194", "\uc2e0\ud544\uaddc", "\uc774\ud55c", "\ubc15\uc815\ud6c8"], 0, "", 0, "\uc0ac\ud68c\uc801 \uc774\uc288\ub97c \ub2e4\ub8e8\uace0 \uc788\uc5b4 \uac10\uc815\uc801\uc778 \ucda9\uc804\ubcf4\ub2e4\ub294 \uc9c0\uc801\uc778 \uc790\uadf9\uc774 \ub354 \uac15\ud560 \uac83 \uac19\uc544\uc694."], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 9, "\uace0\uc804\ubb38\ud559\uc73c\ub85c \ub9cc\ub098\ub294 \ud55c\uad6d\uc5b4\uc640 \ud55c\uad6d\ubb38\ud654 - nk Korean \uc2dc\ub9ac\uc988 ", ["\ubc15\uc18c\uc5f0", "\uc774\uba85\uc560"], 0, "", 0, ""], [1, "sim_E_\uc815\ubbf8\ud76c_s1_1781706800", 10, "\uc704\ud5d8\ud55c \ucc45 \uc77d\uae30 (\ud070\uae00\uc790\ub3c4\uc11c) - \u2018\ubb38\ud559\uc18c\ub140\u2019\uc5d0\uc11c \ud398\ubbf8\ub2c8\uc2a4\ud2b8\uae4c\uc9c0, \ud55c\uad6d \uc5ec\uc131 \ub3c5\uc11c\ubb38\ud654\uc0ac", ["\ud5c8\uc724"], 0, "", 0, "\uc5ed\uc0ac\uc801 \ubd84\uc11d\uc774 \uc8fc\ub41c \ub0b4\uc6a9\uc774\ub77c \uac10\uc815\uc801\uc73c\ub85c \ucda9\uc804\ud558\uae30\uc5d0\ub294 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694."], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 1, "\ud648\uba54\uc774\ub4dc\ucfe1 - \uc6b0\uc0ac\uae30\uc758 \uc6d0\ud50c\ub808\uc774\ud2b8 \uac00\uc815\uc2dd", ["\ub0a8\uc740\uc8fc"], 0, "", 1, "\uac00\uc815\uc2dd \ub808\uc2dc\ud53c\uac00 \uc27d\uace0 \uac04\ub2e8\ud558\uc5ec \uac00\uc871 \uac74\uac15\uc744 \uc704\ud55c \uc694\ub9ac\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 2, "\ud604\ub300\uc0dd\ud65c\uacfc \uac74\uac15\uad00\ub9ac", ["\ucd5c\uacf5\uc9d1"], 0, "", 1, "\uc0dd\ud65c\uc2b5\uad00\ubcd1\uacfc \uac74\uac15 \uad00\ub9ac\uc5d0 \ub300\ud55c \uccb4\uacc4\uc801\uc778 \uc815\ubcf4\uac00 \uac00\uc871 \uac74\uac15 \uac1c\uc120\uc5d0 \ub3c4\uc6c0\uc774 \ub429\ub2c8\ub2e4."], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 3, "\uaf2d\uaf2d \uc539\uc5b4\uba39\ub294 \uc601\uc591\uc774\uc57c\uae30 - \uc57d\uc0ac\uae30\uc790\uac00 \uc4f4 \uad6d\ub0b4 \ucd5c\ucd08\uc758 \uac74\uac15\ubcf4\uc870\uc2dd\ud488 \uc2ec\uce35 \ubd84\uc11d", ["\uc815\uc885\ud638"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 4, "\ud504\ub85c\ub4e4\uc758 \uc190\ub9db\uacf5\uc2dd - \ub9db\ub0b4\uae30 \ube44\ubc95 \uc644\uc804 \uc815\ubcf5!", ["\uc7a5\ub300\uc5f4"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 5, "\ub0a8\ud3b8 & \uc544\ub0b4 \uc0ac\uc6a9 \uc124\uba85\uc11c Gift Set - \ubd80\ubd80\uc758 \ud589\ubcf5\ud55c \uc0b6\uc744 \uc704\ud55c \uc9c0\uce68\uc11c", ["\uc774\ubcd1\uc900"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 6, "\uc0b0\uc18c \uac19\uc740 \uba39\uac70\ub9ac - \uc6b0\ub9ac \uac00\uc871 \uac74\uac15\uc744 \uc0b4\ub9ac\ub294", ["\ud669\uc9c0\ud76c"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 7, "\uc5b4\ub9b0\uc774\ub97c \uc704\ud55c \ub0b4\ubab8 \uc0ac\uc6a9 \uc548\ub0b4\uc11c -  \uc8fc\ub2c8\uc5b4 \uc2a4\ucfe8 6", ["\uc54c\ub808\ud55c\ub4dc\ub85c \uc54c\uac00\ub77c", "\uc874 \ub370\uc774\ube44\uc2a4"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 8, "\uc6b0\ub9ac \uc9d1\ubc25\ud574 \uba39\uc9c0 \uc54a\uc744\ub798\uc694? - \ub098\ub294 \uc65c \uc9d1\ubc25\ud558\ub294 \uc758\uc0ac\uac00 \ub410\ub294\uac00", ["\uc784\uc7ac\uc591"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 9, "\uc544\uc774\ub97c \ubcc0\ud654\uc2dc\ud0a4\ub294 \ub450\ub1cc \uc74c\uc2dd = Disease-Proof Your Child", ["\uc870\uc5d8 \ud384\uba3c"], 0, "", 0, ""], [2, "sim_E_\uc815\ubbf8\ud76c_s2_1781706854", 10, "\uc5d0\uc13c\uc2a4 \uc601\uc591\ud559", ["\uc11c\uad11\ud76c", "\uc11c\uc815\uc219", "\uc774\uc2b9\uad50", "\uc815\ud604\uc219", "\ubc15\ucc2c\uc724", "\uc724\uc608\ub9ac", "\uc774\uc724\uc815", "\uc815\uc720\ubbf8"], 0, "", 0, "\uc804\ubb38\uc801\uc778 \uc601\uc591\ud559\uc801 \ub0b4\uc6a9\uc774 \ub9ce\uc544 \uc77d\uae30 \uc5b4\ub824\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 1, "\uc775\uc219\ud55c \ubc14\ub78c\ub9de\uc774 3", ["\ud55c\uc21c\uc790"], 1, "\uc77c\uc0c1\uc5d0\uc11c \uc790\uc2e0\uc744 \ucc3e\ub294 \uc778\uc0dd \uc5ec\uc815\uacfc \uc18c\uc18c\ud55c \ud589\ubcf5\uc744 \ub2e4\ub8e8\uba70 \uacf5\uac10 \uac00\ub2a5\ud55c \ub0b4\uc6a9\uc73c\ub85c \uc2ec\ub9ac\uc801 \uc774\ud574\ub97c \ub113\ud788\ub294 \ub370 \ubd80\ud569\ud558\uace0, \uc18c\ud0c8\ud55c \ud544\ub825\uc73c\ub85c \uac10\uc815\uc774\uc785\uc774 \uc6a9\uc774\ud558\uba70, \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ub09c\uc774\ub3c4\uac00 \uc801\ud569\ud569\ub2c8\ub2e4.", 0, "\uc77c\uc0c1\uc5d0\uc11c\uc758 \uc18c\uc18c\ud55c \ud589\ubcf5\uc744 \ucc3e\ub294 \ub0b4\uc6a9\uc774\uc9c0\ub9cc, \uc2ec\ub9ac\uc801 \uae4a\uc774\uac00 \ubd80\uc871\ud574 \ubcf4\uc785\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 2, "\ud558\ub8e8 \ud55c \uc7a5 \uc5b4\ub978\uc744 \uc704\ud55c \ud544\uc0ac \ub178\ud2b8 - \uc0b6\uc758 \ubb34\uac8c\ub85c \ud798\uaca8\uc6cc\ud558\ub294 \uc5b4\ub978\ub4e4\uc5d0\uac8c \uc804\ud558\ub294 \ub530\ub73b\ud55c \uc704\ub85c", ["\ubc31\uc815\ubbf8"], 0, "", 1, "\uc9e7\uc740 \uae00\ub4e4\uc774 \uac10\uc815\uc801\uc73c\ub85c \uc6b8\ub9bc\uc744 \uc8fc\uba70, \uc790\uae30 \uc0ac\ub791\uc744 \uac15\uc870\ud558\ub294 \uc810\uc774 \ub9c8\uc74c\uc758 \ud3c9\ud654\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 3, "\ubaa8\ub4e0 \uacc4\uc808\uc774 \ub098\ub97c \ub9cc\ub4e4\uc5c8\ub2e4 (\ud070\uae00\uc790\ucc45) - \uc544\ud508 \ub9cc\ud07c \ub2e8\ub2e8\ud574\uc9c0\uace0 \uc788\uae30\uc5d0 \ub2f9\uc2e0\uc758 \ubaa8\ub4e0 \ub0a0\uc740 \ud5db\ub418\uc9c0 \uc54a\ub2e4", ["\uae40\uc2e0\uc77c"], 0, "", 0, ""], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 4, "\uc5c4\ub9c8\uac00 \ub418\uace0 \ub09c, \uc774\ub7f0 \uc0dd\uac01\uc744 \ud574", ["\ud45c\uc720\uc9c4"], 0, "\uc6cc\ud0b9\ub9d8\uc758 \uc721\uc544\uc640 \uc77c\uc758 \uac08\ub4f1\uc744 \ub2e4\ub8e8\ub294 \ub0b4\uc6a9\uc73c\ub85c, \uc0ac\uc6a9\uc790\uc758 2\uc778 \uac00\uad6c \uc0c1\ud669\uacfc \ub9de\uc9c0 \uc54a\uc73c\uba70 \ud2b9\uc815 \uc0dd\uc560 \ub2e8\uacc4(\uc721\uc544)\uc5d0 \uad6d\ud55c\ub41c \uc8fc\uc81c\ub85c \uc77c\ubc18\uc801\uc778 \uc2ec\ub9ac\uc801 \uc774\ud574 \ud655\uc7a5\uc774\ub77c\ub294 \ub3c5\uc11c \ubaa9\uc801\uacfc \uac70\ub9ac\uac00 \uc788\uc2b5\ub2c8\ub2e4.", 0, "\uc721\uc544\uc640 \uad00\ub828\ub41c \ub0b4\uc6a9\uc774\uc9c0\ub9cc, \uac1c\uc778\uc758 \uc815\uccb4\uc131 \ubb38\uc81c\uc5d0 \ub300\ud55c \uae4a\uc740 \ud0d0\uad6c\uac00 \ubd80\uc871\ud574 \ubcf4\uc785\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 5, "\uc5b4\ub978\uc774 \ub418\uba74 \uad1c\ucc2e\uc744 \uc904 \uc54c\uc558\ub2e4 - \uc2ec\ub9ac\ud559, \uc5b4\ub978\uc758 \uc548\ubd80\ub97c \ubb3b\ub2e4", ["\uae40\ud61c\ub0a8", "\ubc15\uc885\uc11d"], 0, "", 1, "\uc5b4\ub978\uc758 \uac10\uc815\uacfc \uace0\ud1b5\uc744 \ub2e4\ub8e8\uba70, \uc2ec\ub9ac\uc801 \uc774\ud574\ub97c \ub113\ud788\ub294 \ub370 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 6, "X\ud45c \ud558\uc2dc\uc624 - \uc544\uc774\ub4e4 131", ["\uc870\uc9c0\uc601", "\uc815\ubb38\uc8fc"], 0, "\uc544\uc774\ub4e4\uc758 \uc2ec\ub9ac\uc640 \uad00\uc810\uc744 \ub2e4\ub8e8\ub294 \uc544\ub3d9 \ubb38\ud559\uc73c\ub85c, \uc0ac\uc6a9\uc790\uc758 \uc2ec\ub9ac \uc7a5\ub974 \uc120\ud638\uc640 \uc131\uc778 \ub3c5\uc790\ub85c\uc11c\uc758 \ud604\uc7ac \uc0c1\ud669\uc5d0 \ub9de\uc9c0 \uc54a\uc73c\uba70 \ub9c8\uc74c\uc758 \ud3c9\ud654\ub97c \uc704\ud55c \uc2ec\ub9ac\uc801 \uc774\ud574 \ud655\uc7a5\uc774\ub77c\ub294 \ub3c5\uc11c \ubaa9\uc801\uacfc \uac70\ub9ac\uac00 \uc788\uc2b5\ub2c8\ub2e4.", 0, "\uc544\uc774\ub4e4\uc758 \uc2dc\uac01\uc5d0\uc11c \uc774\uc57c\uae30\ud558\uc9c0\ub9cc, \uc131\uc778 \ub3c5\uc790\uc758 \uc2ec\ub9ac\uc801 \uc774\ud574\uc640\ub294 \uac70\ub9ac\uac00 \uc788\uc5b4 \ubcf4\uc785\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 7, "\ucca0\ud5599\ub2e8\uc758 \ud790\ub9c1\ub178\ud2b8 - \uc0b6\uc758 \uc5f4\uc815\uacfc \uc9c0\ud61c\uc640 \ud589\ubcf5\uc744 \uc8fc\ub294", ["\uc774\ucc3d\ud638"], 0, "", 0, "\ucca0\ud559\uc801 \uc811\uadfc\uc774 \ub9ce\uc544 \uac10\uc815\uc774\uc785\uc774 \uc5b4\ub824\uc6b8 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 8, "\uaf2d \uc54c\uace0 \uc2f6\uc740 \ub3c5\uc11c\uce58\uc720\uc758 \ubaa8\ub4e0 \uac83", ["\uc724\uc120\ud76c"], 0, "\ub3c5\uc11c\uce58\uc720 \ubc29\ubc95\ub860\uacfc \ucc98\ubc29\uc804\uc744 \uc124\uba85\ud558\ub294 \uc2e4\uc6a9 \uc548\ub0b4\uc11c\ub85c, \uc2ec\ub9ac \uc7a5\ub974\uc758 \uac10\uc815\uc774\uc785\uacfc \uc0ac\ub840 \uc911\uc2ec\uc758 \uc77d\uae30 \uc2a4\ud0c0\uc77c\uacfc \ub9de\uc9c0 \uc54a\uc73c\uba70 \uc774\uc804 \uc7a5\ub974 \ubd88\uc77c\uce58 \uacbd\ud5d8\uc744 \uace0\ub824\ud560 \ub54c \uc801\ud569\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", 0, "\uc790\uac00 \ub3c5\uc11c\uce58\uc720\uc5d0 \ub300\ud55c \uc548\ub0b4\uc11c\ub85c, \uac10\uc815\uc801 \ucda9\uc804\ubcf4\ub2e4\ub294 \ubc29\ubc95\ub860\uc5d0 \uc911\uc810\uc744 \ub450\uace0 \uc788\uc5b4 \ubcf4\uc785\ub2c8\ub2e4."], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 9, "\uadf8 \uc5ec\uc790\uc758 \uc9d1 - 24 \uacbd\uae30\uc608\uc220\uc9c0\uc6d0 \ubb38\ud559\ucc3d\uc791\uc9c0\uc6d0 \uc120\uc815\uc791 ", ["\uae40\uc218\uc601"], 0, "", 0, ""], [3, "sim_E_\uc815\ubbf8\ud76c_s3_1781706927", 10, "\uc2dc\uc2dc\ud55c \uc2dc\uac04 \uc18d\uc5d0\uc11c", ["\ucc28\uc9c0\uc724"], 1, "\uc911\ub144 \uc5ec\uc131\uc758 \uc2ec\ub9ac\uc801 \uac08\ub4f1\uacfc \uc77c\uc0c1\uc758 \uace0\ubbfc\uc744 \ub2e4\ub8e8\ub294 \uc2ec\ub9ac \uc5d0\uc138\uc774\ub85c \ub3c5\uc11c \ubaa9\uc801\uc5d0 \ubd80\ud569\ud558\uba70, \uc12c\uc138\ud55c \uac10\uc218\uc131\uc73c\ub85c \uacf5\uac10\uacfc \uc704\ub85c\ub97c \uc804\ud558\ub294 \uac10\uc815\uc774\uc785 \uc6a9\uc774\ud55c \uad6c\uc131\uc774\uace0, \ubc24 \uc2dc\uac04 \ub098\ub9cc\uc758 \uc2dc\uac04\uc5d0 \ubd80\ub2f4 \uc5c6\uc774 \uc77d\uc744 \uc218 \uc788\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4.", 1, "\uc911\ub144 \uc5ec\uc131\uc758 \ub0b4\uc801 \uac08\ub4f1\uc744 \ub2e4\ub8e8\uba70, \uacf5\uac10\uacfc \uc704\ub85c\ub97c \uc804\ud558\ub294 \uc810\uc774 \ub9c8\uc74c\uc758 \ud3c9\ud654\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc2b5\ub2c8\ub2e4."]], "log_mode": "IMMUTABLE", "ncols": 9, "nrows": 30}
{"_type": "table", "column_types": {"params": {"type_map": {"all_queries": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "hypothetical_doc": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "original": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "persona_name": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "rewritten": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "session_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step_back": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "sub_queries": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["persona_name", "session_id", "original", "step_back", "rewritten", "sub_queries", "hypothetical_doc", "all_queries"], "data": [["A_\ucd5c\uc7ac\uc6d0", 1, "\uc0ac\uc6a9\uc790\ub294 \uc774\uc9c1 \uc900\ube44 \uc911\uc5d0 \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uace0 \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ud569\ub2c8\ub2e4. \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c \ubd84\uc57c\uc5d0 \ud2b9\ud788 \uad00\uc2ec\uc774 \uc788\uc73c\uba70, \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ub09c\uc774\ub3c4\ub85c \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \ub3c5\uc11c \uacbd\ud5d8\uc774 \ub9ce\uc9c0 \uc54a\uc544 \ucd94\ucc9c\uc744 \ubc1b\uace0 \uc2f6\uc5b4\ud558\ub294 \uc0c1\ud669\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ub9e5\ub77d\uc5d0\uc11c, \uc0ac\uc6a9\uc790\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \uacbd\uc81c \uad00\ub828 \ub3c4\uc11c\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uc2e4\uc0dd\ud65c\uc5d0 \uc989\uac01\uc801\uc73c\ub85c \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc778 \uacbd\uc81c \uc9c0\uc2dd\uc744 \uc6d0\ud558\uba70, \uc774\uc9c1 \uc900\ube44\ub77c\ub294 \uae34\ubc15\ud55c \uc0c1\ud669 \uc18d\uc5d0\uc11c \ube60\ub974\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud568. \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc5d0 \ub300\ud55c \uc815\ubcf4\uac00 \uba85\ud655\ud558\uace0 \uac04\uacb0\ud558\uac8c \uc804\ub2ec\ub418\ub294 \ubb38\uccb4\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\uba70, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc744 \uc6d0\ud560 \uc218 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \ub2e8\uc21c\ud788 \uc774\ub860\uc801\uc778 \uc9c0\uc2dd\ubfd0\ub9cc \uc544\ub2c8\ub77c, \uc2e4\uc81c \uc7ac\uc815 \uad00\ub9ac \ubc0f \ud22c\uc790 \uc804\ub7b5\uc744 \ud3ec\ud568\ud55c \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc744 \uc6d0\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc73c\uba70, \uc774\ub97c \ud1b5\ud574 \uc790\uc0b0 \uc99d\ub300\uc758 \uad6c\uccb4\uc801\uc778 \ubc29\ubc95\uc744 \ubc30\uc6b0\uace0 \uc2f6\uc5b4\ud568. \uacbd\uc81c \uad00\ub828 \uc11c\uc801\uc758 \uacbd\uc6b0, \uc774\uc804\uc5d0 \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \ucc45\uc744 \uc77d\uc5b4\ubcf4\uc9c0 \uc54a\uc558\uc73c\ubbc0\ub85c, \uc774\ubc88\uc5d0\ub294 \uae30\ucd08\ubd80\ud130 \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud558\ub294 \uc785\ubb38\uc11c\ub098 \uac00\uc774\ub4dc\ubd81\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ud07c. \uc774\uc9c1 \uc900\ube44\ub77c\ub294 \uac10\uc815\uc801 \uc694\uc18c\uac00 \uc788\uae30 \ub54c\ubb38\uc5d0, \ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \ub2e4\ub8ec \uc131\uacf5 \uc0ac\ub840\ub098 \ub3d9\uae30 \ubd80\uc5ec\uac00 \ub418\ub294 \uc11c\uc0ac\ub97c \ud3ec\ud568\ud55c \ucc45\uc744 \ud1b5\ud574 \uc2ec\ub9ac\uc801 \uc548\uc815\uc744 \ucc3e\uace0\uc790 \ud560 \uc218 \uc788\uc74c.", "", "", "[\"\uc774\uc9c1 \uc900\ube44\ub97c \ub3d5\ub294 \uc2e4\uc6a9\uc801\uc778 \uacbd\uc81c \ubc0f \uc7ac\ud14c\ud06c \uc785\ubb38\uc11c\", \"\uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc744 \ud1b5\ud574 \uacbd\uc81c \uc9c0\uc2dd\uc744 \uc27d\uac8c \uc804\ub2ec\ud558\ub294 \uc11c\uc801\", \"\ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \ub2e4\ub8ec \uc131\uacf5 \uc0ac\ub840\ub97c \ud3ec\ud568\ud55c \ub3d9\uae30 \ubd80\uc5ec \uc11c\uc801\"]", "\uc7ac\uc815\uc801 \uae30\ubc18\uc744 \ub2e4\uc9c0\uba70 \uc0c8\ub85c\uc6b4 \uacbd\ub85c\ub97c \ubaa8\uc0c9\ud558\ub294 \uc774\uc9c1 \uc900\ube44\uc790\ub4e4\uc744 \uc704\ud55c \uc2e4\uc6a9\uc801\uc778 \uac00\uc774\ub4dc\uc785\ub2c8\ub2e4. \uc774 \ucc45\uc740 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc758 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\uc5ec \ubcf5\uc7a1\ud558\uc9c0 \uc54a\uc740 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc73c\ub85c \ub3c5\uc790\ub4e4\uc774 \ud604\uba85\ud55c \uc7ac\uc815 \uad00\ub9ac\uc640 \ud22c\uc790 \uc804\ub7b5\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\uc90d\ub2c8\ub2e4. \uc790\uc0b0 \uc99d\ub300\uc758 \uc2e4\uc9c8\uc801\uc778 \ubc29\ubc95\uacfc \ud568\uaed8, \ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \uc774\ub8ec \ub2e4\uc591\ud55c \uc131\uacf5 \uc0ac\ub840\ub97c \ud1b5\ud574 \uc790\uadf9\uacfc \ub3d9\uae30 \ubd80\uc5ec\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uae08\uc735 \uc9c0\uc2dd\uc744 \uc27d\uac8c \uc2b5\ub4dd\ud558\uace0\uc790 \ud558\ub294 \ucd08\ubcf4\uc790\ub4e4\uc5d0\uac8c \uc644\ubcbd\ud558\uac8c \ub9de\ucd98 \uc774 \uc785\ubb38\uc11c\ub294 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc720\uc6a9\ud55c \ud1b5\ucc30\ub825\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.", "[\"\uc0ac\uc6a9\uc790\ub294 \uc774\uc9c1 \uc900\ube44 \uc911\uc5d0 \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uace0 \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ud569\ub2c8\ub2e4. \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c \ubd84\uc57c\uc5d0 \ud2b9\ud788 \uad00\uc2ec\uc774 \uc788\uc73c\uba70, \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ub09c\uc774\ub3c4\ub85c \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \ub3c5\uc11c \uacbd\ud5d8\uc774 \ub9ce\uc9c0 \uc54a\uc544 \ucd94\ucc9c\uc744 \ubc1b\uace0 \uc2f6\uc5b4\ud558\ub294 \uc0c1\ud669\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ub9e5\ub77d\uc5d0\uc11c, \uc0ac\uc6a9\uc790\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \uacbd\uc81c \uad00\ub828 \ub3c4\uc11c\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uc2e4\uc0dd\ud65c\uc5d0 \uc989\uac01\uc801\uc73c\ub85c \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc778 \uacbd\uc81c \uc9c0\uc2dd\uc744 \uc6d0\ud558\uba70, \uc774\uc9c1 \uc900\ube44\ub77c\ub294 \uae34\ubc15\ud55c \uc0c1\ud669 \uc18d\uc5d0\uc11c \ube60\ub974\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud568. \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc5d0 \ub300\ud55c \uc815\ubcf4\uac00 \uba85\ud655\ud558\uace0 \uac04\uacb0\ud558\uac8c \uc804\ub2ec\ub418\ub294 \ubb38\uccb4\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc73c\uba70, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc744 \uc6d0\ud560 \uc218 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \ub2e8\uc21c\ud788 \uc774\ub860\uc801\uc778 \uc9c0\uc2dd\ubfd0\ub9cc \uc544\ub2c8\ub77c, \uc2e4\uc81c \uc7ac\uc815 \uad00\ub9ac \ubc0f \ud22c\uc790 \uc804\ub7b5\uc744 \ud3ec\ud568\ud55c \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc744 \uc6d0\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc73c\uba70, \uc774\ub97c \ud1b5\ud574 \uc790\uc0b0 \uc99d\ub300\uc758 \uad6c\uccb4\uc801\uc778 \ubc29\ubc95\uc744 \ubc30\uc6b0\uace0 \uc2f6\uc5b4\ud568. \uacbd\uc81c \uad00\ub828 \uc11c\uc801\uc758 \uacbd\uc6b0, \uc774\uc804\uc5d0 \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \ucc45\uc744 \uc77d\uc5b4\ubcf4\uc9c0 \uc54a\uc558\uc73c\ubbc0\ub85c, \uc774\ubc88\uc5d0\ub294 \uae30\ucd08\ubd80\ud130 \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud558\ub294 \uc785\ubb38\uc11c\ub098 \uac00\uc774\ub4dc\ubd81\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ud07c. \uc774\uc9c1 \uc900\ube44\ub77c\ub294 \uac10\uc815\uc801 \uc694\uc18c\uac00 \uc788\uae30 \ub54c\ubb38\uc5d0, \ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \ub2e4\ub8ec \uc131\uacf5 \uc0ac\ub840\ub098 \ub3d9\uae30 \ubd80\uc5ec\uac00 \ub418\ub294 \uc11c\uc0ac\ub97c \ud3ec\ud568\ud55c \ucc45\uc744 \ud1b5\ud574 \uc2ec\ub9ac\uc801 \uc548\uc815\uc744 \ucc3e\uace0\uc790 \ud560 \uc218 \uc788\uc74c.\", \"\uc774\uc9c1 \uc900\ube44\ub97c \ub3d5\ub294 \uc2e4\uc6a9\uc801\uc778 \uacbd\uc81c \ubc0f \uc7ac\ud14c\ud06c \uc785\ubb38\uc11c\", \"\uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc744 \ud1b5\ud574 \uacbd\uc81c \uc9c0\uc2dd\uc744 \uc27d\uac8c \uc804\ub2ec\ud558\ub294 \uc11c\uc801\", \"\ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \ub2e4\ub8ec \uc131\uacf5 \uc0ac\ub840\ub97c \ud3ec\ud568\ud55c \ub3d9\uae30 \ubd80\uc5ec \uc11c\uc801\", \"\uc7ac\uc815\uc801 \uae30\ubc18\uc744 \ub2e4\uc9c0\uba70 \uc0c8\ub85c\uc6b4 \uacbd\ub85c\ub97c \ubaa8\uc0c9\ud558\ub294 \uc774\uc9c1 \uc900\ube44\uc790\ub4e4\uc744 \uc704\ud55c \uc2e4\uc6a9\uc801\uc778 \uac00\uc774\ub4dc\uc785\ub2c8\ub2e4. \uc774 \ucc45\uc740 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc758 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\uc5ec \ubcf5\uc7a1\ud558\uc9c0 \uc54a\uc740 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc73c\ub85c \ub3c5\uc790\ub4e4\uc774 \ud604\uba85\ud55c \uc7ac\uc815 \uad00\ub9ac\uc640 \ud22c\uc790 \uc804\ub7b5\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\uc90d\ub2c8\ub2e4. \uc790\uc0b0 \uc99d\ub300\uc758 \uc2e4\uc9c8\uc801\uc778 \ubc29\ubc95\uacfc \ud568\uaed8, \ubcc0\ud654\uc640 \uc131\uc7a5\uc744 \uc774\ub8ec \ub2e4\uc591\ud55c \uc131\uacf5 \uc0ac\ub840\ub97c \ud1b5\ud574 \uc790\uadf9\uacfc \ub3d9\uae30 \ubd80\uc5ec\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uae08\uc735 \uc9c0\uc2dd\uc744 \uc27d\uac8c \uc2b5\ub4dd\ud558\uace0\uc790 \ud558\ub294 \ucd08\ubcf4\uc790\ub4e4\uc5d0\uac8c \uc644\ubcbd\ud558\uac8c \ub9de\ucd98 \uc774 \uc785\ubb38\uc11c\ub294 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc720\uc6a9\ud55c \ud1b5\ucc30\ub825\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.\"]"], ["A_\ucd5c\uc7ac\uc6d0", 2, "\uc0ac\uc6a9\uc790\ub294 \ucd5c\uadfc \uacbd\uc81c \uacf5\ubd80\ub85c \uc778\ud574 \uc9c0\uccd0 \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \ucc45\uc744 \uc77d\uace0 \uc2f6\uc5b4\ud569\ub2c8\ub2e4. \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\uc73c\uba70 \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc744 \uc911\uc694\ud558\uac8c \uc5ec\uae30\uace0 \uc788\uc5b4, \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uac00\ubccd\uc9c0\ub9cc \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc81c\uacf5\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc774 \uc5c6\uae30 \ub54c\ubb38\uc5d0, \uc0c8\ub85c\uc6b4 \ucc45\uc744 \ucc3e\uace0 \uc788\ub294 \uc0c1\ud669\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ub9e5\ub77d\uc5d0\uc11c \uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac\uc758 \uac10\uc815\uc801 \ubd80\ub2f4\uc744 \ub35c\uc5b4\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uacbd\uc81c \uacf5\ubd80\ub85c \uc778\ud55c \uc815\uc2e0\uc801 \ud53c\ub85c\ub97c \ub35c\uc5b4\ub0b4\uace0 \uc2f6\uc5b4 \ud558\ubbc0\ub85c, \ub9c8\uc74c\uc774 \ud3b8\uc548\ud574\uc9c0\ub294 \ub530\ub73b\ud55c \ubd84\uc704\uae30\uc758 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc74c\ubbf8\ud558\uba70 \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc744 \uc911\uc694\uc2dc \uc5ec\uae30\ubbc0\ub85c, \uc11c\uc0ac \uad6c\uc870\uac00 \uba85\uc0c1\uc801\uc774\uac70\ub098 \uc790\uc5f0\uc744 \uc8fc\uc81c\ub85c \ud55c \uc5d0\uc138\uc774 \ud615\uc2dd\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uc0ac\uc6a9\uc790\ub294 \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uac00\ubcbc\uc6b4 \ub09c\uc774\ub3c4\ub97c \uc120\ud638\ud558\uc9c0\ub9cc, \ub3d9\uc2dc\uc5d0 \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc81c\uacf5\ud558\ub294 \uae4a\uc774 \uc788\ub294 \uc8fc\uc81c\ub97c \uc6d0\ud558\ubbc0\ub85c, \uc2ec\ub9ac\uc801 \ud1b5\ucc30\uc774\ub098 \uc0b6\uc758 \uc9c0\ud61c\ub97c \ub2e4\ub8ec \ucc45\uc744 \ucc3e\uc744 \uac00\ub2a5\uc131\uc774 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\uc5d0 \ub300\ud55c \uc774\uc804 \uacbd\ud5d8\uc774 \uc5c6\uc73c\ubbc0\ub85c, \uac10\uc815\uc801\uc73c\ub85c \uc5f0\uacb0\ub420 \uc218 \uc788\ub294 \uac1c\uc778\uc801\uc778 \uc774\uc57c\uae30\ub098 \uacbd\ud5d8\ub2f4\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ucd94\uce21\ub428. \ud604\uc7ac\uc758 \uc815\uc11c\uc801 \ubd80\ub2f4\uc744 \ub35c\uc5b4\uc8fc\ub294 \uac83 \uc678\uc5d0\ub3c4, \uc0ac\uc6a9\uc790\ub294 \uc0b6\uc5d0 \ub300\ud55c \uae0d\uc815\uc801\uc778 \uad00\uc810\uc774\ub098 \ud76c\ub9dd\uc801\uc778 \uba54\uc2dc\uc9c0\ub97c \uc804\ub2ec\ud558\ub294 \ub0b4\uc6a9\uc5d0 \ub04c\ub9b4 \uac00\ub2a5\uc131\uc774 \ub192\uc74c.", "", "", "[\"\ub9c8\uc74c\uc774 \ud3b8\uc548\ud574\uc9c0\ub294 \ub530\ub73b\ud55c \ubd84\uc704\uae30\uc758 \ud790\ub9c1 \uc5d0\uc138\uc774\", \"\uba85\uc0c1\uc801 \uc11c\uc0ac \uad6c\uc870\ub97c \uac00\uc9c4 \uc790\uc5f0\uc744 \uc8fc\uc81c\ub85c \ud55c \uc5d0\uc138\uc774\", \"\uc2ec\ub9ac\uc801 \ud1b5\ucc30\uc774\ub098 \uc0b6\uc758 \uc9c0\ud61c\ub97c \ub2e4\ub8ec \uac1c\uc778\uc801\uc778 \uc774\uc57c\uae30 \uc5d0\uc138\uc774\"]", "\uc0b6\uc758 \ubcf5\uc7a1\ud568 \uc18d\uc5d0\uc11c \uc783\uc5b4\ubc84\ub9b0 \ub098 \uc790\uc2e0\uc744 \ucc3e\uc544\uac00\ub294 \uc5ec\uc815, \uc774 \uc5d0\uc138\uc774\ub294 \uc77c\uc0c1\uc758 \uc18c\uc18c\ud55c \uc21c\uac04\uc5d0\uc11c \ubc1c\uacac\ud558\ub294 \ud3c9\ud654\uc640 \uae30\uc068\uc744 \uc774\uc57c\uae30\ud569\ub2c8\ub2e4. \uc800\uc790\ub294 \uc790\uc5f0\uc758 \uc544\ub984\ub2e4\uc6c0\uacfc \uac04\ub2e8\ud55c \uc0b6\uc758 \uc9c0\ud61c\ub97c \ud1b5\ud574 \ub9c8\uc74c\uc758 \uc548\uc815\uc744 \ub418\ucc3e\ub294 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud558\uba70, \ub3c5\uc790\uc5d0\uac8c \uc0ac\uc0c9\uc758 \uc2dc\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uac01 \uc7a5\uc740 \uac1c\uc778\uc801\uc778 \uacbd\ud5d8\ub2f4\uacfc \ud568\uaed8 \uae4a\uc774 \uc788\ub294 \ud1b5\ucc30\uc744 \ub2f4\uc544\ub0b4\uc5b4, \ud604\ub300\uc778\uc758 \uc815\uc2e0\uc801 \ud53c\ub85c\ub97c \ub35c\uc5b4\uc904 \ub530\ub73b\ud55c \uc704\ub85c\uc758 \uba54\uc2dc\uc9c0\ub97c \uc804\ud569\ub2c8\ub2e4. \uc9c0\uce5c \ub9c8\uc74c\uc744 \ub2ec\ub798\uace0 \uc2f6\uc740 \uc21c\uac04, \uc774 \ucc45\uc740 \ub2f9\uc2e0\uc758 \ub9c8\uc74c\uc744 \uac10\uc2f8\uc904 \ub530\uc2a4\ud55c \ub3d9\ubc18\uc790\uac00 \ub418\uc5b4\uc904 \uac83\uc785\ub2c8\ub2e4.", "[\"\uc0ac\uc6a9\uc790\ub294 \ucd5c\uadfc \uacbd\uc81c \uacf5\ubd80\ub85c \uc778\ud574 \uc9c0\uccd0 \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \ucc45\uc744 \uc77d\uace0 \uc2f6\uc5b4\ud569\ub2c8\ub2e4. \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\uc73c\uba70 \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc744 \uc911\uc694\ud558\uac8c \uc5ec\uae30\uace0 \uc788\uc5b4, \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uac00\ubccd\uc9c0\ub9cc \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc81c\uacf5\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc774 \uc5c6\uae30 \ub54c\ubb38\uc5d0, \uc0c8\ub85c\uc6b4 \ucc45\uc744 \ucc3e\uace0 \uc788\ub294 \uc0c1\ud669\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ub9e5\ub77d\uc5d0\uc11c \uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac\uc758 \uac10\uc815\uc801 \ubd80\ub2f4\uc744 \ub35c\uc5b4\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uacbd\uc81c \uacf5\ubd80\ub85c \uc778\ud55c \uc815\uc2e0\uc801 \ud53c\ub85c\ub97c \ub35c\uc5b4\ub0b4\uace0 \uc2f6\uc5b4 \ud558\ubbc0\ub85c, \ub9c8\uc74c\uc774 \ud3b8\uc548\ud574\uc9c0\ub294 \ub530\ub73b\ud55c \ubd84\uc704\uae30\uc758 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc74c\ubbf8\ud558\uba70 \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc744 \uc911\uc694\uc2dc \uc5ec\uae30\ubbc0\ub85c, \uc11c\uc0ac \uad6c\uc870\uac00 \uba85\uc0c1\uc801\uc774\uac70\ub098 \uc790\uc5f0\uc744 \uc8fc\uc81c\ub85c \ud55c \uc5d0\uc138\uc774 \ud615\uc2dd\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uc0ac\uc6a9\uc790\ub294 \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uac00\ubcbc\uc6b4 \ub09c\uc774\ub3c4\ub97c \uc120\ud638\ud558\uc9c0\ub9cc, \ub3d9\uc2dc\uc5d0 \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc81c\uacf5\ud558\ub294 \uae4a\uc774 \uc788\ub294 \uc8fc\uc81c\ub97c \uc6d0\ud558\ubbc0\ub85c, \uc2ec\ub9ac\uc801 \ud1b5\ucc30\uc774\ub098 \uc0b6\uc758 \uc9c0\ud61c\ub97c \ub2e4\ub8ec \ucc45\uc744 \ucc3e\uc744 \uac00\ub2a5\uc131\uc774 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\uc5d0 \ub300\ud55c \uc774\uc804 \uacbd\ud5d8\uc774 \uc5c6\uc73c\ubbc0\ub85c, \uac10\uc815\uc801\uc73c\ub85c \uc5f0\uacb0\ub420 \uc218 \uc788\ub294 \uac1c\uc778\uc801\uc778 \uc774\uc57c\uae30\ub098 \uacbd\ud5d8\ub2f4\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ucd94\uce21\ub428. \ud604\uc7ac\uc758 \uc815\uc11c\uc801 \ubd80\ub2f4\uc744 \ub35c\uc5b4\uc8fc\ub294 \uac83 \uc678\uc5d0\ub3c4, \uc0ac\uc6a9\uc790\ub294 \uc0b6\uc5d0 \ub300\ud55c \uae0d\uc815\uc801\uc778 \uad00\uc810\uc774\ub098 \ud76c\ub9dd\uc801\uc778 \uba54\uc2dc\uc9c0\ub97c \uc804\ub2ec\ud558\ub294 \ub0b4\uc6a9\uc5d0 \ub04c\ub9b4 \uac00\ub2a5\uc131\uc774 \ub192\uc74c.\", \"\ub9c8\uc74c\uc774 \ud3b8\uc548\ud574\uc9c0\ub294 \ub530\ub73b\ud55c \ubd84\uc704\uae30\uc758 \ud790\ub9c1 \uc5d0\uc138\uc774\", \"\uba85\uc0c1\uc801 \uc11c\uc0ac \uad6c\uc870\ub97c \uac00\uc9c4 \uc790\uc5f0\uc744 \uc8fc\uc81c\ub85c \ud55c \uc5d0\uc138\uc774\", \"\uc2ec\ub9ac\uc801 \ud1b5\ucc30\uc774\ub098 \uc0b6\uc758 \uc9c0\ud61c\ub97c \ub2e4\ub8ec \uac1c\uc778\uc801\uc778 \uc774\uc57c\uae30 \uc5d0\uc138\uc774\", \"\uc0b6\uc758 \ubcf5\uc7a1\ud568 \uc18d\uc5d0\uc11c \uc783\uc5b4\ubc84\ub9b0 \ub098 \uc790\uc2e0\uc744 \ucc3e\uc544\uac00\ub294 \uc5ec\uc815, \uc774 \uc5d0\uc138\uc774\ub294 \uc77c\uc0c1\uc758 \uc18c\uc18c\ud55c \uc21c\uac04\uc5d0\uc11c \ubc1c\uacac\ud558\ub294 \ud3c9\ud654\uc640 \uae30\uc068\uc744 \uc774\uc57c\uae30\ud569\ub2c8\ub2e4. \uc800\uc790\ub294 \uc790\uc5f0\uc758 \uc544\ub984\ub2e4\uc6c0\uacfc \uac04\ub2e8\ud55c \uc0b6\uc758 \uc9c0\ud61c\ub97c \ud1b5\ud574 \ub9c8\uc74c\uc758 \uc548\uc815\uc744 \ub418\ucc3e\ub294 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud558\uba70, \ub3c5\uc790\uc5d0\uac8c \uc0ac\uc0c9\uc758 \uc2dc\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uac01 \uc7a5\uc740 \uac1c\uc778\uc801\uc778 \uacbd\ud5d8\ub2f4\uacfc \ud568\uaed8 \uae4a\uc774 \uc788\ub294 \ud1b5\ucc30\uc744 \ub2f4\uc544\ub0b4\uc5b4, \ud604\ub300\uc778\uc758 \uc815\uc2e0\uc801 \ud53c\ub85c\ub97c \ub35c\uc5b4\uc904 \ub530\ub73b\ud55c \uc704\ub85c\uc758 \uba54\uc2dc\uc9c0\ub97c \uc804\ud569\ub2c8\ub2e4. \uc9c0\uce5c \ub9c8\uc74c\uc744 \ub2ec\ub798\uace0 \uc2f6\uc740 \uc21c\uac04, \uc774 \ucc45\uc740 \ub2f9\uc2e0\uc758 \ub9c8\uc74c\uc744 \uac10\uc2f8\uc904 \ub530\uc2a4\ud55c \ub3d9\ubc18\uc790\uac00 \ub418\uc5b4\uc904 \uac83\uc785\ub2c8\ub2e4.\"]"], ["A_\ucd5c\uc7ac\uc6d0", 3, "\uc0ac\uc6a9\uc790\ub294 \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\uc640 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc2ec\ub9ac\ud559\uc801\uc73c\ub85c \uc774\ud574\ud558\uace0 \uc2f6\uc5b4\ud558\uba70, \uc774\ub97c \uc704\ud574 \uc2ec\ub9ac\ud559 \ubd84\uc57c\uc758 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \ubc30\uc6b8 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc73c\uba70, \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc \ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc0ac\ub78c\uc740 \ubb34\uc5c7\uc73c\ub85c \uc0ac\ub294\uac00'\uc5d0\uc11c \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \uad00\uacc4 \ud615\uc131\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc744 \ud765\ubbf8\ub86d\uac8c \ub290\uaf08\uace0, \uc774 \uacbd\ud5d8\uc774 \uc9c1\uc7a5\uc5d0\uc11c\uc758 \uc18c\ud1b5 \uc774\ud574\uc5d0 \ub3c4\uc6c0\uc774 \ub418\uc5c8\ub2e4\uace0 \ubc1d\ud614\uc2b5\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ubc30\uacbd\uc744 \ubc14\ud0d5\uc73c\ub85c, \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uacfc \uc2e4\uc9c8\uc801\uc778 \uc0ac\ub840\ub97c \uc81c\uacf5\ud558\ub294 \ucc45\uc774 \ud544\uc694\ud558\ub2e4\uace0 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud558\uae30 \uc704\ud574 \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uc744 \uc81c\uacf5\ud558\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \ucc45\uc744 \uc6d0\ud568. \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc0ac\ub78c\uc740 \ubb34\uc5c7\uc73c\ub85c \uc0ac\ub294\uac00'\uc640 \uc720\uc0ac\ud558\uac8c, \ud604\uc7ac\ub294 \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \uac08\ub4f1 \ud574\uacb0\uc5d0 \ub300\ud55c \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \uae4a\uc774 \uc788\ub294 \uc774\ud574\ub97c \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc2ec\ub9ac\ud559\uc801 \uc6d0\ub9ac\ub97c \uc2e4\uc81c \uc0c1\ud669\uc5d0 \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc778 \uc811\uadfc \ubc29\uc2dd\uc744 \uc120\ud638\ud558\ubbc0\ub85c, \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840\uc640 \uc2a4\ud1a0\ub9ac\ub97c \uc911\uc2ec\uc73c\ub85c \uc9dc\uc5ec\uc9c4 \uc11c\uc0ac\ub97c \uc6d0\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \ud604\uc7ac \uc0ac\uc6a9\uc790\uc758 \uac10\uc815 \uc0c1\ud0dc\uc5d0\uc11c \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc \ud558\ubbc0\ub85c, \uc811\uadfc\uc131\uc774 \ub192\uc740 \ubb38\uccb4\uc640 \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \ucc45\uc744 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ubcf4\uc784. \uc9c1\uc7a5 \ub0b4 \uc778\uac04\uad00\uacc4\uc640 \uc18c\ud1b5\uc774 \uc8fc\uc694 \uad00\uc2ec\uc0ac\uc774\ubbc0\ub85c, \uc8fc\uc778\uacf5\uc774 \uc9c1\uc7a5 \ub0b4 \uac08\ub4f1\uc744 \ud574\uacb0\ud558\uac70\ub098 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uac1c\uc120\ud558\ub294 \uc5ec\uc815\uc774 \ub2f4\uae34 \uc11c\uc0ac\uc5d0 \uacf5\uac10\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \uc2ec\ub9ac\ud559 \uad00\ub828 \uc11c\uc801 \uc911\uc5d0\uc11c\ub3c4 \uc0ac\ub78c\uc758 \ud589\ub3d9\uacfc \ub3d9\uae30\ub97c \ud0d0\uad6c\ud558\ub294 \ucc45\uc744 \ud2b9\ud788 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ubcf4\uc774\uba70, \uc2e4\uc2b5\uc801 \uc694\uc18c\uac00 \ud3ec\ud568\ub41c \ucc45\uc774 \uc801\ud569\ud560 \uac83\uc784.", "", "", "[\"\uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uacfc \uc2e4\uc81c \uc0ac\ub840\ub97c \uc911\uc2ec\uc73c\ub85c \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud560 \uc218 \uc788\ub294 \ub3c4\uc11c\", \"\uc0ac\ub78c\ub4e4\uc774 \ub3d9\uae30\uc640 \uac08\ub4f1 \ud574\uacb0\uc5d0 \ub300\ud55c \uc0ac\ub840\ub97c \ud1b5\ud574 \uc778\uac04\uad00\uacc4\ub97c \ud0d0\uad6c\ud558\ub294 \uc11c\uc0ac \uc911\uc2ec\uc758 \ucc45\", \"\uc811\uadfc\uc131\uc774 \ub192\uc740 \ubb38\uccb4\ub85c \uc2e4\uc6a9\uc801\uc778 \uc2ec\ub9ac\ud559 \uc6d0\ub9ac\ub97c \uc81c\uc2dc\ud558\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \ub3c4\uc11c\"]", "\uc9c1\uc7a5 \ub0b4 \uac08\ub4f1\uacfc \uc18c\ud1b5\uc758 \ubbf8\ub85c\uc5d0\uc11c \uae38\uc744 \ucc3e\uace0\uc790 \ud558\ub294 \uc774\ub4e4\uc5d0\uac8c \uc644\ubcbd\ud55c \uc548\ub0b4\uc11c\uc785\ub2c8\ub2e4. \ub2e4\uc591\ud55c \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uc744 \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \ud589\ub3d9\uc744 \uae4a\uc774 \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\uc90d\ub2c8\ub2e4. \uc8fc\uc778\uacf5\uc774 \uc9c1\uc7a5\uc5d0\uc11c \uacaa\ub294 \uac08\ub4f1\uacfc \uc18c\ud1b5\uc758 \ubb38\uc81c\ub97c \ud574\uacb0\ud574 \ub098\uac00\ub294 \uc5ec\uc815\uc740 \ub3c5\uc790\uc5d0\uac8c \uacf5\uac10\uacfc \uc2e4\uc9c8\uc801\uc778 \uad50\ud6c8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc774 \ucc45\uc740 \uc2ec\ub9ac\ud559 \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc11c\uc0ac\ub85c, \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ubb38\uccb4\ub85c \uc4f0\uc5ec\uc838 \uc788\uc5b4 \ubd80\ub2f4 \uc5c6\uc774 \uc77d\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\ub97c \uac1c\uc120\ud558\ub824\ub294 \ubaa8\ub4e0 \uc774\uc5d0\uac8c \ud544\uc218\uc801\uc778 \uc9c0\uce68\uc11c\uac00 \ub420 \uac83\uc785\ub2c8\ub2e4.", "[\"\uc0ac\uc6a9\uc790\ub294 \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\uc640 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc2ec\ub9ac\ud559\uc801\uc73c\ub85c \uc774\ud574\ud558\uace0 \uc2f6\uc5b4\ud558\uba70, \uc774\ub97c \uc704\ud574 \uc2ec\ub9ac\ud559 \ubd84\uc57c\uc758 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \ubc30\uc6b8 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc73c\uba70, \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc \ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc0ac\ub78c\uc740 \ubb34\uc5c7\uc73c\ub85c \uc0ac\ub294\uac00'\uc5d0\uc11c \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \uad00\uacc4 \ud615\uc131\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc744 \ud765\ubbf8\ub86d\uac8c \ub290\uaf08\uace0, \uc774 \uacbd\ud5d8\uc774 \uc9c1\uc7a5\uc5d0\uc11c\uc758 \uc18c\ud1b5 \uc774\ud574\uc5d0 \ub3c4\uc6c0\uc774 \ub418\uc5c8\ub2e4\uace0 \ubc1d\ud614\uc2b5\ub2c8\ub2e4. \uc774\ub7ec\ud55c \ubc30\uacbd\uc744 \ubc14\ud0d5\uc73c\ub85c, \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uacfc \uc2e4\uc9c8\uc801\uc778 \uc0ac\ub840\ub97c \uc81c\uacf5\ud558\ub294 \ucc45\uc774 \ud544\uc694\ud558\ub2e4\uace0 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc0ac\uc6a9\uc790\ub294 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud558\uae30 \uc704\ud574 \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uc744 \uc81c\uacf5\ud558\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \ucc45\uc744 \uc6d0\ud568. \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc0ac\ub78c\uc740 \ubb34\uc5c7\uc73c\ub85c \uc0ac\ub294\uac00'\uc640 \uc720\uc0ac\ud558\uac8c, \ud604\uc7ac\ub294 \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \uac08\ub4f1 \ud574\uacb0\uc5d0 \ub300\ud55c \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \uae4a\uc774 \uc788\ub294 \uc774\ud574\ub97c \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc2ec\ub9ac\ud559\uc801 \uc6d0\ub9ac\ub97c \uc2e4\uc81c \uc0c1\ud669\uc5d0 \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc778 \uc811\uadfc \ubc29\uc2dd\uc744 \uc120\ud638\ud558\ubbc0\ub85c, \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840\uc640 \uc2a4\ud1a0\ub9ac\ub97c \uc911\uc2ec\uc73c\ub85c \uc9dc\uc5ec\uc9c4 \uc11c\uc0ac\ub97c \uc6d0\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \ud604\uc7ac \uc0ac\uc6a9\uc790\uc758 \uac10\uc815 \uc0c1\ud0dc\uc5d0\uc11c \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc \ud558\ubbc0\ub85c, \uc811\uadfc\uc131\uc774 \ub192\uc740 \ubb38\uccb4\uc640 \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \ucc45\uc744 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ubcf4\uc784. \uc9c1\uc7a5 \ub0b4 \uc778\uac04\uad00\uacc4\uc640 \uc18c\ud1b5\uc774 \uc8fc\uc694 \uad00\uc2ec\uc0ac\uc774\ubbc0\ub85c, \uc8fc\uc778\uacf5\uc774 \uc9c1\uc7a5 \ub0b4 \uac08\ub4f1\uc744 \ud574\uacb0\ud558\uac70\ub098 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uac1c\uc120\ud558\ub294 \uc5ec\uc815\uc774 \ub2f4\uae34 \uc11c\uc0ac\uc5d0 \uacf5\uac10\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c. \uc0ac\uc6a9\uc790\ub294 \uc2ec\ub9ac\ud559 \uad00\ub828 \uc11c\uc801 \uc911\uc5d0\uc11c\ub3c4 \uc0ac\ub78c\uc758 \ud589\ub3d9\uacfc \ub3d9\uae30\ub97c \ud0d0\uad6c\ud558\ub294 \ucc45\uc744 \ud2b9\ud788 \uc120\ud638\ud560 \uac83\uc73c\ub85c \ubcf4\uc774\uba70, \uc2e4\uc2b5\uc801 \uc694\uc18c\uac00 \ud3ec\ud568\ub41c \ucc45\uc774 \uc801\ud569\ud560 \uac83\uc784.\", \"\uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uacfc \uc2e4\uc81c \uc0ac\ub840\ub97c \uc911\uc2ec\uc73c\ub85c \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud560 \uc218 \uc788\ub294 \ub3c4\uc11c\", \"\uc0ac\ub78c\ub4e4\uc774 \ub3d9\uae30\uc640 \uac08\ub4f1 \ud574\uacb0\uc5d0 \ub300\ud55c \uc0ac\ub840\ub97c \ud1b5\ud574 \uc778\uac04\uad00\uacc4\ub97c \ud0d0\uad6c\ud558\ub294 \uc11c\uc0ac \uc911\uc2ec\uc758 \ucc45\", \"\uc811\uadfc\uc131\uc774 \ub192\uc740 \ubb38\uccb4\ub85c \uc2e4\uc6a9\uc801\uc778 \uc2ec\ub9ac\ud559 \uc6d0\ub9ac\ub97c \uc81c\uc2dc\ud558\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \ub3c4\uc11c\", \"\uc9c1\uc7a5 \ub0b4 \uac08\ub4f1\uacfc \uc18c\ud1b5\uc758 \ubbf8\ub85c\uc5d0\uc11c \uae38\uc744 \ucc3e\uace0\uc790 \ud558\ub294 \uc774\ub4e4\uc5d0\uac8c \uc644\ubcbd\ud55c \uc548\ub0b4\uc11c\uc785\ub2c8\ub2e4. \ub2e4\uc591\ud55c \uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uc744 \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \ud589\ub3d9\uc744 \uae4a\uc774 \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\uc90d\ub2c8\ub2e4. \uc8fc\uc778\uacf5\uc774 \uc9c1\uc7a5\uc5d0\uc11c \uacaa\ub294 \uac08\ub4f1\uacfc \uc18c\ud1b5\uc758 \ubb38\uc81c\ub97c \ud574\uacb0\ud574 \ub098\uac00\ub294 \uc5ec\uc815\uc740 \ub3c5\uc790\uc5d0\uac8c \uacf5\uac10\uacfc \uc2e4\uc9c8\uc801\uc778 \uad50\ud6c8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc774 \ucc45\uc740 \uc2ec\ub9ac\ud559 \uc774\ub860\ubcf4\ub2e4\ub294 \uc0ac\ub840 \uc911\uc2ec\uc758 \uc11c\uc0ac\ub85c, \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ubb38\uccb4\ub85c \uc4f0\uc5ec\uc838 \uc788\uc5b4 \ubd80\ub2f4 \uc5c6\uc774 \uc77d\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\ub97c \uac1c\uc120\ud558\ub824\ub294 \ubaa8\ub4e0 \uc774\uc5d0\uac8c \ud544\uc218\uc801\uc778 \uc9c0\uce68\uc11c\uac00 \ub420 \uac83\uc785\ub2c8\ub2e4.\"]"]], "log_mode": "IMMUTABLE", "ncols": 8, "nrows": 3}
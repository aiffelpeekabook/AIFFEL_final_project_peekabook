{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["step", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [[1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 1, "\ubd80\uc790 \uc544\ube60 \uac00\ub09c\ud55c \uc544\ube60 2", ["\ub85c\ubc84\ud2b8 \uae30\uc694\uc0ac\ud0a4"], 0, "\uc0ac\uc6a9\uc790\uac00 '\ub2e4\ub4e4 \uc77d\ub294 \ubed4\ud55c \ubca0\uc2a4\ud2b8\uc140\ub7ec'\ub97c \uc2eb\uc5b4\ud558\ub294\ub370, \uc774 \ucc45\uc740 \uc804 \uc138\uacc4\uc801 \uc5f4\ud48d\uc758 \uc18d\ud3b8\uc73c\ub85c \uc804\ud615\uc801 \uc7ac\ud14c\ud06c \ubca0\uc2a4\ud2b8\uc140\ub7ec\uc774\uba70, \ucd94\ucc9c \uadfc\uac70 \uc5c6\uc774 '\ub9c8\uc74c\uc744 \ub2e4\uc7a1\uace0 \uc77d\uc5b4\ub77c'\ub294 \uc2dd\uc758 \ubaa8\ud638\ud55c \ud45c\ud604\ub9cc \uc788\uc5b4 \uc0ac\uc6a9\uc790\uc758 pain point(\ucd94\ucc9c \uadfc\uac70 \uc5c6\uc73c\uba74 \uc190\uc774 \uc548 \uac10)\ub97c \ucda9\uc871\ud558\uc9c0 \ubabb\ud568.", 1, "\uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uc0c1\ud669\uc744 \uc810\uac80\ud558\uace0 \uacbd\uc81c\uc801 \uae30\ubc18\uc744 \ub2e4\uc9c0\uae30 \uc704\ud55c \uc2e4\uc6a9\uc801\uc778 \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294 \ucc45\uc785\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 2, "\uc8fc\uc2dd\ud68c\uc0ac \ub300\ud55c\ubbfc\uad6d, \uc774\uc81c \ub2e4\uc2dc \uc2dc\uc791\uc774\ub2e4", ["\uc0bc\uc815KPMG \uacbd\uc81c\uc5f0\uad6c\uc6d0"], 0, "\uae00\ub85c\ubc8c \uacbd\uc81c \uc704\uae30 \uc9c4\ub2e8\uacfc \uac70\uc2dc\uacbd\uc81c \ubc29\ud5a5\uc131\uc744 \ub2e4\ub8e8\ub294 \ucc45\uc73c\ub85c, \uc774\uc9c1 \uc900\ube44 \uc911 \uac1c\uc778\uc758 \uc7ac\uc815 \uae30\ubc18\uc744 \uc7a1\uace0 \uc2f6\uc740 \uc0ac\uc6a9\uc790\uc758 reading_goal(\uac1c\uc778 \uc7ac\ubb34 \uad00\ub9ac)\uacfc \ub9de\uc9c0 \uc54a\uc73c\uba70, \uacbd\uc81c\uc5f0\uad6c\uc6d0 \ucd9c\ud310\ubb3c\ub85c \ud559\uc220\uc801 \uc131\uaca9\uc774 \uac15\ud574 difficulty_level \ubd80\ub2f4 \uac00\ub2a5\uc131 \ub192\uc74c.", 0, "\uacbd\uc81c\uc704\uae30\uc640 \uad00\ub828\ub41c \ub0b4\uc6a9\uc774\uc9c0\ub9cc, \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud55c \uc2e4\uc9c8\uc801\uc778 \uc7ac\uc815 \uc804\ub7b5\ubcf4\ub2e4\ub294 \uc9c4\ub2e8\uacfc \ubc29\ud5a5 \uc81c\uc2dc\uac00 \uc8fc\ub97c \uc774\ub8e8\uc5b4 \ubd80\ub2f4\uc2a4\ub7ec\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 3, "\ub611\ub611\ud55c \uae08\uc735\uc0dd\ud65c - \uac74\uc804\ud55c \ud22c\uc790\uc640 \uac74\uac15\ud55c \uc7ac\ubb34\uc124\uacc4 \uc9c0\uce68\uc11c", ["\ubc15\ub355\ubc30"], 1, "\uae08\uc735 \uae30\ucd08\ubd80\ud130 \ud575\uc2ec\uae4c\uc9c0 \uccb4\uacc4\uc801\uc73c\ub85c \uc815\ub9ac\ud55c \uc2e4\uc6a9\uc11c\ub85c reading_goal(\uacbd\uc81c\uc801 \uae30\ubc18 \ub9c8\ub828)\uacfc preferred_genre(\uc7ac\ud14c\ud06c \uad50\uc591\uc11c)\uc5d0 \ubd80\ud569\ud558\uba70, '\uae30\ucd08\ubd80\ud130 \ud575\uc2ec\uae4c\uc9c0' '\uc2e4\uc6a9\uc11c'\ub77c\ub294 \ud45c\ud604\uc73c\ub85c reading_style(\ud575\uc2ec\uc774 \ubd84\uba85\ud558\uace0 \uc2e4\uc0dd\ud65c \uc5f0\uacb0)\uc744 \ucda9\uc871\ud558\uace0, \uac1c\uc778\uc758 \uc7ac\uc815 \uc5b4\ub824\uc6c0\uc744 \ud53c\ud558\uace0 \uacbd\uc81c\uc801 \uc0b6\uc744 \uc124\uacc4\ud558\ub3c4\ub85d \ub3d5\ub294 \ub0b4\uc6a9\uc774 \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc9c1\uc811 \ub3c4\uc6c0\ub428.", 1, "\ud575\uc2ec\uc801\uc778 \uae08\uc735 \uc9c0\uc2dd\uacfc \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ub0b4\uc6a9\uc744 \uc81c\uacf5\ud558\uc5ec \uc7ac\uc815\uc801 \uc5b4\ub824\uc6c0\uc744 \uadf9\ubcf5\ud558\ub294 \ub370 \ub3c4\uc6c0\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 4, "\ub530\ub77c\ud558\ub294 \uc7ac\ud14c\ud06c - \ub3c8 \uc880 \ubaa8\uc544\ubcfc\uae4c?", ["\uae40\uacbd\ud658"], 1, "Check list\uc640 To do list\ub85c '\ub530\ub77c\ud558\uba74' \uc2e4\ucc9c\ud560 \uc218 \uc788\ub294 \uad6c\uccb4\uc801 \uac00\uc774\ub4dc\ub85c reading_style(\uc2e4\uc0dd\ud65c \uc5f0\uacb0, \ud575\uc2ec \ubd84\uba85)\uc744 \ucda9\uc871\ud558\uace0, \uc791\uc2ec\uc0bc\uc77c \uadf9\ubcf5\uacfc \ub2e8\uacc4\ubcc4 \uc2e4\ud589\uc744 \uac15\uc870\ud574 \ud604\uc7ac '\uc9c0\uce58\uace0 \ub9c9\ub9c9\ud55c' \uc0c1\ud669\uc5d0\uc11c \ubc29\ud5a5\uc744 \ucc3e\uc73c\ub824\ub294 current_context\uc5d0 \uc815\ud655\ud788 \ubd80\ud569\ud558\uba70, \uc18c\ube44\u00b7\uc800\ucd95\u00b7\ud22c\uc790 \uc804\ubc18\uc744 \ub2e4\ub8e8\ub294 \uc2e4\uc6a9\uc801 \uc7ac\ud14c\ud06c \ucc45\uc73c\ub85c reading_goal\uacfc preferred_genre \ubaa8\ub450 \ub9cc\uc871.", 1, "\uc2e4\ucc9c \uac00\ub2a5\ud55c \uc7ac\ud14c\ud06c \ubc29\ubc95\uacfc \uccb4\ud06c\ub9ac\uc2a4\ud2b8\ub97c \uc81c\uacf5\ud558\uc5ec \uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uad00\ub9ac\uc5d0 \uc720\uc6a9\ud560 \uac83\uc785\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 5, "\ub3c8\uc758 \uc778\ubb38\ud559 - \uc9c0\uae08 \uc6b0\ub9ac\uc5d0\uac8c \ud544\uc694\ud55c \ub3c8\uacfc \uacbd\uc81c\uc5d0 \ub300\ud55c \ud1b5\ucc30", ["\ud64d\uc775\ud76c"], 0, "\uacbd\uc81c\uc0ac\uc801 \ubc18\ucd94, \uc0ac\ud68c\ud559\uc801 \uc870\ub9dd, \uacbd\uc81c \uc774\ub860 \ubd84\uc11d \ub4f1 \uc778\ubb38\ud559\uc801\u00b7\ud559\uc220\uc801 \uc811\uadfc\uc73c\ub85c difficulty_level(\ub108\ubb34 \ud559\uc220\uc801\uc778 \ucc45\uc740 \ubd80\ub2f4)\uc5d0 \ub9de\uc9c0 \uc54a\uc73c\uba70, \uac70\uc2dc\uacbd\uc81c \ud604\uc0c1 \ubd84\uc11d\uacfc \ud22c\uc790 \uc804\ub9dd\uc774 \uc8fc \ub0b4\uc6a9\uc73c\ub85c \uac1c\uc778\uc758 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80\uc774\ub77c\ub294 reading_goal\uacfc\uc758 \uc9c1\uc811\uc801 \uc5f0\uacb0\uc131\uc774 \uc57d\ud568.", 0, "\uacbd\uc81c \uc774\ub860\uacfc \ubd84\uc11d\uc774 \uc8fc\ub97c \uc774\ub8e8\uc5b4 \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub418\uae30 \uc5b4\ub824\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 6, "\uac78\uc5b4\ub2e4\ub2c8\ub294 \uacbd\uc81c\uc0ac", ["\ud669\uc138\uc5f0"], 0, "\uacbd\uc81c\uc0ac\ub97c \uc5ed\uc0ac \uc21c\uc11c\uc5d0 \ub530\ub77c \uc124\uba85\ud558\ub294 \uae30\ucd08 \uacbd\uc81c \uc785\ubb38\uc11c\ub85c, \uacbd\uc81c\uc815\ucc45 \ubcc0\ud654\uc640 \uc704\uae30 \uadf9\ubcf5 \uc0ac\ub840\ub97c \ub2e4\ub8e8\uc9c0\ub9cc \uac1c\uc778\uc758 \uc7ac\uc815 \uad00\ub9ac\uc640 \uc7ac\ud14c\ud06c\ub77c\ub294 reading_goal(\uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uae30\ubc18 \ub9c8\ub828)\uacfc \uc9c1\uc811\uc801 \uc5f0\uacb0\uc774 \uc57d\ud558\uace0, \uc774\ub860 \uc911\uc2ec\uc758 \uc785\ubb38\uc11c\ub85c '\uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub418\ub294' reading_style \uc694\uad6c\ub97c \ucda9\uc871\ud558\uae30 \uc5b4\ub824\uc6c0.", 0, "\uae30\ucd08 \uacbd\uc81c \uc785\ubb38\uc11c\ub85c, \ud604\uc7ac\uc758 \uc7ac\uc815\uc801 \uc0c1\ud669\uc5d0 \ub300\ud55c \uc2e4\uc9c8\uc801\uc778 \uc870\uc5b8\ubcf4\ub2e4\ub294 \uc774\ub860\uc801 \uc9c0\uc2dd\uc5d0 \uc911\uc810\uc744 \ub450\uace0 \uc788\uc5b4 \ubd80\ub2f4\uc2a4\ub7ec\uc6b8 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 7, "\uae08\uc735\uc9c0\uc2dd, \uc774\ubcf4\ub2e4 \uc26c\uc6b8 \uc218 \uc5c6\ub2e4", ["\uad8c\uc18c\ud604"], 1, "\uae08\uc735\uc2dc\uc7a5, \uc790\uc0b0\uc2dc\uc7a5, \uacbd\uc81c\uc9c0\ud45c \ub4f1\uc744 '\uc27d\uac8c \ud480\uc5b4\uc8fc\ub294' \uad6c\uc131\uc73c\ub85c reading_style(\ud575\uc2ec \ubd84\uba85, \uc2e4\uc0dd\ud65c \uc5f0\uacb0)\uc744 \ucda9\uc871\ud558\uace0, \uacbd\uc81c \ubd88\ud655\uc2e4\uc131 \uc18d \uc704\uae30 \uadf9\ubcf5\uc744 \uc704\ud55c \uae08\uc735 \uc9c0\uc2dd\uc744 \uc81c\uacf5\ud574 reading_goal(\uc7ac\uc815 \uc0c1\ud669 \uc810\uac80, \uacbd\uc81c\uc801 \uae30\ubc18 \ub9c8\ub828)\uacfc current_context(\ub9c9\ub9c9\ud55c \uc0c1\ud669\uc5d0\uc11c \ubc29\ud5a5 \ucc3e\uae30)\uc5d0 \ubd80\ud569\ud558\uba70, difficulty_level(\uc131\uc778 \uc77c\ubc18 \uc218\uc900)\ub3c4 \uc801\uc808\ud568.", 0, "\uacbd\uc81c\uc640 \uae08\uc735\uc5d0 \ub300\ud55c \uc804\ubc18\uc801\uc778 \uc9c0\uc2dd\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub418\ub294 \ub0b4\uc6a9\uc774 \ubd80\uc871\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 8, "\uacbd\uc81c\ud559, \ud604\uc2e4\uc5d0 \ub9d0\uc744 \uac78\ub2e4 - \ub354 \ub098\uc740 \ub0b4\uc77c\uc744 \uc704\ud55c \ud1b5\uc12d", ["\uc774\uba74\ud76c"], 0, "\uacbd\uc81c\ud559 \uc804\uacf5\uc790\uac00 \uc544\ub2cc \uc0ac\ub78c\uc744 \uc704\ud55c \ucc38\uace0\uc11c\uc774\uc9c0\ub9cc, \ud654\ud3d0\uc81c\ub3c4\u00b7\uc2e4\ubb3c\uacbd\uc81c\u00b7\uae08\uc735\uc704\uae30 \ub4f1 \uac70\uc2dc\uacbd\uc81c \uc774\ub860\uacfc \uc5ed\uc0ac\uc801 \uc0ac\ub840 \ubd84\uc11d\uc774 \uc8fc \ub0b4\uc6a9\uc73c\ub85c difficulty_level(\ud559\uc220\uc801 \uc131\uaca9)\uacfc reading_goal(\uac1c\uc778 \uc7ac\uc815 \uad00\ub9ac)\uc758 \uc9c1\uc811\uc801 \uc5f0\uacb0\uc131\uc774 \uc57d\ud558\uba70, \uac1c\uc778\uc758 \uc7ac\ud14c\ud06c \uc2e4\ud589 \ubc29\ubc95\ubcf4\ub2e4\ub294 \uacbd\uc81c \ud604\uc0c1 \uc774\ud574\uc5d0 \ucd08\uc810.", 0, "\uacbd\uc81c\ud559\uc801 \uc774\ub860\uacfc \ubcf5\uc7a1\ud55c \ub0b4\uc6a9\uc774 \ub9ce\uc544 \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 9, "\ub0b4 \uc0b6\uc744 \ubc14\uafbc \uc778\uc0dd\uc5ed\uc804 \ub3c5\uc11c\ubc95 - \uc800\ub294 \uc774 \ub3c5\uc11c\ubc95\uc73c\ub85c \uad6c\ub3c5\uc790 15\ub9cc, \uc5f0\ubd09 2\uc5b5\uc774 \ub418\uc5c8\uc2b5\ub2c8\ub2e4", ["\uc774\uc0c1\uc724"], 0, "\ub3c5\uc11c\ub97c \ud1b5\ud55c \uc131\uacf5 \uc2a4\ud1a0\ub9ac\uc640 \ub3c5\uc11c\ubc95 \uc790\uccb4\uac00 \uc8fc\uc81c\ub85c, preferred_genre(\uacbd\uc81c\u00b7\uc7ac\ud14c\ud06c \uad50\uc591\uc11c)\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, reading_goal(\uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80)\uacfc\ub3c4 \uc9c1\uc811\uc801 \uad00\ub828\uc774 \uc5c6\uace0, \uc720\ud29c\ubc84 \uc131\uacf5\ub2f4\uc73c\ub85c \uc0ac\uc6a9\uc790\uac00 \uc2eb\uc5b4\ud558\ub294 '\uc804\ud615\uc801\uc778 \uc790\uae30\uacc4\ubc1c\uc11c' \uc131\uaca9\uc5d0 \ud574\ub2f9.", 0, ""], [1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781706015", 10, "\ud30c\uc0b0\uc218\uc5c5 - \ubb34\ub108\uc9c4 \uc6b0\ub9ac\ub97c \ub2e4\uc2dc \uc138\uc6b0\ub294 \ubb38\ud559\uc758 \ud798", ["\uc815\uc7ac\uc5fd"], 0, "\ud68c\uc0ac \ubd80\ub3c4\uc640 \uc815\uc2e0\uc801 \ud30c\uc0b0 \uadf9\ubcf5 \uacfc\uc815\uc5d0\uc11c \ubb38\ud559 \uc77d\uae30\uc758 \uc704\ub85c\uc640 \ud68c\ubcf5\uc744 \ub2e4\ub8e8\ub294 \ucc45\uc73c\ub85c, preferred_genre(\uacbd\uc81c\u00b7\uc7ac\ud14c\ud06c \uad50\uc591\uc11c)\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, reading_goal(\uc7ac\uc815 \uae30\ubc18 \ub9c8\ub828, \uacbd\uc81c\uc801 \ubc29\ud5a5 \ucc3e\uae30)\uacfc\ub3c4 \ubb34\uad00\ud558\uace0, \ubb38\ud559\uc801 \uc704\ub85c\uac00 \uc8fc \ub0b4\uc6a9\uc73c\ub85c \uc2e4\uc6a9\uc801 \uc7ac\ud14c\ud06c \uc815\ubcf4\ub97c \uc6d0\ud558\ub294 \uc0ac\uc6a9\uc790\uc758 reading_style\uacfc \ubd80\ud569\ud558\uc9c0 \uc54a\uc74c.", 0, "\ubb38\ud559\uc801 \uc811\uadfc\uc73c\ub85c \uacbd\uc81c\uc801 \ud68c\ubcf5\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc2e4\uc9c8\uc801\uc778 \uc7ac\uc815 \uad00\ub9ac\uc640\ub294 \uac70\ub9ac\uac00 \uc788\uc5b4 \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 1, "\ucca0\ud5599\ub2e8\uc758 \ud790\ub9c1\ub178\ud2b8 - \uc0b6\uc758 \uc5f4\uc815\uacfc \uc9c0\ud61c\uc640 \ud589\ubcf5\uc744 \uc8fc\ub294", ["\uc774\ucc3d\ud638"], 0, "\uc18c\uac1c\uae00\uc5d0\uc11c '\uc790\uae30\uacc4\ubc1c\uc11c\uc640\ub294 \uc9c8\uc801\uc73c\ub85c \ub2e4\ub974\ub2e4'\uace0 \uac15\uc870\ud558\uc9c0\ub9cc, \uc2e4\uc81c\ub85c\ub294 '\ud798\uacfc \uc6a9\uae30\uc640 \uc9c0\ud61c\ub97c \uc804\ud574\uc8fc\ub294' \ub4f1 \uc804\ud615\uc801\uc778 \uc790\uae30\uacc4\ubc1c \uba54\uc2dc\uc9c0 \uad6c\uc870\ub97c \ub760\uace0 \uc788\uc5b4 \uc0ac\uc6a9\uc790\uc758 '\ubed4\ud55c \ubca0\uc2a4\ud2b8\uc140\ub7ec, \uc804\ud615\uc801\uc778 \uc790\uae30\uacc4\ubc1c\uc11c' \ud68c\ud53c \uc131\ud5a5\uacfc \ucda9\ub3cc\ud568.", 1, "\uc778\ubb38\ud559\uc801 \uae4a\uc774\uc640 \uac10\uc815\uc801 \uc704\ub85c\ub97c \ub3d9\uc2dc\uc5d0 \uc81c\uacf5\ud558\ub294 \ucc45\uc73c\ub85c, \ub2f9\uc2e0\uc758 \ud604\uc7ac \ub9c8\uc74c \uc0c1\ud0dc\uc5d0 \uc798 \ub9de\uc2b5\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 2, "\ub9c8\uc74c\uc774 \ud5a5\ud55c \uadf8\uacf3\uc5d0\uc11c \ub2e4\uc2dc \ud0dc\uc5b4\ub098\ub2e4", ["\uc724\uacbd\uc219"], 1, "\uc77c\uc0c1\uc758 \ub9c8\uc74c\uc744 \ub2f4\uc740 \uc5d0\uc138\uc774\ub85c preferred_genre(\uc778\ubb38, \ucca0\ud559 \uc5d0\uc138\uc774)\uc5d0 \ubd80\ud569\ud558\uace0, \uc9c0\uce5c \ub9c8\uc74c\uc744 \uc704\ub85c\ud558\ub294 reading_goal\uacfc \uc77c\uce58\ud558\uba70, \uac00\ubccd\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \uc5d0\ud53c\uc18c\ub4dc \uad6c\uc131\uc774 difficulty_level\uc5d0 \uc801\ud569\ud568.", 1, "\uc77c\uc0c1\uc5d0\uc11c\uc758 \ub9c8\uc74c \uce58\uc720\ub97c \ub2e4\ub8ec \uc5d0\uc138\uc774\ub85c, \ub2f9\uc2e0\uc774 \uc6d0\ud558\ub294 \uc704\ub85c\uc640 \uacf5\uac10\uc744 \uc904 \uc218 \uc788\uc744 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 3, "\ubcc4\ub09c \uac00\ub974\uce68 4 - \uac00\ub984\uce68\uc740 \uc0ac\ub791\uc774\ub2e4", ["\uae40\ucd98\ud604"], 0, "\uc8fc \ub300\uc0c1\uc774 '\uacf5\ubd80\uc5d0 \uc9c0\uce5c \uc544\uc774\ub4e4\uacfc \ubd80\ubaa8\ub2d8'\uc73c\ub85c \uc124\uc815\ub418\uc5b4 \uc788\uc5b4 32\uc138 \uc9c1\uc7a5\uc778\uc758 current_context(\ud1f4\uadfc \ud6c4 \ud63c\uc790 \uc0ac\uc0c9)\uc640 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uc544\uc774\ub4e4\uc744 \uc704\ud55c \uc774\uc57c\uae30\ub85c, \ub2f9\uc2e0\uc758 \ud604\uc7ac \ub9c8\uc74c \uc0c1\ud0dc\uc640\ub294 \uac70\ub9ac\uac00 \uc788\uc5b4 \ubcf4\uc785\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 4, "\ub2f9\uc2e0\uc5d0\uac8c \uc704\ub85c\uac00 \ub418\uc5c8\uc73c\uba74 \uc88b\uaca0\uc2b5\ub2c8\ub2e4 - \uc2ec\ub9ac\ud559 \uc5d0\uc138\uc774", ["\uc815\uc11c\uc544"], 1, "\uc2ec\ub9ac\ud559\uacfc \ucca0\ud559\uc744 \uc7ac\ud574\uc11d\ud55c \uc5d0\uc138\uc774\ub85c preferred_genre\uc5d0 \ubd80\ud569\ud558\uace0, '\ub2e4\uc815\ud558\uace0 \uae4a\uc774 \uc788\ub294 \uc5d0\uc138\uc774'\uac00 reading_style(\uae4a\uc774 \uc788\ub294 \uc0ac\uc0c9)\uacfc \uc77c\uce58\ud558\uba70, \uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c\uc744 \uc704\ub85c\ud558\ub294 reading_goal\uc744 \uc9c1\uc811 \ucda9\uc871\ud568.", 1, "\uc2ec\ub9ac\ud559\uc801 \ud1b5\ucc30\uacfc \uc704\ub85c\uc758 \uba54\uc2dc\uc9c0\ub97c \ub2f4\uace0 \uc788\uc5b4, \ub2f9\uc2e0\uc758 \ub9c8\uc74c\uc744 \uce58\uc720\ud558\ub294 \ub370 \ub3c4\uc6c0\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 5, "\uc0ac\ub791\ud558\ub77c \ub2e4\uc2dc \ud55c\ubc88 \ub354", ["\uae40\uc9c0\uc5f0"], 0, "\uc8fc\uc81c\uac00 \uc5f0\uc560\uc640 \uc0ac\ub791 \uadf9\ubcf5\uc5d0 \uc9d1\uc911\ub418\uc5b4 \uc788\uc5b4 '\uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c\uc744 \ub2ec\ub798\uc904 \ucc45'\uc774\ub77c\ub294 reading_goal\uacfc \uac70\ub9ac\uac00 \uc788\uace0, 1\uc778 \uac00\uad6c\uc758 \ud604\uc7ac \uc0c1\ud669\uacfc \ub9de\uc9c0 \uc54a\uc74c.", 1, "\uc0ac\ub791\uacfc \uc778\uc0dd\uc758 \uc758\ubbf8\ub97c \ud0d0\uad6c\ud558\uba70 \ud76c\ub9dd\uc801\uc778 \uba54\uc2dc\uc9c0\ub97c \uc804\ud558\ub294 \ucc45\uc73c\ub85c, \ub2f9\uc2e0\uc758 \uc0ac\uc0c9\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 6, "\ub4e4\uaf43 \uac19\uc740 \uac15\ubb3c\uc774", ["\uc815\ud558\uc131"], 1, "\uc790\uc5f0\uacfc \uc77c\uc0c1\uc758 \uc18c\ubc15\ud55c \uac10\uc131\uc73c\ub85c \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\ub294 \uc5d0\uc138\uc774\ub85c preferred_genre(\uc778\ubb38 \uc5d0\uc138\uc774)\uc5d0 \ubd80\ud569\ud558\uace0, '\uc7a0\uc2dc \uac78\uc74c\uc744 \uba48\ucd94\uace0 \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\ub77c'\ub294 \uba54\uc2dc\uc9c0\uac00 reading_goal(\uc0ac\uc0c9)\uacfc current_context(\uc870\uc6a9\ud788 \ud63c\uc790 \uc0ac\uc0c9)\uc5d0 \uc815\ud655\ud788 \ubd80\ud569\ud568.", 1, "\uc790\uc5f0\uacfc \uc77c\uc0c1\uc758 \uc18c\uc18c\ud55c \uae30\uc068\uc744 \uc774\uc57c\uae30\ud558\uba70 \uc5ec\uc720\ub97c \ucc3e\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ucc45\uc785\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 7, "\ub098\ub294 \ub108\uc640\uc758 \uc5f0\uc560\ub97c \ud6c4\ud68c\ud55c\ub2e4", ["\ud5c8\uc720\uc120"], 0, "\uc5f0\uc560\uc640 \uad00\uacc4\uc5d0 \ub300\ud55c \ucca0\ud559\uc801 \uace0\ubbfc\uc774 \uc8fc\uc81c\uc778\ub370, 1\uc778 \uac00\uad6c \uc0ac\uc6a9\uc790\uc758 \ud604\uc7ac \uc0c1\ud669\uacfc \uc9c1\uc811\uc801 \uad00\ub828\uc131\uc774 \ub0ae\uace0, reading_goal(\uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c)\uacfc \uac70\ub9ac\uac00 \uc788\uc74c.", 1, "\uc0ac\ub791\uacfc \uad00\uacc4\uc5d0 \ub300\ud55c \uae4a\uc740 \uace0\ubbfc\uc744 \ub2e4\ub8e8\uba70, \ub2f9\uc2e0\uc758 \uc0ac\uc0c9\uc744 \uc790\uadf9\ud560 \uc218 \uc788\ub294 \ub0b4\uc6a9\uc785\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 8, "30\uc77c \uc778\ubb38\ud559", ["\uc774\ud638\uac74"], 1, "\uc9c1\uc7a5\uc778\uc744 \uc704\ud55c \uc778\ubb38\ud559\uc73c\ub85c preferred_genre(\uc778\ubb38, \ucca0\ud559)\uc5d0 \ubd80\ud569\ud558\uace0, '\uc790\ud22c\ub9ac \uc2dc\uac04\uc5d0 \uc77d\uae30'\ub77c\ub294 \uad6c\uc131\uc774 difficulty_level(\uac00\ubccd\uac8c \uc77d\uc744 \uc218 \uc788\ub294)\uc5d0 \uc801\ud569\ud558\uba70, \uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \uc9c1\uc7a5\uc778\uc758 reading_goal\uc744 \uc9c1\uc811 \ud574\uacb0\ud568.", 0, "\uc9c1\uc7a5\uc778\ub4e4\uc744 \uc704\ud55c \uc778\ubb38\ud559\uc801 \uc811\uadfc\uc774\uc9c0\ub9cc, \ub2f9\uc2e0\uc774 \uc6d0\ud558\ub294 \uae4a\uc774 \uc788\ub294 \uc0ac\uc0c9\ubcf4\ub2e4\ub294 \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc774 \ub9ce\uc544 \ub9de\uc9c0 \uc54a\uc744 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 9, "\ub098\ub294 \ubb34\uc5c7\uc744 \ubaa8\ub974\ub294\uc9c0\uc870\ucc28 \ubaa8\ub974\uace0 \uc0b4\uc558\ub2e4", ["\uc774\uc885\uc6b1"], 1, "\uc77c\uc0c1\uc758 \uc18c\uc18c\ud55c \uc758\ubbf8\ub97c \ubc1c\uacac\ud558\ub294 \uc5d0\uc138\uc774\ub85c preferred_genre(\uc778\ubb38 \uc5d0\uc138\uc774)\uc5d0 \ubd80\ud569\ud558\uace0, '\ud558\ub8e8\ub97c \ub3cc\uc544\ubcf4\uba70 \ub9cc\uc871\ud560 \uc218 \uc788\uc744\uae4c'\ub77c\ub294 \uc0ac\uc0c9\uc801 \uad6c\uc870\uac00 reading_style\uacfc current_context(\ud1f4\uadfc \ud6c4 \ud63c\uc790 \uc0ac\uc0c9)\uc5d0 \uc815\ud655\ud788 \ub9de\uc74c.", 1, "\uc77c\uc0c1\uc5d0\uc11c\uc758 \uc791\uc740 \ud589\ubcf5\uc744 \ubc1c\uacac\ud558\uac8c \ud574\uc8fc\ub294 \uba54\uc2dc\uc9c0\ub97c \ub2f4\uace0 \uc788\uc5b4, \ub2f9\uc2e0\uc758 \ub9c8\uc74c\uc5d0 \uc704\ub85c\uac00 \ub420 \uac83\uc785\ub2c8\ub2e4."], [2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781706072", 10, "\ub2f9\uc2e0\uc740 \ub098\uc758 \uc0ac\ub78c\uc785\ub2c8\ub2e4", ["\uc774\uc194\uac74"], 0, "\uc2dc \ud615\uc2dd\uc758 \ub3c4\uc11c\ub85c preferred_genre(\uc5d0\uc138\uc774)\uc640 \ub2e4\ub974\uace0, \uc18c\uac1c\uae00\uc5d0\uc11c '\uc0c1\ucc98 \uce58\uc720'\uc5d0 \uc9d1\uc911\ub418\uc5b4 \uc788\uc5b4 '\uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c\uc744 \ub2ec\ub798\uc904' reading_goal\uacfc\uc758 \uc5f0\uacb0\uace0\ub9ac\uac00 \uba85\ud655\ud558\uc9c0 \uc54a\uc74c.", 1, "\uc704\ub85c\uc640 \uacf5\uac10\uc744 \uc8fc\ub294 \uc2dc\ub85c, \ub2f9\uc2e0\uc758 \uac10\uc815\uc801 \ud68c\ubcf5\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 1, "\uac00\uc7a5 \ub4e3\uace0 \uc2f6\uc740 \ud55c \ub9c8\ub514 yes!", ["\uae40\ud0dc\uc6d0"], 1, "\uc9c1\uc7a5 \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uacfc \uc2ec\ub9ac\ud559\uc744 \ub2e4\ub8e8\uba70 \uad6c\uccb4\uc801 \uc0ac\ub840 \uc911\uc2ec\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uace0, \uc800\uc790\uc758 \uc2e4\uc81c \uacbd\ud5d8\uc744 \ubc14\ud0d5\uc73c\ub85c \uc2e4\ubb34 \uc801\uc6a9 \uac00\ub2a5\ud55c \ub0b4\uc6a9\uc744 \uc81c\uc2dc\ud558\uc5ec \uc0ac\uc6a9\uc790\uc758 \ubaa9\ud45c\uc640 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uc5d0 \ubd80\ud569\ud568.", 1, "\uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \ubb38\uc81c\ub97c \ub2e4\ub8e8\uace0 \uad6c\uccb4\uc801\uc778 \uc0ac\ub840\ub97c \ud1b5\ud574 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\uc5b4 \ud765\ubbf8\ub85c\uc6b8 \uac83 \uac19\uc544\uc694."], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 2, "\uc778\uac04\uad00\uacc4\ub860", ["\ub098\uc0c1\uc6b4", "\ubcc0\uc6a9\ub9cc", "\uc774\uc601\uc8fc", "\uc784\uad6c\uc6d0"], 0, "\uc2ec\ub9ac\ud559 \uae30\ubc18\uc774\uc9c0\ub9cc \uc9c1\uc7a5 \uad00\uacc4\uc5d0 \ud2b9\ud654\ub418\uc9c0 \uc54a\uc558\uace0, \uc0dd\uc560\ubc1c\ub2ec\uc8fc\uae30 \ub4f1 \uad11\ubc94\uc704\ud55c \uc778\uac04\uad00\uacc4\ub97c \ub2e4\ub8e8\uc5b4 \uc0ac\uc6a9\uc790\uc758 \uad6c\uccb4\uc801 \ubaa9\ud45c(\uc9c1\uc7a5 \uad00\uacc4 \uc774\ud574)\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70 \uad50\uacfc\uc11c\uc801 \uad6c\uc131\uc73c\ub85c \ubcf4\uc784.", 1, "\ub2e4\uc591\ud55c \uc778\uac04\uad00\uacc4\uc758 \uc720\ud615\uacfc \uac08\ub4f1 \ud574\uacb0 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud574 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc544\uc694."], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 3, "\ud558\uc9c0\ud604 \ubc15\uc0ac\uc758 \uc18c\ud1b5&\uacf5\uac10 - \uc0ac\uc18c\ud55c \ub9d0 \ud55c\ub9c8\ub514\uc5d0\ub3c4 \uc0c1\ucc98\ubc1b\ub294 \uc9c1\uc7a5\uc778\ub4e4\uc744 \uc704\ud55c \uc2ec\ub9ac\ud559 \uba58\ud1a0\ub9c1", ["\ud558\uc9c0\ud604"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 4, "\ub9ac\ub354\uc2ed\uc758 \uc2ec\ub9ac\ud559 - MBA \ub9ac\ub354\uc2ed \uc5d0\uc13c\uc2a4 = Psychology for Leaders", ["\ub518 \ud1a0\uc988\ubcfc\ub4dc", "\uba54\ub9ac \ud1a0\uc988\ubcfc\ub4dc"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 5, "\uc0ac\ub78c\uacfc \uc870\uc9c1\uc744 \uc6c0\uc9c1\uc774\ub294 \uc2ec\ub9ac\ud30c\uc6cc\uc758 \ube44\ubc00 30", ["\ud1a0\ubbf8\uc2dc\uac8c \ucf04\uc774\uce58"], 1, "\uc2ec\ub9ac\ud559 \uae30\ubc18\uc73c\ub85c \uc9c1\uc7a5 \uc0c1\ud669\uc758 \uad6c\uccb4\uc801 \uc0ac\ub840\ub97c \ud1b5\ud574 \uc0ac\ub78c \uc2ec\ub9ac\ub97c \uc77d\ub294 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud558\uba70, \uc2e4\ubb34 \uc801\uc6a9 \uac00\ub2a5\ud55c \uad6c\uc131\uc73c\ub85c \uc0ac\uc6a9\uc790\uc758 \ubaa9\ud45c\uc640 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uc5d0 \ubd80\ud569\ud568.", 1, "\uc0ac\ub78c\uc758 \uc2ec\ub9ac\ub97c \uc77d\ub294 \ubc29\ubc95\uacfc \uad6c\uccb4\uc801\uc778 \ube44\uc988\ub2c8\uc2a4 \uc0c1\ud669\uc744 \ub2e4\ub8e8\uc5b4 \uc2e4\uc6a9\uc801\uc77c \uac83 \uac19\uc544\uc694."], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 6, "\ub208\uce58\ucf54\uce58 \uc2ec\ub9ac\ud559 - \ud0c0\uc778\uc758 \uc9c4\uc2ec\uc744 \ube68\ub9ac \uc54c\uc544\ucc28\ub9ac\ub294 \ub098\ub9cc\uc758 \ub178\ud558\uc6b0", ["\uc2dc\ubd80\uc57c \uc1fc\uc870"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 7, "\uc18c\ud1b5\uc758 \uae30\uc220 - \ub9d0 \ud55c\ub9c8\ub514\uac00 \uc6b4\uba85\uc744 \ubc14\uafb8\uace0 \uc778\uc0dd\ub3c4 \ubc14\uafbc\ub2e4", ["\uc774\ud638\ud604"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 8, "\uc774\ub04c\uc9c0 \ub9d0\uace0 \ub530\ub974\uac8c \ud558\ub77c - \uc0c8\ub85c\uc6b4 \ub9ac\ub354\uc2ed\uc744 \uc704\ud55c \uc9c0\ud61c\uc758 \uc2ec\ub9ac\ud559", ["\uae40\uacbd\uc77c"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 9, "\ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc740 \uacfc\ud559\uc774\ub2e4 - \ud6a8\uacfc\uc801\uc778 \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc744 \uc704\ud55c 7\ub2e8\uacc4 \uc804\ub7b5 = The Art and Science of Communication (2008)", ["\ud30c\uba5c\ub77c S. \ud37c\ud0a8\uc2a4"], 0, "", 0, ""], [3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781706151", 10, "\uc778\uac04\uad00\uacc4\uc758 \uc9c0\ud61c 88\uac00\uc9c0", ["\uc774\uc640\uc4f0\ud0a4 \uac90\uc9c0"], 0, "88\uac00\uc9c0 \ud56d\ubaa9 \uc911\uc2ec\uc758 \uad6c\uc131\uc73c\ub85c \uc0ac\uc6a9\uc790\uac00 \uc120\ud638\ud558\ub294 '\uc0ac\ub840 \uc911\uc2ec \uc77d\uae30 \uc26c\uc6b4 \uad6c\uc131'\uacfc \ub9de\uc9c0 \uc54a\uc73c\uba70, \uac00\uc871\u00b7\ubd80\ubd80 \ub4f1 \uad11\ubc94\uc704\ud55c \uc778\uac04\uad00\uacc4\ub97c \ub2e4\ub8e8\uc5b4 \uc9c1\uc7a5 \uad00\uacc4 \uc774\ud574\ub77c\ub294 \ubaa9\ud45c\uc640 \ucd08\uc810\uc774 \ub2e4\ub984.", 1, "\ub2e4\uc591\ud55c \uc778\uac04\uad00\uacc4\uc758 \uac08\ub4f1\uc744 \ubd84\uc11d\ud558\uace0 \ud574\ubc95\uc744 \uc81c\uc2dc\ud574 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5\uc5d0 \uc720\uc6a9\ud560 \uac83 \uac19\uc544\uc694."]], "log_mode": "IMMUTABLE", "ncols": 9, "nrows": 30}
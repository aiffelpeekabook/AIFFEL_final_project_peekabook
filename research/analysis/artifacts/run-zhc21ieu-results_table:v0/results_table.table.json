{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "book_intro": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "category": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "persona_name": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "reflection": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "session_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "summary": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["rank", "persona_name", "session_id", "title", "author", "category", "book_intro", "score", "reason", "summary", "reflection"], "data": [[1, "C_\uc624\ubbfc\uc544", "5b3decfe", "Unity 3D Game Development by Example \ud55c\uad6d\uc5b4\ud310 - \uc720\ub2c8\ud2f0 3D \uac8c\uc784 \ud504\ub85c\uadf8\ub798\ubc0d = Unity 3D Game Development by Example", ["\ub77c\uc774\uc5b8 \ud5e8\uc2a8 \ud06c\ub808\uc774\ud2bc"], "\ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c/\ubc29\ubc95\ub860", "\ubaa8\ubc14\uc77c\uc6a9 \uac8c\uc784 \uc5d4\uc9c4\uc73c\ub85c \uac01\uad11 \ubc1b\uace0 \uc788\ub294 \uc720\ub2c8\ud2f0 3\uc758 \uc785\ubb38\uc11c\ub2e4. \uc0c1\uc138\ud55c \uc124\uba85\uacfc \uc608\uc81c \ud30c\uc77c\uc744 \ud1b5\ud574, \uac1c\ubc1c \uacbd\ud5d8\uacfc \uc804\ubb38 \uc9c0\uc2dd\uc774 \uc5c6\ub294 \ucd08\ubcf4\uc790\ub3c4 \ucf54\ub529\uc744 \ud1b5\ud574 \uc2e4\uc81c\ub85c \uac8c\uc784\uc744 \ub9cc\ub4e4 \uc218 \uc788\ub3c4\ub85d \uce5c\uc808\ud558\uac8c \uc548\ub0b4\ud55c\ub2e4. \ucd1d 4\uac1c\uc758 \uac8c\uc784\uc744 \ub9cc\ub4dc\ub294 \uacfc\uc815\uc5d0\uc11c \uc720\ub2c8\ud2f0 3\uc758 \ud575\uc2ec \uac1c\ub150\uacfc \uae30\ub2a5\uc744 \uc18c\uac1c\ud558\ub294 \uc774 \ucc45\uc73c\ub85c \uac8c\uc784\uc744 \uad6c\uc131\ud558\ub294 \uae30\ud68d\uacfc \ud504\ub85c\uadf8\ub798\ubc0d\uacfc \uc544\ud2b8 \uc804\ubc18\uc5d0 \ub300\ud55c \uc774\ud574\ub97c \ub113\ud790 \uc218 \uc788\ub2e4.", 1, "\uc720\ub2c8\ud2f0 3\uc758 \uc785\ubb38\uc11c\ub85c \ucd08\ubcf4\uc790\uac00 \uac8c\uc784\uc744 \ub9cc\ub4e4 \uc218 \uc788\ub3c4\ub85d \uce5c\uc808\ud558\uac8c \uc548\ub0b4\ud558\uba70, \ub2e8\uacc4\uc801\uc778 \uc124\uba85\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc5b4 \uc801\ud569\ud558\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [2, "C_\uc624\ubbfc\uc544", "5b3decfe", "\uc720\ub2c8\ud2f0 5 \uac8c\uc784 \uc81c\uc791 \uac00\uc774\ub4dc - \ucd08\ubcf4\uc790\ub97c \uc704\ud55c", ["\uc8fc\ub3d9\uadfc"], "\ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c/\ubc29\ubc95\ub860", "\ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uc720\ub2c8\ud2f0 5 \uac8c\uc784 \uc81c\uc791 \uac00\uc774\ub4dc \ub294 \ud504\ub85c\uadf8\ub7a8\uc774 \ucc98\uc74c\uc778 \uc0ac\ub78c\uc774 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \uae30\ubcf8\uc801\uc778 \uc6a9\uc5b4\ubd80\ud130 \uc2dc\uc791\ud574\uc11c, \uac8c\uc784 \uac1c\ubc1c \ud658\uacbd\uc5d0 \ub300\ud55c \uc548\ub0b4, \ud504\ub85c\uadf8\ub798\ubc0d \uae30\ucd08 \ub4f1 \uac8c\uc784 \uc81c\uc791\uc744 \uc704\ud55c \uae30\ubcf8\uc801\uc778 \ub0b4\uc6a9\uc744 \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud558\uace0 \uc788\uc73c\uba70, \uae30\uc874\uc5d0 \uc720\ub2c8\ud2f0\ub97c \ub2e4\ub904\ubd24\ub358 \uc911\uae09 \uac1c\ubc1c\uc790\ub97c \uc704\ud574\uc11c \uac8c\uc784 \uc81c\uc791 \uacfc\uc815\uc5d0\uc11c \ubc14\ub85c \ucc38\uace0\ud560 \uc218 \uc788\ub3c4\ub85d \ucd5c\ub300\ud55c \uac04\ub7b5\ud558\uba74\uc11c\ub3c4 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc744 \uc815\ub9ac\ud574\uc11c \ub2f4\uace0 \uc788\ub2e4.", 1, "\ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uc720\ub2c8\ud2f0 5 \uac8c\uc784 \uc81c\uc791 \uac00\uc774\ub4dc\ub85c, \uae30\ubcf8\uc801\uc778 \uc6a9\uc5b4\ubd80\ud130 \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud558\uc5ec \uc785\ubb38\uc790\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [3, "C_\uc624\ubbfc\uc544", "5b3decfe", "\uacfc\ud559 \uc601\uc7ac\ub97c \ub9cc\ub4dc\ub294 \uc544\ub450\uc774\ub178 \uad50\uc2e4 - \uc544\ube60\uc640 \ud568\uaed8 \uc544\ub450\uc774\ub178 \uc791\ud488 \ub9cc\ub4e4\uae30", ["\ucd5c\uc7ac\ucca0", "\ub9c8\ucc3d\uc218"], "\ucef4\ud4e8\ud130 \uacf5\ud559", "\uacfc\ud559 \uc601\uc7ac\ub97c \uafc8\uafb8\ub294 \ud559\uc0dd\ub4e4, \uc790\ub140, \ud559\uc0dd\uacfc \ud568\uaed8 \uc9c1\uc811 \uc544\ub450\uc774\ub178 \uc791\ud488\uc744 \ub9cc\ub4e4\uc5b4\ubcf4\uba70 \ud765\ubbf8\ub85c\uc6b4 \uacfc\ud559 \uc2e4\uc2b5\uc744 \ud574\ubcf4\uace0 \uc2f6\uc5b4\ud558\ub294 \uad50\uc0ac\uc640 \ubd80\ubaa8, IoT \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \uc785\ubb38\ud574\ubcf4\uace0 \uc2f6\uc740 \ucd08\ubcf4 \ud504\ub85c\uadf8\ub798\ubc0d \uc785\ubb38\uc790 \ub4f1 \ubaa8\ub4e0 \uc0ac\ub78c\uc5d0\uac8c \uaf2d \ud544\uc694\ud55c \ucd5c\uace0\uc758 \uc9c0\uce68\uc11c\ub2e4. \ucf54\ub4dc \ud55c \uc904 \ubab0\ub77c\ub3c4, \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ub300\ud55c \uc9c0\uc2dd\uc774 \uc5c6\uc5b4\ub3c4 \ucd5c\ub300\ud55c \uc774\ud574\ud558\uae30 \uc27d\uace0 \ub204\uad6c\ub77c\ub3c4 \uac04\ub2e8\ud788 \ub9cc\ub4e4 \uc218 \uc788\uac8c \uc124\uba85\ud558\uc600\ub2e4. \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \uad00\ud55c \uae30\ucd08\uc801\uc778 \ubd80\ubd84\ub3c4 \uc124\uba85\ud558\uace0 \uc788\uc73c\uba70, \uac00\ub2a5\ud55c \uc911\ub3c4\uc5d0 \ud3ec\uae30\ud558\uc9c0 \uc54a\ub3c4\ub85d \uc2ec\ud608\uc744 \uae30\uc6b8\uc5ec \uc9d1\ud544\ud558\ub2e4. \uc5b4\uca4c\uba74 \uc0dd\uac01\ubcf4\ub2e4 \uc26c\uc6b4 \uac1c\ubc1c\uc5d0 \ub180\ub77c\uc6c0\uc744 \ub290\ub084 \uc218\ub3c4 \uc788\uc744 \uac83\uc774\ub2e4.", 0, "\uc544\ub450\uc774\ub178\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c \uac8c\uc784 \uac1c\ubc1c\uacfc\ub294 \uad00\ub828\uc774 \uc801\uc5b4 \uc0ac\uc6a9\uc790\uc758 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\ub294\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [4, "C_\uc624\ubbfc\uc544", "5b3decfe", "\ud30c\uc774\uc36c\uc73c\ub85c \ubc30\uc6b0\ub294 \uac8c\uc784 \uac1c\ubc1c \uc2e4\uc804\ud3b8 - \uc7a5\uc560\ubb3c \ud53c\ud558\uae30, \ub2f7\uc787 \uc561\uc158, \ub9f5 \uc5d0\ud2f0\ud130, \ud0c4\ub9c9 \uc288\ud305, 3D \uce74 \ub808\uc774\uc2f1, \uac8c\uc784 \ub7f0\ucc98 \ub4f1\uc744 \ub9cc\ub4e4\uba70 \ubc30\uc6b4\ub2e4!", ["\ud788\ub85c\uc138 \uce20\uc694\uc2dc"], "\ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4", "\ud30c\uc774\uc36c\uc744 \ud1b5\ud574 \ubcf8\uaca9\uc801\uc73c\ub85c \uc0c1\uc5c5\uc6a9 \uac8c\uc784\uc744 \ub9cc\ub4e0\ub2e4! 25\ub144\ucc28 \ud604\uc9c1 \uac8c\uc784 \ud504\ub85c\uadf8\ub798\uba38\uac00 \uc54c\ub824 \uc8fc\ub294 \uac8c\uc784 \uac1c\ubc1c \ub178\ud558\uc6b0! \uc774 \ucc45\uc740 \ud30c\uc774\uc36c\uc73c\ub85c \ubc30\uc6b0\ub294 \uac8c\uc784 \uac1c\ubc1c \uc785\ubb38\ud3b8 \uc758 \ud6c4\ud3b8\uc73c\ub85c, \uc561\uc158 \uac8c\uc784, \uc288\ud305 \uac8c\uc784, \uc720\uc0ac 3D \uc601\uc0c1 \ud45c\ud604\uc744 \ud65c\uc6a9\ud55c 3D \uce74 \ub808\uc774\uc2f1 \uac8c\uc784 \ub4f1 \uc804\ud3b8\ubcf4\ub2e4 \uc880 \ub354 \ub09c\uc774\ub3c4\uac00 \ub192\uc740 \uac8c\uc784\uc744 \uac1c\ubc1c\ud558\uba74\uc11c \ud30c\uc774\uc36c\uc758 \ub2e4\uc591\ud55c \uae30\ub2a5\uc744 \uc775\ud790 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ub418\uc5c8\ub2e4. \uac8c\uc784 \uc81c\uc791\uc744 \ud1b5\ud574 \ud30c\uc774\uc36c \uc2e4\ub825\uc740 \ud55c \ub2e8 \uacc4 \ub192\uc774\ub824\ub294 \ubd84, \ucde8\ubbf8\ub85c \uac8c\uc784\uc744 \uac1c\ubc1c\ud558\uace0 \uc2f6\uc740 \ubd84, \uadf8\ub9ac\uace0 \ub354 \ub098\uc740 \ud504\ub85c\uadf8\ub798\uba38\ub85c \uc131\uc7a5\ud558\uace0 \uc2f6\uc740 \ubd84\uc774 \uc77d\uc73c\uba74 \uc88b\ub2e4.", 0, "\uc774 \ucc45\uc740 \ub09c\uc774\ub3c4\uac00 \ub192\uc740 \uac8c\uc784 \uac1c\ubc1c\uc744 \ub2e4\ub8e8\uace0 \uc788\uc5b4 \uace0\ub4f1\ud559\uc0dd \uc785\ubb38 \uc218\uc900\uc5d0\ub294 \ubd80\ub2f4\uc774 \ub420 \uc218 \uc788\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [5, "C_\uc624\ubbfc\uc544", "5b3decfe", "I'm \uc2a4\ud06c\ub798\uce58 3.0 - \ud63c\uc790 \ub9cc\ub4dc\ub294 \uccab \ucf54\ub529 \ud504\ub85c\uc81d\ud2b8", ["\ub178\ud6c8"], "\uacfc\ud559/\uc218\ud559/\ucef4\ud4e8\ud130", "\uc774 \ucc45\uc740 \ucef4\ud4e8\ud130 \ud504\ub85c\uadf8\ub798\ubc0d\uc744 \ucc98\uc74c \uc811\ud558\ub294 \ucd08\ub4f1\ud559\uc0dd\ub4e4\uc774 \ucf54\ub529\uc758 \uae30\ubcf8 \uac1c\ub150\uc744 \uc774\ud574\ud558\uace0 \uc2e4\uc81c \ud504\ub85c\uc81d\ud2b8\ub97c \ub9cc\ub4e4\uc5b4\ubd04\uc73c\ub85c\uc368 \ucf54\ub529 \uacfc\uc815\uc744 \uccb4\ud5d8\ud560 \uc218 \uc788\ub3c4\ub85d \ub9cc\ub4e0 \uc6cc\ud06c\ubd81\uc785\ub2c8\ub2e4. \uc2a4\ud06c\ub798\uce58 3.0\uc758 \uc7a5\uc810\uc778 \uc9c1\uad00\uc131\uacfc \ud3b8\ub9ac\ud55c \uc0ac\uc6a9 \ud658\uacbd\uc744 \ucd5c\ub300\ud55c \uc0b4\ub824 \ub204\uad6c\ub098 \uc27d\uac8c \ub530\ub77c\ud560 \uc218 \uc788\ub3c4\ub85d \ucf54\ub529 \uacfc\uc815 \ud558\ub098\ud558\ub098\ub97c \uc138\uc138\ud558\uac8c \ub2e4\ub8e8\uc5c8\uc2b5\ub2c8\ub2e4. \uadf8\ub9ac\uace0 \uac04\ub2e8\ud55c \ud504\ub85c\uc81d\ud2b8\ubd80\ud130 \ubcf5\uc7a1\ud55c \ud504\ub85c\uc81d\ud2b8\uae4c\uc9c0 \ub2e8\uacc4\ubcc4\ub85c \uad6c\uc131\ud558\uc600\uace0 \uc55e\uc5d0\uc11c \ub2e4\ub8e8\uc5c8\ub358 \uae30\ub2a5\uc774\ub098 \uac1c\ub150\ub4e4\uc744 \ubc18\ubcf5\ud574\uc11c \ub2e4\ub8f8\uc73c\ub85c\uc368 \ucda9\ubd84\ud788 \uae30\ub2a5\ub4e4\uc744 \uc219\uc9c0\ud558\uba70 \ub530\ub77c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", 1, "\ucf54\ub529\uc758 \uae30\ubcf8 \uac1c\ub150\uc744 \uc774\ud574\ud558\uace0 \uc2e4\uc81c \ud504\ub85c\uc81d\ud2b8\ub97c \ub9cc\ub4e4\uc5b4\ubcfc \uc218 \uc788\uc5b4 \uc785\ubb38\uc790\uc5d0\uac8c \uc801\ud569\ud558\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [6, "C_\uc624\ubbfc\uc544", "5b3decfe", "\ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uc720\ub2c8\ud2f0 \uc785\ubb38 - \uc2e4\uc2b5\ud558\uba70 \uc815\ubcf5\ud558\ub294 2D & 3D \uac8c\uc784 \uac1c\ubc1c \uae30\ucd08 = Unity2021\u5165\u9580", ["\uc544\ub77c\uce74\uc640 \ub2e4\ucfe0\uc57c", "\uc544\uc0ac\ub178 \uc720\uc774\uce58"], "\ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c/\ubc29\ubc95\ub860", "\uc720\ub2c8\ud2f0 \ucd08\ubcf4\uc790\ub97c \uc704\ud55c \ucd5c\uc801\uc758 \uc785\ubb38\uc11c \ub530\ub77c \ud558\ub2e4 \ubcf4\uba74 \uc5b4\ub290\uc0c8 \ub098\ub3c4 \uac8c\uc784 \uac1c\ubc1c\uc790! \uc774 \ucc45\uc740 \uc720\ub2c8\ud2f0 \uc124\uce58\ubd80\ud130 2D, 3D \uac8c\uc784 \uc81c\uc791\uae4c\uc9c0 \ub2e4\ub8ec\ub2e4. \ucd08\ubcf4\uc790\uac00 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ud544\uc694\ud55c \uc0ac\uc6a9\ubc95\uc744 \uc2b5\ub4dd\ud558\ub294 \ub370 \uc9d1\uc911\ud558\ub3c4\ub85d \uc124\uce58, \uc124\uc815, \uc5d0\ub514\ud130 \uc0ac\uc6a9\ubc95, \ud504\ub85c\uc81d\ud2b8\uc640 \uc52c \uad6c\uc131, \uc624\ube0c\uc81d\ud2b8 \uc124\uc815 \ub4f1\uc744 \uc27d\uac8c \uc124\uba85\ud55c\ub2e4. \uc720\ub2c8\ud2f0 \uae30\ubcf8\uae30\ub97c \uc775\ud788\uba70 3D \uacf5 \uad74\ub9ac\uae30 \uac8c\uc784\uacfc 2D \ub300\ud3ec \uac8c\uc784\uc744 \ub9cc\ub4e4\uace0 \uc720\ub2c8\ud2f0 UI \uc2dc\uc2a4\ud15c\uc744 \uc774\uc6a9\ud574 \uac8c\uc784 UI\ub3c4 \uc81c\uc791\ud55c\ub2e4. \ub9c8\uc9c0\ub9c9\uc73c\ub85c 3D \uc7a5\uc560\ubb3c \ub2ec\ub9ac\uae30 \uac8c\uc784\uc744 \ub9cc\ub4e4\uc5b4 \ubaa8\ubc14\uc77c\uc6a9 \uac8c\uc784\uc73c\ub85c \uc190\uc27d\uac8c \ubcc0\uacbd\ud558\ub294 \ubc29\ubc95\ub3c4 \uc0b4\ud3b4\ubcf8\ub2e4. \uc774 \ucc45\uacfc \ud568\uaed8\ub77c\uba74 \uc720\ub2c8\ud2f0 \ucd08\ubcf4\uc790\ub3c4 \uac8c\uc784\uc744 \ub9cc\ub4e4 \uc218 \uc788\ub2e4.", 1, "\uc720\ub2c8\ud2f0 \ucd08\ubcf4\uc790\ub97c \uc704\ud55c \ucd5c\uc801\uc758 \uc785\ubb38\uc11c\ub85c, \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uad6c\uc131\uc73c\ub85c \uc801\ud569\ud558\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [7, "C_\uc624\ubbfc\uc544", "5b3decfe", "\uc2dc\uc791\ud558\uc138\uc694! \uc548\ub4dc\ub85c\uc774\ub4dc \uac8c\uc784 \ud504\ub85c\uadf8\ub798\ubc0d - \ubd81\uc2a4 \uac8c\uc784 \uac1c\ubc1c \uc2dc\ub9ac\uc988 1 = Beginning Android Games", ["\ub9c8\ub9ac\uc624 \uc81c\ud750\ub108"], "\ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c/\ubc29\ubc95\ub860", "\uc774 \ucc45\uc758 \uc800\uc790\uc778 \ub9c8\ub9ac\uc624 \uc81c\ud750\ub108\ub294 \uc624\ud508\uc18c\uc2a4 \ud06c\ub85c\uc2a4\ud50c\ub7ab\ud3fc \uac8c\uc784 \uac1c\ubc1c \uc194\ub8e8\uc158\uc778 libgdx\uc758 \uc8fc \uac1c\ubc1c\uc790\ub85c\uc11c \ub204\uad6c\ubcf4\ub2e4\ub3c4 \uac8c\uc784 \ud504\ub808\uc784\uc6cc\ud06c\ub97c \ub9cc\ub4dc\ub294 \ubc95\uc744 \uc798 \uc124\uba85\ud560 \uc218 \uc788\ub294 \uc800\uc790\ub2e4. \uc774 \ucc45\uc5d0\uc11c\ub294 \uac8c\uc784 \uac1c\ubc1c\uc758 \uae30\ubcf8\uc774 \ub418\ub294 \ud30c\uc77c \uc785\ucd9c\ub825(I O), \uc0ac\uc6a9\uc790 \uc785\ub825 \ucc98\ub9ac, \uadf8\ub798\ud53d, \uc624\ub514\uc624 \ub4f1 \uac01 \ud504\ub808\uc784\uc6cc\ud06c \uc694\uc18c\ub97c \ucd94\uc0c1\ud654\ud558\uace0 \uc2e4\uc81c \uc608\uc81c \ucf54\ub4dc\ub97c \ud1b5\ud574 \uac01 \ud504\ub808\uc784\uc6cc\ud06c \uc694\uc18c\ub97c \uc801\uc808\ud788 \uad6c\ud604\ud568\uc73c\ub85c\uc368 \uc7ac\uc0ac\uc6a9\ud560 \uc218 \uc788\ub294 \uac8c\uc784 \ud504\ub808\uc784\uc6cc\ud06c\ub97c \uc644\uc131\ud558\ub294 \ubc95\uc744 \ubcf4\uc5ec\uc900\ub2e4. \ub610 \uac8c\uc784 \ub85c\uc9c1 \uad6c\ud604\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \ubc30\uacbd \uc9c0\uc2dd\uc5d0 \ub300\ud55c \uc124\uba85\uc744 \ud1b5\ud574 \ucda9\ub3cc \uac10\uc9c0, \ube44\ud2b8\ub9f5 \ube14\ub9ac\ud305, 3D \uadf8\ub798\ud53d \ud504\ub85c\uadf8\ub798\ubc0d \uac19\uc740 \uace0\uae09 \uc8fc\uc81c\ub97c \ucc28\ub840\ub85c \uc18c\uac1c\ud55c\ub2e4.", 0, "\uace0\uae09 \uc8fc\uc81c\ub97c \ub2e4\ub8e8\uace0 \uc788\uc5b4 \ucd08\ubcf4\uc790\uc5d0\uac8c\ub294 \ubd80\ub2f4\uc2a4\ub7ec\uc6b8 \uc218 \uc788\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [8, "C_\uc624\ubbfc\uc544", "5b3decfe", "\ub9cc\ub9cc\ud55c \uc608\uc81c\ub85c C \ud504\ub85c\uadf8\ub798\ubc0d \uc0ac\ub85c\uc7a1\uae30", ["\uc9c4\uba85\uc219 \ub4f1"], "\ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4", "\ud504\ub85c\uadf8\ub798\ubc0d\uc744 \ucc98\uc74c \uc811\ud558\ub294 \ub3c5\uc790\ub97c \uc704\ud55c C \uc5b8\uc5b4 \uc785\ubb38\uc11c\ub85c C\uc758 \uae30\ubcf8\uc744 \ud655\uc2e4\ud558\uace0 \uc27d\uac8c \uc9da\uc5b4\uc8fc\ub294 \ucc45\uc774\ub2e4. \uc608\uc81c\ub97c \ub530\ub77c\ud558\uba74\uc11c C \ud504\ub85c\uadf8\ub798\ubc0d\uc758 \uc6d0\ub9ac\ub97c \uc27d\uac8c \uc775\ud790 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\ub2e4. \ucc45\uc5d0 \uc218\ub85d\ub41c \ud48d\ubd80\ud55c \uc608\uc81c\uc640 \ubaa8\ub4e0 \uc18c\uc2a4 \ucf54\ub4dc\uc758 \uc2e4\ud589\uacb0\uacfc\ub97c \ubbf8\ub9ac\ubcf4\uae30\ub85c \ubc30\uce58\ud558\uc5ec \uc77d\ub294 \uac83\ub9cc\uc73c\ub85c\ub3c4 \uc2e4\uc2b5\ud558\ub294 \uac83\uacfc \uac19\uc740 \ud6a8\uacfc\ub97c \uac00\uc9c8 \uc218 \uc788\ub2e4. \ub610\ud55c, \uac01 \uc7a5\uc758 \ud575\uc2ec\uac1c\ub150\uacfc \ud504\ub85c\uadf8\ub7a8 \uc2e4\ud589 \uc2dc\uc758 \uba54\ubaa8\ub9ac \uc0c1\ud669\uc744 \uadf8\ub9bc\uc73c\ub85c \ud45c\ud604\ud558\uc5ec \ub354\uc6b1 \uc27d\uace0 \ube60\ub974\uac8c \ud559\uc2b5\ud560 \uc218 \uc788\ub2e4. \ub09c\uc774\ub3c4\ub97c \uace0\ub824\ud55c \uc138\uc2ec\ud55c \ub2e8\uc6d0 \ubc30\uce58\uc640 \ub2e8\uc6d0 \ubbf8\ub9ac\ubcf4\uae30, \ucc55\ud130 \uc815\ub9ac \ub4f1\uc758 \ub0b4\uc6a9\uc744 \ud1b5\ud574 \ud6a8\uacfc\uc801\uc778 \ud559\uc2b5\uc774 \uac00\ub2a5\ud558\uba70, \ud3ec\uc778\ud130\uc640 \ub2e4\ucc28\uc6d0 \ubc30\uc5f4, \ub2e4\uc591\ud55c \ud568\uc218\uc758 \ub9e4\uac1c \ubcc0\uc218 \ud615\uc2dd, \uc815\ub82c \ub4f1 \uae30\ubc18 \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ud544\uc694\ud55c \ub0b4\uc6a9\uc744 \uc218\ub85d\ud558\uc600\ub2e4. \ubd80\ub85d CD\uc5d0\ub294 \ucef4\ud30c\uc77c\ub7ec \uc0ac\uc6a9\ubc95\uc744 \ub3d9\uc601\uc0c1 \ud30c\uc77c\ub85c \uc81c\uacf5\ud558\uace0 \uc788\ub2e4.", 0, "C \uc5b8\uc5b4\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c \uac8c\uc784 \uac1c\ubc1c\uacfc\ub294 \uad00\ub828\uc774 \uc801\uc5b4 \uc0ac\uc6a9\uc790\uc758 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\ub294\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [9, "C_\uc624\ubbfc\uc544", "5b3decfe", "C# \ud504\ub85c\uadf8\ub798\ubc0d \uc815\uc11d", ["\uc774\ucc3d\ud604"], "\ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4", "\uc774 \ucc45\uc740 IT \ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c \ubd84\uc57c\uc5d0\uc11c 20\ub144\uc774 \ub118\uac8c \ubab8\uc744 \ub2f4\uc544 \uc628 \uc800\uc790\uac00 C \uc5d0 \ucc98\uc74c \uc785\ubb38\ud558\ub294 \ubd84\ub4e4\uc744 \uc704\ud574 C \uc758 \uae30\ubcf8 \uc774\ub860\ubd80\ud130 \uc2e4\ubb34\uc5d0\uc11c \uc4f0\ub294 \uae30\ub2a5\ub4e4\uc744 \uc5c4\uc120\ud558\uc5ec \ub2e4\ub8ec \ucc45\uc774\ub2e4. C \uc740 \uac1d\uccb4 \uc9c0\ud5a5\uc758 \ub300\ud45c\uc801\uc778 \uc5b8\uc5b4\ub85c, \ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c\uc744 \ud560 \ub54c \ud544\uc218\uc801\uc73c\ub85c \uc0ac\uc6a9\ud574\uc57c \ud558\ub294 \uc5b8\uc5b4\ub2e4. \uc774\ub7f0 C \uc758 \uae30\ubcf8\uc801\uc778 \uac1c\ub150\uc744 \uc77c\uc0c1\uc5d0\uc11c \ucc3e\uc544\ubcfc \uc218 \uc788\ub294 \ub2e4\uc591\ud55c \uc0ac\ub840\ub4e4\uc744 \ud1b5\ud574 \uc7ac\ubbf8\uc788\uac8c \uc124\uba85\ud558\uc600\ub2e4. \ud074\ub798\uc2a4, \ucd94\uc0c1\ud654, \uc0c1\uc18d, \uc624\ubc84\ub85c\ub529 \ub4f1 \ub2e4\uc18c \uc5b4\ub824\uc6b8 \uc218 \uc788\ub294 \uac1c\ub150\ub4e4\uc744 \uc7ac\ubbf8\uc788\ub294 \uc18c\uc7ac\ub97c \ud1b5\ud574 \uc124\uba85\ud558\uae30 \ub54c\ubb38\uc5d0 \uba38\ub9ac\uce74\ub77d\uc744 \uc7a1\uc73c\uba70 \uace0\ub1cc\ud558\uc9c0 \uc54a\uc544\ub3c4 \uc27d\uac8c \uc774\ud574\uac00 \ub41c\ub2e4. \ub610\ud55c \uac01 \uac1c\ub150\ubcc4 \ucf54\ub4dc \uc791\uc131 \uc608\uc2dc\ub97c \uac19\uc774 \ubcf4\uc5ec \uc8fc\uae30 \ub54c\ubb38\uc5d0 \ub2e8\uc21c\ud788 \ub530\ub77c\uc11c \uc554\uae30\ub9cc \ud558\uc9c0 \uc54a\uace0 \uc8fc\uccb4\uc801\uc73c\ub85c C \ud504\ub85c\uadf8\ub798\ubc0d \ud559\uc2b5\uc744 \ud574 \ubcfc \uc218 \uc788\ub2e4. \ucc45\uc758 \ub9c8\uc9c0\ub9c9\uc5d0\uc11c\ub294 \uac04\ub2e8\ud558\uc9c0\ub9cc \ud004\ub9ac\ud2f0 \uc788\ub294 \uac8c\uc784 \uc81c\uc791\uae4c\uc9c0 \ub2e4\ub8ec\ub2e4. \uc774 \ucc45 \ud558\ub098\uba74 \uac1c\ubc1c IT \ud504\ub85c\uc81d\ud2b8\ub97c \uc704\ud574 \ud544\uc694\ud55c C \ud504\ub85c\uadf8\ub798\ubc0d \uc2e4\ubb34 \uae30\uc220\ub4e4\uc744 \ubaa8\ub450 \uc775\ud790 \uc218 \uc788\ub2e4.", 0, "C# \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c, \uc9c0\ub098\uce58\uac8c \uc804\ubb38\uc801\uc77c \uc218 \uc788\uc5b4 \uc0ac\uc6a9\uc790\uc758 \uc218\uc900\uc5d0 \ub9de\uc9c0 \uc54a\ub294\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"], [10, "C_\uc624\ubbfc\uc544", "5b3decfe", "\uae30\ucd08\ubcf4\ub2e4 \ub354 \uc26c\uc6b4 \uc6f9\ud504\ub85c\uadf8\ub798\ubc0d", ["\ucd5c\ud6c8"], "\ud504\ub85c\uadf8\ub798\ubc0d \uac1c\ubc1c/\ubc29\ubc95\ub860", "\uc6f9 \ud504\ub85c\uadf8\ub798\ubc0d\uacfc \uad00\ub828\ud55c \uae30\ubcf8 \uc9c0\uc2dd\uc744 \uc2b5\ub4dd\ud558\uace0 \uc2e4\uc81c\uc801\uc73c\ub85c \ubcf8\uc778\uc758 \ud648\ud398\uc774\uc9c0\ub97c \uad6c\ucd95\ud560 \uc218 \uc788\ub3c4\ub85d \uc2e4\uc2b5\uacfc \uc608\uc81c\ub97c \ud1b5\ud574 \ub3c5\uc790\uc758 \uc774\ud574\ub97c \ub192\uc774\ub3c4\ub85d \uad6c\uc131\ub41c \ucc45\uc774\ub2e4. \uc774 \ucc45\uc740 \uc774\uc81c \ub9c9 \uc6f9 \ud504\ub85c\uadf8\ub798\ubc0d\uc744 \uc2dc\uc791\ud558\ub294 \ucd08\ubcf4\uc790\ub4e4\uc744 \ub300\uc0c1\uc73c\ub85c \ud558\uace0 \uc788\uc5b4 \uac00\uae09\uc801 \ub9ce\uc740 \uc608\uc81c\uc640 \ud45c\ub97c \uc774\uc6a9\ud558\uc5ec \uc6f9 \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ub300\ud55c \uc774\ud574\ub97c \ub3d5\uace0 \uc788\ub2e4. \uac01 \uc7a5\uc758 \ub9c8\uc9c0\ub9c9 \ubd80\ubd84\uc5d0 \uc218\ub85d\ub418\uc5b4 \uc788\ub294 \uc5f0\uc2b5 \ubb38\uc81c\ub97c \ud1b5\ud574 \ud574\ub2f9 \uc7a5\uc5d0\uc11c \ubc30\uc6b4 \ub0b4\uc6a9\uc744 \ubcf5\uc2b5\ud574 \ubcfc \uc218 \uc788\uc744 \uac83\uc774\ub2e4.", 0, "\uc6f9 \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c \uac8c\uc784 \uac1c\ubc1c\uacfc\ub294 \uad00\ub828\uc774 \uc801\uc5b4 \uc0ac\uc6a9\uc790\uc758 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\ub294\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \uc785\ubb38\ud558\uace0 \uc2f6\uc5b4 \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud604\uc7ac \ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc774 \uac70\uc758 \uc5c6\uc5b4, \uae30\ucd08\ubd80\ud130 \ub2e8\uacc4\uc801\uc73c\ub85c \ub530\ub77c\ud560 \uc218 \uc788\ub294 \uc785\ubb38\uc11c\uac00 \ud544\uc694\ud569\ub2c8\ub2e4. \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ud65c\uc6a9\ud558\uc5ec \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc5d0 \ub9de\ub294 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uacfc \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uace0\uc790 \ud558\uba70, \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubcc0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c \uae30\ucd08\uc801\uc778 \ub0b4\uc6a9\uc744 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uad00\ub828 \ub3c4\uc11c\ub97c \uc77d\uc5b4\ubcf8 \uacbd\ud5d8\uc740 \uc5c6\uc9c0\ub9cc, \uc644\uc804 \ucd08\ubcf4\uc778 \ub9cc\ud07c \ucd08\uae09\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc790\ub8cc\ub97c \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4.", "\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uae30\ucd08\uc801\uc778 \uc774\ud574\ub97c \ub3c4\uc640\uc904 \uc218 \uc788\ub294 \uc2e4\uc6a9\uc801\uc774\uace0 \ub2e8\uacc4\uc801\uc778 \uc9c0\uce68\uc11c \ud615\uc2dd\uc744 \uc6d0\ud568 \ucf54\ub529 \uad00\ub828 \ub3c4\uc11c\uc5d0\uc11c \uad6c\uccb4\uc801\uc778 \ucf54\ub4dc \uc608\uc81c\uc640 \uc2e4\uc2b5\uc744 \ud1b5\ud574 \uc2e4\uc9c8\uc801\uc778 \uae30\uc220 \uc2b5\ub4dd\uc744 \ucd94\uad6c\ud558\ub294 \uacbd\ud5a5\uc774 \ubcf4\uc784 \uae30\ucd08\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \uc785\ubb38\uc11c\uc774\ubbc0\ub85c, \ub2e8\uc21c\ud558\uace0 \uba85\ud655\ud55c \ubb38\uccb4\ub85c \ubcf5\uc7a1\ud55c \uac1c\ub150\uc744 \uc27d\uac8c \uc124\uba85\ud558\ub294 \ucc45\uc744 \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \uc788\uc74c \uac8c\uc784 \uac1c\ubc1c\uc758 \ucd5c\uc2e0 \ud2b8\ub80c\ub4dc\uc640 \uae30\uc220\uc744 \ubc18\uc601\ud55c \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub41c \ucc45\uc744 \ud1b5\ud574 \ucd5c\uc2e0 \uc815\ubcf4\ub97c \uc811\ud558\uace0 \uc2f6\uc5b4\ud560 \uac83\uc73c\ub85c \ubcf4\uc784 \uad00\uc2ec\uc0ac\uac00 \uc790\uc8fc \ubc14\ub00c\ub294 \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c, \ub2e4\uc591\ud55c \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \ub3c4\uad6c\ub098 \uc5b8\uc5b4\ub97c \uc18c\uac1c\ud558\ub294 \ucc45\uc744 \ud1b5\ud574 \ud3ed\ub113\uc740 \uc2dc\uac01\uc744 \uc5bb\uace0 \uc2f6\uc5b4\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc74c"]], "log_mode": "IMMUTABLE", "ncols": 11, "nrows": 10}
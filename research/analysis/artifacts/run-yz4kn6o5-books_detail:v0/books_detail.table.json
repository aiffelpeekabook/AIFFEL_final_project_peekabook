{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["step", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [[1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 1, "Unity 3D Game Development by Example \ud55c\uad6d\uc5b4\ud310 - \uc720\ub2c8\ud2f0 3D \uac8c\uc784 \ud504\ub85c\uadf8\ub798\ubc0d = Unity 3D Game Development by Example", ["\ub77c\uc774\uc5b8 \ud5e8\uc2a8 \ud06c\ub808\uc774\ud2bc"], 0, "", 0, ""], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 2, "\uc720\ub2c8\ud2f0 \uad50\uacfc\uc11c", ["\uae30\ud0c0\ubb34\ub77c \ub9c8\ub098\ubbf8", "\uae40\uc740\ucca0"], 0, "\uad50\uacfc\uc11c \uac19\uc740 \ub290\ub08c\uc758 \ucc45\uc744 \uc2eb\uc5b4\ud558\ub294 \uc0ac\uc6a9\uc790\uc758 disliked \ud56d\ubaa9\uc5d0 \uc9c1\uc811 \ud574\ub2f9\ub418\uba70, \uc81c\ubaa9 \uc790\uccb4\uac00 '\uad50\uacfc\uc11c'\ub85c \uba85\uc2dc\ub418\uc5b4 \uc788\uc5b4 \ubd80\uc801\ud569", 1, "\uadf8\ub9bc\uacfc \uc608\uc81c\ub97c \ud1b5\ud574 \uc27d\uac8c \uc720\ub2c8\ud2f0\ub97c \ubc30\uc6b8 \uc218 \uc788\uc5b4\uc11c \uc88b\uc544."], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 3, "\uc720\ub2c8\ud2f0 5 \uac8c\uc784 \uc81c\uc791 \uac00\uc774\ub4dc - \ucd08\ubcf4\uc790\ub97c \uc704\ud55c", ["\uc8fc\ub3d9\uadfc"], 1, "\ud504\ub85c\uadf8\ub7a8 \ucc98\uc74c\uc778 \uc0ac\ub78c \ub300\uc0c1, \uae30\ubcf8 \uc6a9\uc5b4\ubd80\ud130 \uc2dc\uc791\ud558\ub294 \ub2e8\uacc4\uc801 \uad6c\uc131, \ucd08\ubcf4\uc790 \uc911\uc2ec \uc124\uba85\uc73c\ub85c reading_goal, difficulty_level, reading_style \ucda9\uc871", 1, "\uae30\ubcf8 \uc6a9\uc5b4\ubd80\ud130 \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud574\uc918\uc11c \ucd08\ubcf4\uc790\uc5d0\uac8c \uc801\ud569\ud574."], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 4, "\ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uc720\ub2c8\ud2f0 \uc785\ubb38 - \uc2e4\uc2b5\ud558\uba70 \uc815\ubcf5\ud558\ub294 2D & 3D \uac8c\uc784 \uac1c\ubc1c \uae30\ucd08 = Unity2021\u5165\u9580", ["\uc544\ub77c\uce74\uc640 \ub2e4\ucfe0\uc57c", "\uc544\uc0ac\ub178 \uc720\uc774\uce58"], 0, "", 0, ""], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 5, "\uc2e4\uc804 \uc720\ub2c8\ud2f0 3D & 2D \uac8c\uc784 \uac1c\ubc1c \uc138\ud2b8 - \ucf58 \uac8c\uc784 \uac1c\ubc1c \ud504\ub85c\uadf8\ub798\ubc0d \uc2dc\ub9ac\uc988 ", ["\ub9f7 \uc2a4\ubbf8\uc2a4", "\uce58\ucf54 \ucf00\uc774\ub85c\uc988", "\uae40\uc815\uc5f4", "\ubb38\uae30\uc601", "\uae40\uc138\uc911"], 0, "", 0, ""], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 6, "\uac8c\uc784\uc744 \uae30\ud68d\ud558\uace0 \ub9cc\ub4dc\ub294 \uc0ac\ub78c\ub4e4\uc774 \uaf2d \uc77d\uc5b4\uc57c \ud560 \ud074\ub798\uc2dd \uc138\ud2b8 - \ucf58 \uac8c\uc784 \uac1c\ubc1c \ud504\ub85c\uadf8\ub798\ubc0d \uc2dc\ub9ac\uc988 ", ["\uc81c\uc774\uc2a8 \uadf8\ub808\uace0\ub9ac", "\uc81c\uc2dc \uc178", "\ubc15\uc0c1\ud76c", "\uc804\uc720\ud0dd"], 0, "", 0, ""], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 7, "\uc5b8\ub9ac\uc5bc \uc5d4\uc9c4 4 \ube14\ub8e8\ud504\ub9b0\ud2b8 \uac8c\uc784 \ub9cc\ub4e4\uae30", ["\ubc15\uc2b9\uc81c"], 0, "\uc720\ub2c8\ud2f0\uac00 \uc544\ub2cc \uc5b8\ub9ac\uc5bc \uc5d4\uc9c4 \uae30\ubc18\uc774\uba70, \uc0ac\uc6a9\uc790\uac00 \ucc3e\ub294 '\uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \uc785\ubb38\uc11c'\uc758 \uc8fc\uc694 \uc5d4\uc9c4\uacfc \ub2e4\ub974\ubbc0\ub85c reading_goal \ubbf8\ucda9\uc871", 0, "\uc720\ub2c8\ud2f0\uac00 \uc544\ub2cc \uc5b8\ub9ac\uc5bc \uc5d4\uc9c4\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc774\ub77c\uc11c \ub9de\uc9c0 \uc54a\uc544."], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 8, "\ud30c\uc774\uc36c\uc73c\ub85c \ubc30\uc6b0\ub294 \uac8c\uc784 \uac1c\ubc1c \uc2e4\uc804\ud3b8 - \uc7a5\uc560\ubb3c \ud53c\ud558\uae30, \ub2f7\uc787 \uc561\uc158, \ub9f5 \uc5d0\ud2f0\ud130, \ud0c4\ub9c9 \uc288\ud305, 3D \uce74 \ub808\uc774\uc2f1, \uac8c\uc784 \ub7f0\ucc98 \ub4f1\uc744 \ub9cc\ub4e4\uba70 \ubc30\uc6b4\ub2e4!", ["\ud788\ub85c\uc138 \uce20\uc694\uc2dc"], 0, "", 0, ""], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 9, "\uacfc\ud559 \uc601\uc7ac\ub97c \ub9cc\ub4dc\ub294 \uc544\ub450\uc774\ub178 \uad50\uc2e4 - \uc544\ube60\uc640 \ud568\uaed8 \uc544\ub450\uc774\ub178 \uc791\ud488 \ub9cc\ub4e4\uae30", ["\ucd5c\uc7ac\ucca0", "\ub9c8\ucc3d\uc218"], 0, "", 0, "\uc544\ub450\uc774\ub178 \uad00\ub828 \ub0b4\uc6a9\uc774\ub77c \uac8c\uc784 \uac1c\ubc1c\uacfc\ub294 \uac70\ub9ac\uac00 \uc788\uc5b4."], [1, "sim_C_\uc624\ubbfc\uc544_s1_1781706419", 10, "\uc5d4\ud2b8\ub9ac \uac8c\uc784 \uc81c\uc791 \ubb34\uc791\uc815 \ub530\ub77c\ud558\uae30", ["\ubc15\ud61c\uc815", "\uac15\ubbfc\uc6b1", "\ubc30\uc131\ubbfc", "\ubc29\uc9c4\ud601", "\uae40\ubbfc\uc900"], 0, "\ucd08\ub4f1\ud559\uc0dd \ub300\uc0c1\uc758 \uc5d4\ud2b8\ub9ac \ud50c\ub7ab\ud3fc\uc73c\ub85c \uace0\ub4f1\ud559\uc0dd \uc218\uc900\uc758 \uc778\ub514 \uac8c\uc784 \uac1c\ubc1c \uc785\ubb38\uc11c \uc694\uad6c\uc0ac\ud56d\uacfc \ub9de\uc9c0 \uc54a\uc73c\uba70, difficulty_level \ubbf8\ucda9\uc871", 1, "\ucf54\ub529 \uc6d0\ub9ac\ub97c \uc27d\uac8c \ubc30\uc6b8 \uc218 \uc788\uc5b4 \ucd08\ubcf4\uc790\uc5d0\uac8c \uc801\ud569\ud574."], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 1, "\ub514\uc9c0\ud138 \uc5d0\ub4c0\ud14c\uc778\uba3c\ud2b8 \uc2a4\ud1a0\ub9ac\ud154\ub9c1 - \uc9c0\uc2dd\ucd1d\uc11c 196", ["\uac15\uc2ec\ud638"], 0, "\uac8c\uc784 \uae30\ud68d\uacfc \uc2a4\ud1a0\ub9ac\ud154\ub9c1 \ubaa9\ud45c\uc5d0\ub294 \ubd80\ud569\ud558\uc9c0\ub9cc, \uc5d0\ub4c0\ud14c\uc778\uba3c\ud2b8 \ucf58\ud150\uce20 \uc911\uc2ec\uc73c\ub85c \uc2e4\uc81c \uac8c\uc784 \uc0ac\ub840 \uc124\uba85\uc774 \uba85\uc2dc\ub418\uc9c0 \uc54a\uc558\uace0, '\uc9c0\uc2dd\ucd1d\uc11c'\ub77c\ub294 \ud559\uc220\uc801 \uc131\uaca9\uc774 \uc0ac\uc6a9\uc790\uc758 '\ud559\uad50 \uad50\uacfc\uc11c \uac19\uc740 \ub290\ub08c' \uac70\ubd80\uac10\uacfc \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uc2a4\ud1a0\ub9ac\ud154\ub9c1\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc740 \uc788\uc9c0\ub9cc, \uac8c\uc784 \uae30\ud68d\uacfc \uad00\ub828\ub41c \uc2e4\uc81c \uc0ac\ub840\uac00 \ubd80\uc871\ud574."], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 2, "\uac8c\uc784\uc744 \uae30\ud68d\ud558\uace0 \ub9cc\ub4dc\ub294 \uc0ac\ub78c\ub4e4\uc774 \uaf2d \uc77d\uc5b4\uc57c \ud560 \ud074\ub798\uc2dd \uc138\ud2b8 - \ucf58 \uac8c\uc784 \uac1c\ubc1c \ud504\ub85c\uadf8\ub798\ubc0d \uc2dc\ub9ac\uc988 ", ["\uc81c\uc774\uc2a8 \uadf8\ub808\uace0\ub9ac", "\uc81c\uc2dc \uc178", "\ubc15\uc0c1\ud76c", "\uc804\uc720\ud0dd"], 0, "", 0, ""], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 3, "\uac8c\uc784 \ud504\ub85c\uadf8\ub798\uba38\ub85c \uc0b0\ub2e4\ub294 \uac83", ["\uae40\uc131\uc644", "\uc815\uc7ac\uc6d0", "\uc774\uad6d\ud604", "\uae40\uc0c1\ucc9c", "\uae40\uc6a9\uc900", "\ucd5c\uc601\uc900"], 0, "\uac8c\uc784 \ud504\ub85c\uadf8\ub798\uba38\uc758 \uacbd\ud5d8\ub2f4 \uc911\uc2ec\uc73c\ub85c, \uc0ac\uc6a9\uc790\uc758 '\uac8c\uc784 \uae30\ud68d\uacfc \uc2a4\ud1a0\ub9ac\ud154\ub9c1 \ud559\uc2b5' \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \ud504\ub85c\uadf8\ub798\uba38 \uc9c4\ub85c \uc774\uc57c\uae30\ub294 \ud604\uc7ac \uae30\ud68d \uad00\uc2ec\uc0ac\uc640 \ubd80\ud569\ud558\uc9c0 \uc54a\uc74c.", 0, "\uac1c\ubc1c\uc790\ub4e4\uc758 \uc774\uc57c\uae30\uc9c0\ub9cc, \uae30\ud68d\uc774\ub098 \uc2a4\ud1a0\ub9ac\ud154\ub9c1\uc5d0 \ub300\ud55c \uad6c\uccb4\uc801\uc778 \ub0b4\uc6a9\uc774 \ubd80\uc871\ud574."], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 4, "\uc2e4\uc804 \uc720\ub2c8\ud2f0 3D & 2D \uac8c\uc784 \uac1c\ubc1c \uc138\ud2b8 - \ucf58 \uac8c\uc784 \uac1c\ubc1c \ud504\ub85c\uadf8\ub798\ubc0d \uc2dc\ub9ac\uc988 ", ["\ub9f7 \uc2a4\ubbf8\uc2a4", "\uce58\ucf54 \ucf00\uc774\ub85c\uc988", "\uae40\uc815\uc5f4", "\ubb38\uae30\uc601", "\uae40\uc138\uc911"], 0, "", 0, ""], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 5, "\uacfc\ud559 \uc601\uc7ac\ub97c \ub9cc\ub4dc\ub294 \uc544\ub450\uc774\ub178 \uad50\uc2e4 - \uc544\ube60\uc640 \ud568\uaed8 \uc544\ub450\uc774\ub178 \uc791\ud488 \ub9cc\ub4e4\uae30", ["\ucd5c\uc7ac\ucca0", "\ub9c8\ucc3d\uc218"], 0, "", 0, "\uac8c\uc784 \uae30\ud68d\uacfc\ub294 \uad00\ub828\uc774 \uc5c6\uace0, \uc544\ub450\uc774\ub178\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc774\ub77c\uc11c \uad00\uc2ec\uacfc \ub9de\uc9c0 \uc54a\uc544."], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 6, "C\ub97c \uc774\uc6a9\ud55c \uac8c\uc784\ud504\ub85c\uadf8\ub798\ubc0d", ["\uc774\ud0dc\uc131"], 0, "C\uc5b8\uc5b4 \uac8c\uc784 \ud504\ub85c\uadf8\ub798\ubc0d \uae30\uc220\uc11c\ub85c, \uc0ac\uc6a9\uc790\uac00 '\ucf54\ub529\ubcf4\ub2e4 \uae30\ud68d\uc5d0 \ub354 \uad00\uc2ec'\uc774\ub77c\ub294 \ud604\uc7ac \uc0c1\ud669\uacfc \uc815\ubc18\ub300\uc774\uba70, \uac8c\uc784 \uae30\ud68d\u00b7\uc2a4\ud1a0\ub9ac\ud154\ub9c1 \ud559\uc2b5 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \uc911\uc810\uc744 \ub450\uace0 \uc788\uc5b4, \uae30\ud68d\uacfc \uc2a4\ud1a0\ub9ac\ud154\ub9c1\uc744 \ubc30\uc6b0\uace0 \uc2f6\uc740 \ub098\uc5d0\uac8c\ub294 \uc801\ud569\ud558\uc9c0 \uc54a\uc544."], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 7, "\ud30c\uc774\uc36c\uc73c\ub85c \ubc30\uc6b0\ub294 \uac8c\uc784 \uac1c\ubc1c \uc2e4\uc804\ud3b8 - \uc7a5\uc560\ubb3c \ud53c\ud558\uae30, \ub2f7\uc787 \uc561\uc158, \ub9f5 \uc5d0\ud2f0\ud130, \ud0c4\ub9c9 \uc288\ud305, 3D \uce74 \ub808\uc774\uc2f1, \uac8c\uc784 \ub7f0\ucc98 \ub4f1\uc744 \ub9cc\ub4e4\uba70 \ubc30\uc6b4\ub2e4!", ["\ud788\ub85c\uc138 \uce20\uc694\uc2dc"], 0, "", 0, ""], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 8, "10\ub300\uc5d0 \ud504\ub85c\uadf8\ub798\uba38\uac00 \ub418\uace0 \uc2f6\uc740 \ub098, \uc5b4\ub5bb\uac8c \ud560\uae4c? - \ucf54\ub529\ubd80\ud130 \uc18c\ud504\ud2b8\uc6e8\uc5b4 \uac1c\ubc1c \uc724\ub9ac\uae4c\uc9c0, \uc0c8\ub0b4\uae30 \ud504\ub85c\uadf8\ub798\uba38\uac00 \uc54c\uc544\uc57c \ud560 \ubaa8\ub4e0 \uac83", ["\uc81c\ub2c8\ud37c \ucf54\ub108-\uc2a4\ubbf8\uc2a4"], 0, "", 0, ""], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 9, "\ucf54\ub529\uc73c\ub85c \uc138\uc0c1\uc744 \ubc14\uafc0 \uc218 \uc788\ub2e4\uba74 - \ub0b4 \uacc1\uc758 IT \uae30\uc220\uc744 \uc774\ud574\ud558\uace0 \ud65c\uc6a9\ud558\uae30 \uc704\ud574 \uc54c\uc544\uc57c \ud560 \uae30\ucd08 \uad50\uc591", ["\uc774\ub798\uc740"], 0, "", 0, ""], [2, "sim_C_\uc624\ubbfc\uc544_s2_1781706488", 10, "99% \uae30\ud68d\ucd08\ubcf4\uc790\uac00 \ubaa8\ub974\ub294 \uae30\ud68d\ub825", ["\ubc15\uc9c0\uc740"], 1, "\ube44\uc988\ub2c8\uc2a4 \uae30\ud68d\uc758 \uae30\ucd08\ubd80\ud130 \uc2e4\ud589\uae4c\uc9c0 \ub2e8\uacc4\ubcc4\ub85c \uc124\uba85\ud558\ub294 \uae30\ud68d \uc785\ubb38\uc11c\ub85c, \uac8c\uc784 \uae30\ud68d \ud559\uc2b5 \ubaa9\ud45c\uc5d0 \ubd80\ud569\ud558\uace0, \uae30\ud68d \ucd08\ubcf4\uc790 \ub300\uc0c1\uc758 \uc26c\uc6b4 \uc124\uba85 \ubc29\uc2dd\uc774 \uace0\ub4f1\ud559\uc0dd \uc218\uc900\uc5d0 \uc801\ud569\ud558\uba70, \ud604\uc7ac '\uae30\ud68d \uad00\uc2ec' \uc0c1\ud669\uacfc \uc815\ud655\ud788 \ub9de\uc74c.", 1, "\uae30\ud68d \ucd08\ubcf4\uc790\uc5d0\uac8c \uc801\ud569\ud55c \uc811\uadfc\ubc95\uacfc \ud575\uc2ec\uc744 \uc27d\uac8c \uc804\ub2ec\ud574\uc904 \uac83 \uac19\uc544."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 1, "3DCG GAME \uce90\ub9ad\ud130 - \ubaa8\ub378\ub9c1\uc5d0\uc11c \ub9ac\uae45\uae4c\uc9c0", ["\uc190\uc131\ud638"], 1, "\uac8c\uc784 \uce90\ub9ad\ud130 \uc81c\uc791 \uc804 \uacfc\uc815\uc744 \ub2e4\ub8e8\uba70 \uc2e4\uc81c \uac8c\uc784 \uce90\ub9ad\ud130 \uc0ac\ub840 \uae30\ubc18 \ud559\uc2b5\uc73c\ub85c \uc0ac\uc6a9\uc790\uc758 '\uac8c\uc784\uc5d0 \ub4e4\uc5b4\uac08 \uce90\ub9ad\ud130\ub97c \uc9c1\uc811 \uadf8\ub824\ubcf4\uace0 \uc2f6\uc5b4\ud568' \ubaa9\ud45c\uc640 \uc815\ud655\ud788 \ubd80\ud569\ud558\uace0, \uc5ec\ub7ec \ub3c4\uad6c\ub97c \uc720\uae30\uc801\uc73c\ub85c \uc0ac\uc6a9\ud558\ub294 \uc2e4\uc804 \ubc29\uc2dd\uc774 \ub530\ub77c\ud558\uae30 \uc26c\uc6b4 \uad6c\uc131 \uc694\uad6c\ub97c \ucda9\uc871\ud568.", 0, "\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d\uc5d0 \ub300\ud55c \uc785\ubb38\uc11c\uac00 \uc544\ub2c8\ub77c, \uc804\ubb38\uc801\uc778 3D \ubaa8\ub378\ub9c1 \uae30\uc220\uc744 \ub2e4\ub8e8\uace0 \uc788\uc5b4."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 2, "\uc2e4\uc804 \uc720\ub2c8\ud2f0 3D & 2D \uac8c\uc784 \uac1c\ubc1c \uc138\ud2b8 - \ucf58 \uac8c\uc784 \uac1c\ubc1c \ud504\ub85c\uadf8\ub798\ubc0d \uc2dc\ub9ac\uc988 ", ["\ub9f7 \uc2a4\ubbf8\uc2a4", "\uce58\ucf54 \ucf00\uc774\ub85c\uc988", "\uae40\uc815\uc5f4", "\ubb38\uae30\uc601", "\uae40\uc138\uc911"], 0, "", 0, ""], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 3, "\uac8c\uc784 \ud504\ub85c\uadf8\ub798\uba38\ub85c \uc0b0\ub2e4\ub294 \uac83", ["\uae40\uc131\uc644", "\uc815\uc7ac\uc6d0", "\uc774\uad6d\ud604", "\uae40\uc0c1\ucc9c", "\uae40\uc6a9\uc900", "\ucd5c\uc601\uc900"], 0, "\uac8c\uc784 \ud504\ub85c\uadf8\ub798\uba38\uc758 \uacbd\ub825\uacfc \uc0b6\uc5d0 \uad00\ud55c \uc5d0\uc138\uc774\ub85c '\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d \uc785\ubb38' \ubaa9\ud45c\uc640 \ubb34\uad00\ud558\uba70, \uc2dc\uac01\uc801\uc73c\ub85c \ub530\ub77c\ud558\uae30 \uc26c\uc6b4 \uad6c\uc131\uc774\ub77c\ub294 \ub3c5\uc11c \uc2a4\ud0c0\uc77c \uc694\uad6c\ub97c \ucda9\uc871\ud558\uc9c0 \ubabb\ud568.", 0, "\uac8c\uc784 \uac1c\ubc1c\uc5d0 \ub300\ud55c \uacbd\ud5d8\ub2f4\uc744 \ub2e4\ub8ec \ucc45\uc73c\ub85c, \uc2e4\uc2b5 \uc911\uc2ec\uc758 \ub0b4\uc6a9\uc774 \uc544\ub2c8\ub77c\uc11c \ubaa9\uc801\uc5d0 \ub9de\uc9c0 \uc54a\uc544."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 4, "\ub530\ub77c\ud558\uba74\uc11c \ubc30\uc6b0\ub294 \ud30c\uc774\uc36c", ["\uc774\uc0c1\ucca0"], 0, "\ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4 \ud559\uc2b5 \uad50\uc7ac\ub85c '\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d' \uc120\ud638 \uc7a5\ub974\uc640 \ubb34\uad00\ud558\uba70, \uc0ac\uc6a9\uc790\uac00 \uc6d0\ud558\ub294 '\uac8c\uc784 \uce90\ub9ad\ud130\ub97c \uc9c1\uc811 \uadf8\ub824\ubcf4\uae30'\ub77c\ub294 \ud604\uc7ac \ubaa9\ud45c\uc640 \uc804\ud600 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\ucf54\ub529\uc5d0 \ub300\ud55c \uae30\ucd08\ub97c \ub2e4\ub8e8\uc9c0\ub9cc, \uac8c\uc784 \uac1c\ubc1c\uacfc \uc9c1\uc811\uc801\uc778 \uc5f0\uad00\uc131\uc774 \uc801\uc5b4."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 5, "C\ub97c \uc774\uc6a9\ud55c \uac8c\uc784\ud504\ub85c\uadf8\ub798\ubc0d", ["\uc774\ud0dc\uc131"], 0, "C\uc5b8\uc5b4 \ud504\ub85c\uadf8\ub798\ubc0d\uc744 \ud1b5\ud55c \uac8c\uc784 \uac1c\ubc1c \uae30\uc220\uc11c\ub85c '\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d' \uc785\ubb38 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \ud504\ub85c\uadf8\ub798\ubc0d \uc911\uc2ec\uc758 \uc804\ubb38 \uae30\uc220\uc11c \uc131\uaca9\uc774 \uc0ac\uc6a9\uc790\uc758 '\uc9c0\ub098\uce58\uac8c \uc804\ubb38\uc801\uc778 \uae30\uc220\uc11c' \ud68c\ud53c \uc131\ud5a5\uacfc \ucda9\ub3cc\ud568.", 0, "C\uc5b8\uc5b4\ub97c \uae30\ubc18\uc73c\ub85c \ud55c \uac8c\uc784 \uc81c\uc791\uc11c\ub85c, \ube44\uc804\uacf5\uc790\uc5d0\uac8c\ub294 \ub09c\uc774\ub3c4\uac00 \ub192\uc744 \uc218 \uc788\uc5b4."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 6, "\ud30c\uc774\uc36c\uc73c\ub85c \ubc30\uc6b0\ub294 \uac8c\uc784 \uac1c\ubc1c \uc2e4\uc804\ud3b8 - \uc7a5\uc560\ubb3c \ud53c\ud558\uae30, \ub2f7\uc787 \uc561\uc158, \ub9f5 \uc5d0\ud2f0\ud130, \ud0c4\ub9c9 \uc288\ud305, 3D \uce74 \ub808\uc774\uc2f1, \uac8c\uc784 \ub7f0\ucc98 \ub4f1\uc744 \ub9cc\ub4e4\uba70 \ubc30\uc6b4\ub2e4!", ["\ud788\ub85c\uc138 \uce20\uc694\uc2dc"], 0, "", 0, ""], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 7, "\uacfc\ud559 \uc601\uc7ac\ub97c \ub9cc\ub4dc\ub294 \uc544\ub450\uc774\ub178 \uad50\uc2e4 - \uc544\ube60\uc640 \ud568\uaed8 \uc544\ub450\uc774\ub178 \uc791\ud488 \ub9cc\ub4e4\uae30", ["\ucd5c\uc7ac\ucca0", "\ub9c8\ucc3d\uc218"], 0, "", 0, "\uc544\ub450\uc774\ub178\uc640 \uad00\ub828\ub41c \ub0b4\uc6a9\uc73c\ub85c, \uac8c\uc784 \uadf8\ub798\ud53d\uacfc\ub294 \uad00\ub828\uc774 \uc5c6\uc5b4."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 8, "Xcode4\ub85c \uc2dc\uc791\ud558\ub294 \uc544\uc774\ud3f0 \ud504\ub85c\uadf8\ub798\ubc0d", ["Yoshinao Mori"], 0, "\uc544\uc774\ud3f0 \uc571 \ud504\ub85c\uadf8\ub798\ubc0d \uae30\uc220\uc11c\ub85c '\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d' \uc785\ubb38 \ubaa9\ud45c\uc640 \ubb34\uad00\ud558\uba70, \ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4 \ud559\uc2b5 \uc911\uc2ec\uc758 \uc804\ubb38 \uae30\uc220\uc11c \uc131\uaca9\uc774 \uc0ac\uc6a9\uc790\uc758 \ud68c\ud53c \uc131\ud5a5\uacfc \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uc571 \ud504\ub85c\uadf8\ub798\ubc0d\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c, \uac8c\uc784 \uadf8\ub798\ud53d\uacfc\ub294 \uad00\ub828\uc774 \uc5c6\uc5b4."], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 9, "\ucf54\ub529\uc73c\ub85c \uc138\uc0c1\uc744 \ubc14\uafc0 \uc218 \uc788\ub2e4\uba74 - \ub0b4 \uacc1\uc758 IT \uae30\uc220\uc744 \uc774\ud574\ud558\uace0 \ud65c\uc6a9\ud558\uae30 \uc704\ud574 \uc54c\uc544\uc57c \ud560 \uae30\ucd08 \uad50\uc591", ["\uc774\ub798\uc740"], 0, "", 0, ""], [3, "sim_C_\uc624\ubbfc\uc544_s3_1781706532", 10, "\uc778\uacf5\uc9c0\ub2a5 \uc571 \ud504\ub85c\uc81d\ud2b8 with \uc571 \uc778\ubca4\ud130", ["Sunny"], 0, "\ube14\ub85d \ucf54\ub529\uc744 \ud1b5\ud55c AI \uc571 \uac1c\ubc1c \uc785\ubb38\uc11c\ub85c '\ub514\uc9c0\ud138 \uc544\ud2b8\uc640 \uac8c\uc784 \uadf8\ub798\ud53d' \uc120\ud638 \uc7a5\ub974\uc640 \ubb34\uad00\ud558\uba70, \uc0ac\uc6a9\uc790\uac00 \uc6d0\ud558\ub294 '\uac8c\uc784 \uce90\ub9ad\ud130 \uc81c\uc791'\uc774\ub77c\ub294 \ud604\uc7ac \ubaa9\ud45c\uc640 \uc804\ud600 \uc5f0\uacb0\ub418\uc9c0 \uc54a\uc74c.", 0, "\uc778\uacf5\uc9c0\ub2a5 \uc571 \uac1c\ubc1c\uc5d0 \ub300\ud55c \ub0b4\uc6a9\uc73c\ub85c, \uac8c\uc784 \uadf8\ub798\ud53d\uacfc\ub294 \uad00\ub828\uc774 \uc5c6\uc5b4."]], "log_mode": "IMMUTABLE", "ncols": 9, "nrows": 30}
{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["step", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [[1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 1, "\uc5c4\ub9c8\ub294 \ub2e8\uc9dd\uce5c\uad6c 4 - \uc5c4\ub9c8\uac00 \uaf2d \ub098\ub9cc \ud588\uc744 \ub54c \uc774\uc57c\uae30", ["\uc774\ube48"], 0, "", 1, "\uac00\uc871\uc758 \uc18c\uc911\ud568\uc744 \ub2e4\ub8ec \ub530\ub73b\ud55c \uc774\uc57c\uae30\ub85c, \uac10\ub3d9\uc801\uc774\uace0 \uc7ac\ubbf8\uc788\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 2, "\uc5c4\ub9c8\ub294 \ub2e8\uc9dd\uce5c\uad6c 16", ["\uc774\ube48"], 0, "\uac00\uc871 \uc911\uc2ec\uc758 \ub9cc\ud654\ub85c \uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uae30\uc5d0\ub294 \ubd80\ubaa8-\uc790\ub140 \uad00\uacc4 \uc911\uc2ec\uc774\uba70, \ubd80\ubaa8\uc758 \ucd94\uc5b5 \uacf5\uc720\uac00 \uc8fc\ubaa9\uc801\uc774\ub77c \uc0ac\uc6a9\uc790\uc758 '\uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uc744 \ucc45' \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc74c.", 1, "\uac00\uc871\uc758 \uc18c\uc911\ud568\uc744 \ub2e4\ub8ec \ub530\ub73b\ud55c \uc774\uc57c\uae30\ub85c, \uac10\ub3d9\uc801\uc774\uace0 \uc7ac\ubbf8\uc788\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 3, "\uc5c4\ub9c8\ub294 \ub2e8\uc9dd\uce5c\uad6c 20", ["\uc774\ube48"], 0, "\uac00\uc871 \uc911\uc2ec\uc758 \ub9cc\ud654\ub85c \uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uae30\uc5d0\ub294 \ubd80\ubaa8-\uc790\ub140 \uad00\uacc4 \uc911\uc2ec\uc774\uba70, \ubd80\ubaa8\uc758 \ucd94\uc5b5 \uacf5\uc720\uac00 \uc8fc\ubaa9\uc801\uc774\ub77c \uc0ac\uc6a9\uc790\uc758 '\uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uc744 \ucc45' \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc74c.", 1, "\uac00\uc871\uc758 \uc18c\uc911\ud568\uc744 \ub2e4\ub8ec \ub530\ub73b\ud55c \uc774\uc57c\uae30\ub85c, \uac10\ub3d9\uc801\uc774\uace0 \uc7ac\ubbf8\uc788\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 4, "\ub9c8\uc74c\uc774 \uc5f4\ub9ac\ub294 \ud0c0\ub85c\ub300\ud654", ["\uc784\ucd98\ud76c", "\uc96c\ub9ac"], 1, "\uce5c\uad6c\uc640 \ud568\uaed8 \ub300\ud654\ud558\uba70 \uacf5\uac10\ud558\ub294 \ud65c\ub3d9\uc744 \uc911\uc2ec\uc73c\ub85c \uc124\uacc4\ub41c \ucc45\uc73c\ub85c '\uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uae30' \ubaa9\ud45c\uc5d0 \ubd80\ud569\ud558\uba70, \uc2a4\ub9c8\ud2b8\ud3f0 \ub300\uc2e0 \uc9c1\uc811 \ub300\uba74 \ud65c\ub3d9\uc774\ub77c \ud604\uc7ac \uc0c1\ud669(\uce5c\uad6c\ub124 \uc9d1\uc5d0\uc11c \ud568\uaed8)\uc5d0 \uc801\ud569\ud568.", 0, "\ub300\ud654\uc640 \uacf5\uac10\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc774\uc57c\uae30 \uc911\uc2ec\uc774 \uc544\ub2c8\ub77c\uc11c \uce5c\uad6c\uc640 \uc77d\uae30\uc5d4 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 5, "\ub0b4 \uc544\uc774 \ucc45\uc740 \ub0b4\uac00 \uace0\ub978\ub2e4 (\uace0\ud559\ub144\uc6a9) - \uc88b\uc740 \ucc45\uc744 \ucc3e\ub294 \ud559\ubd80\ubaa8\uc640 \uad50\uc0ac\ub97c \uc704\ud55c \uac00\uc774\ub4dc \ubd81", ["\uc870\uc6d4\ub840"], 0, "", 0, ""], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 6, "\uc0ac\uacc4\uc808 \uc6c3\ub294 \ucf54\ub07c\ub9ac \uc138\ud2b8 - \uc80415\uad8c", ["\uae40\uc625"], 0, "", 0, "\uc800\ud559\ub144 \ub3d9\ud654\ub77c\uc11c \ub0b4 \uc218\uc900\uc5d0\ub294 \ub9de\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 7, "\uc678\ud560\uba38\ub2c8\uc758 \uc120\ubb3c - Grandma's Gift", ["\uc870\uc218\uc601", "\uc774\uc724\ud76c"], 0, "", 1, "\ud55c\uad6d\uc801\uc778 \uc815\uc11c\uc640 \uac10\ub3d9\uc801\uc778 \uc774\uc57c\uae30\ub97c \ub2e4\ub8e8\uace0 \uc788\uc5b4 \uce5c\uad6c\uc640 \ud568\uaed8 \uc77d\uae30 \uc88b\uc744 \uac83 \uac19\uc544."], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 8, "\uc624\ub298\ub3c4 \uad81\uae08\ud55c \uac83\uc774 \ub9ce\uc740 \ub108\uc5d0\uac8c - \ud504\ub791\uc2a4 \uc544\uc774\ub4e4\uc740 \uc5c4\ub9c8 \uc544\ube60\uc5d0\uac8c \uc5b4\ub5a4 \uc9c8\ubb38\uc744 \ud560\uae4c? = Les grandes questions du CP : Les reponses aux pourquoi des enfants", ["\uc0e4\ub97c\ub85c\ud2b8 \uadf8\ub85c\uc2a4\ud14c\ud2b8", "\ud2f0\uc5d0\ub9ac \ub9c8\ub124\uc2a4"], 0, "", 0, ""], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 9, "\uc5c4\ub9c8\ub97c \uc704\ud55c \uadf8\ub9bc\ucc45 - \uadf8\ub9bc\ucc45\uc774 \uc804\ud574\uc8fc\ub294 \ub530\ub73b\ud55c \uacf5\uac10\uacfc \uc704\ub85c\uc758 \uc2dc\uac04\ub4e4", ["\uc7a5\uc9c0\uc740"], 0, "", 0, ""], [1, "sim_D_\uc774\uc218\ube48_s1_1781706599", 10, "\uc911\ud559\uc0dd\uc758 \ucc45\uc77d\uae30 - \uc77d\uae30 \ub0b4\uacf5\uc744 \ud30d\ud30d \uc62c\ub824\uc8fc\ub294 \ucc45\ubc8c\ub808 \uc120\uc0dd\ub2d8\uc758 \ub3c5\uc11c \uc218\uc5c5", ["\uc784\uc131\ubbf8"], 0, "", 0, ""], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 1, "\uc601\uc0dd\uc5d0 \ud22c\uc790\ud558\ub77c - \uc131\uacbd\uc801 \uc7ac\uc815\uad00\ub9ac", ["\uae40\uc6a9\uc218"], 0, "\uc131\uacbd\uc801 \uad00\uc810\uc758 \uc131\uc778 \ub300\uc0c1 \uc7ac\uc815\uad00\ub9ac \ucc45\uc73c\ub85c, \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uacfc \uc5b4\ub9b0\uc774 \uacbd\uc81c \uc7a5\ub974 \uc694\uad6c\uc5d0 \ub9de\uc9c0 \uc54a\uc73c\uba70 \uc2e4\uc0dd\ud65c \uc6a9\ub3c8 \uad00\ub9ac\ub77c\ub294 \ud604\uc7ac \uc0c1\ud669\uacfc\ub3c4 \uac70\ub9ac\uac00 \uc788\uc74c.", 0, "\uc5b4\ub9b0\uc774 \uacbd\uc81c\u00b7\uc2e4\uc0dd\ud65c\uc5d0 \ub9de\uc9c0 \uc54a\uace0, \ub0b4\uc6a9\uc774 \uc2ec\ub3c4 \uae4a\uc5b4 \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uc5d0 \uc801\ud569\ud558\uc9c0 \uc54a\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 2, "2015 \uac00\uacc4\ubd81", ["\uadf8\ub9ac\uace0\ucc45 \ud3b8\uc9d1\ubd80"], 0, "\uac00\uacc4\ubd80 \uc791\uc131 \ub3c4\uad6c\ub85c \uc2e4\uc6a9\uc801\uc774\ub098 \uc18c\uac1c\uae00\uc5d0 \uc7ac\ubbf8\uc788\ub294 \uad6c\uc131\uc774\ub098 \uc5b4\ub9b0\uc774 \ub208\ub192\uc774 \uc124\uba85\uc774 \uc5c6\uc5b4 reading_style(\uc720\uc775\ud558\uace0 \uc7ac\ubbf8\uc788\uac8c)\uacfc difficulty_level(\ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900)\uc744 \ucda9\uc871\ud558\uc9c0 \ubabb\ud568.", 1, "\uc6a9\ub3c8 \uad00\ub9ac\uc640 \uc18c\ube44 \uacc4\ud68d\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc5b4 \ub0b4 \uc218\uc900\uc5d0 \ub9de\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 3, "\uba38\ub2c8 \ud30c\uc6cc - \uacbd\uc81c\uc801 \ub3c5\ub9bd\uc744 \uc704\ud55c \ubcf4\ub3c4 \uc100\ud37c\uc758 \uba58\ud0c8 \ucf54\uce6d = Geld tut Frauen richtig gut.", ["\ubcf4\ub3c4 \uc100\ud37c"], 0, "", 0, ""], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 4, "\ub3c8 \uacf5\ubd80\ub85c \ubd80\uc790 \ub420\ub798\uc694 - \uc704\uae30\uc5d0 \ucc98\ud55c \uc544\ube60 \uac00\uac8c\ub97c \uc0b4\ub824\ub77c!", ["\ub2e4\ub098\uce74 \uc57c\uc2a4\ud788\ub85c", "\uc6b0\uc0ac\ubbf8", "\uc544\ud0a4\uc57c\ub9c8 \ub2e4\uce74\uc694"], 1, "\ub9cc\ud654\uc640 \ub3d9\ud654\ub85c \uc6a9\ub3c8 \uad00\ub9ac\uc640 \ud604\uba85\ud55c \uc18c\ube44 \ubc29\ubc95\uc744 \uc7ac\ubbf8\uc788\uac8c \uc124\uba85\ud558\uba70, \uc5b4\ub9b0\uc774 \ub208\ub192\uc774\uc758 \uacbd\uc81c \uac1c\ub150 \ud559\uc2b5\uc744 \uc81c\uacf5\ud574 reading_goal, preferred_genre, reading_style, difficulty_level, current_context \ubaa8\ub450 \ucda9\uc871.", 1, "\uc7ac\ubbf8\uc788\ub294 \ub9cc\ud654\uc640 \ub3d9\ud654\ub85c \uc6a9\ub3c8 \uad00\ub9ac \ubc29\ubc95\uc744 \uc27d\uac8c \ubc30\uc6b8 \uc218 \uc788\uc5b4 \ub0b4 \uad00\uc2ec\uc0ac\uc640 \ub9de\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 5, "\ub9e4\ucf64\ud55c \uacbd\uc81c\ub808\uc2dc\ud53c - \ub0b4 \uc544\uc774\ub97c \uc704\ud55c", ["\uace0\ubcd1\ucca0"], 0, "\ubd80\ubaa8\ub97c \uc704\ud55c \uc790\ub140 \uacbd\uc81c\uad50\uc721 \uac00\uc774\ub4dc\ub85c, \uc0ac\uc6a9\uc790\uac00 \uc9c1\uc811 \uc77d\uc744 \ub300\uc0c1 \ub3c4\uc11c\uac00 \uc544\ub2c8\uba70 \ucd08\ub4f1 \uace0\ud559\ub144 \ub3c5\uc790\uc758 reading_goal\uacfc \ub9de\uc9c0 \uc54a\uc74c.", 1, "\uacbd\uc81c\uc801 \uc2b5\uad00\uc744 \uae30\ub974\ub294 \ubc29\ubc95\uc744 \uc54c\ub824\uc8fc\uba70, \uc5b4\ub9b0\uc774\ub97c \uc704\ud55c \ub0b4\uc6a9\uc73c\ub85c \ub0b4 \uc218\uc900\uc5d0 \uc801\ud569\ud568."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 6, "\ub3c8\uc774\ub0d0 \uc778\uc0dd\uc774\ub0d0", [], 0, "\uc18c\uac1c\uae00\uc5d0 \ub300\uc0c1 \uc5f0\ub839\uce35\uc774 \uba85\uc2dc\ub418\uc9c0 \uc54a\uc558\uc73c\ub098 '\uacbd\uc81c\uc0dd\ud65c\uacfc \uc0b6\uc758 \uc735\ud569' \ub4f1 \ucd94\uc0c1\uc801 \uac1c\ub150\uc73c\ub85c \ubcf4\uc544 \uc131\uc778 \ub300\uc0c1\uc774\uba70, \uc6a9\ub3c8 \uad00\ub9ac\ub77c\ub294 \uad6c\uccb4\uc801 reading_goal\uacfc \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uc5b4\ub824\uc6b4 \uac1c\ub150\uacfc \ubcf5\uc7a1\ud55c \ub0b4\uc6a9\uc774 \ub9ce\uc544 \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uc5d0 \ub9de\uc9c0 \uc54a\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 7, "\ub514\uc9c0\ud138 \uc2dc\ub300\uc758 \uc885\ud6a1\ubb34\uc9c4 \uc7ac\ud14c\ud06c", ["\uc624\uc815\uc120"], 0, "\uc608\uae08\u00b7\ud22c\uc790\u00b7\uc7ac\ud14c\ud06c \uc804\ub7b5\uc744 \ub2e4\ub8e8\ub294 \uc131\uc778 \ub300\uc0c1 \ucc45\uc73c\ub85c, \ucd08\ub4f1 \uace0\ud559\ub144\uc758 \uc6a9\ub3c8 \uad00\ub9ac learning goal\uacfc difficulty_level \uc694\uad6c\uc5d0 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\ub0b4\uc6a9\uc774 \ubcf5\uc7a1\ud558\uace0 \uc2e4\uc0dd\ud65c\uc5d0 \ubc14\ub85c \uc801\uc6a9\ud558\uae30 \uc5b4\ub824\uc6b4 \uc815\ubcf4\uac00 \ub9ce\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 8, "\ub098\ub294 \ub3c8 \uac71\uc815 \uc5c6\uc774 \uc0b4\uace0 \uc2f6\ub2e4 - \uc801\uac8c \ubc8c\uc5b4\ub3c4 \ub3c8\uc5d0\uc11c \uc790\uc720\ub85c\uc6cc\uc9c0\ub294 \ubc95", ["\uae40\uc120\ud654"], 0, "6\ub2e8\uacc4 \ub3c8 \uad00\ub9ac\ubc95\uacfc \ud22c\uc790 \ubc29\ubc95\uc744 \ub2e4\ub8e8\ub294 \uc131\uc778 \ub300\uc0c1 \ucc45\uc73c\ub85c, \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uc758 \uc6a9\ub3c8 \uad00\ub9ac\ub77c\ub294 reading_goal\uacfc difficulty_level\uc5d0 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uc5b4\ub9b0\uc774\uc5d0\uac8c \uc801\ud569\ud558\uc9c0 \uc54a\uc740 \ubcf5\uc7a1\ud55c \uc7ac\uc815 \uacc4\ud68d\uacfc \uc804\ub7b5\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc74c."], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 9, "\ub098\ub294 \ub3c5\uc11c \uc7ac\ud14c\ud06c\ub85c \uc6d4\uae09 \ub9d0\uace0 \ub9e4\ub144 3\ucc9c\ub9cc \uc6d0 \ubc88\ub2e4 - \ube5a\ub354\ubbf8\uc5d0 \uc2dc\ub2ec\ub9ac\ub358 \uadf8\ub140, \ub3c5\uc11c\ub85c \uae30\uc801\uc744 \ub9cc\ub4e4\ub2e4!", ["\uc548\uba85\uc219", "\uae40\ud0dc\uad11(\uae40\ub3c4\uc0ac)"], 0, "", 0, ""], [2, "sim_D_\uc774\uc218\ube48_s2_1781706663", 10, "\ub530\ub77c\ud558\ub294 \uc7ac\ud14c\ud06c - \ub3c8 \uc880 \ubaa8\uc544\ubcfc\uae4c?", ["\uae40\uacbd\ud658"], 0, "\uc800\ucd95\u00b7\ud22c\uc790\u00b7\uc7ac\ubb34\uc0c1\ub2f4\uc744 \ub2e4\ub8e8\ub294 \uc131\uc778 \ub300\uc0c1 \ucc45\uc73c\ub85c, \ucd08\ub4f1 \uace0\ud559\ub144\uc758 \uc6a9\ub3c8 \uad00\ub9ac\ub77c\ub294 reading_goal\uacfc difficulty_level \uc694\uad6c\uc5d0 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\ub0b4\uc6a9\uc774 \ubcf5\uc7a1\ud558\uace0 \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uc5d0 \ube44\ud574 \uc5b4\ub824\uc6b4 \uacbd\uc81c \uac1c\ub150\uc774 \ub9ce\uc74c."], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 1, "\ubd80\uae00\ubd80\uae00 \uacfc\uc790 \uacf5\uc7a5 - \ud504\ub80c\uc988 \uac10\uc815 \uadf8\ub9bc\ucc45 ", ["\uc720\ud558\uc740", "\ube44\ube44"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 2, "\ud3ec\ud3ec\uc758 \ubb34\uc9c0\uac1c \ub0a0\uac1c - \ucf69 \ucc3d\uc791\ub3d9\ud654 ", ["\ubc15\uc138\ubbf8", "\uc870\uc2ac\uae30"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 3, "\ub300\ub2c8\uc758 \uc2ec\ubd80\ub984 - \ucf69 \ucc3d\uc791\ub3d9\ud654 ", ["\ud478\ub978\uc232\uae00\ubc29", "\uc7a5\uc9c0\ud61c"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 4, "\ud63c\uc790\ud560 \uc218 \uc788\uc5b4! - \ucf69 \ucc3d\uc791\ub3d9\ud654 ", ["\ubc15\uc138\ubbf8", "\uae40\ubbf8\uc120"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 5, "\uac78\ub9ac\ubc84 \uc5ec\ud589\uae30 - \ubcf8 \uc138\uacc4 \uba85\uc791 ", ["\uc870\ub098\ub2e8 \uc2a4\uc704\ud504\ud2b8 \uc6d0", "\ub85c\ub77c \ucf54\uc644"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 6, "\ubd80\ub044\ub7ec\uc6cc\uc694 - \ucf69\ub2e5 \uac10\uc815\ud45c\ud604 \ub3d9\ud654 ", ["\ud478\ub978\uc232 \uae00\ubc29", "\uae40\uc601\ubbf8"], 0, "", 0, ""], [3, "sim_D_\uc774\uc218\ube48_s3_1781706719", 7, "\ud504\ub80c\uc988 - \ub85c \uac04 \ub2ec\ud33d\uc774 7", ["\uc2e0\uc9c0\uc601"], 0, "\uccad\uc18c\ub144\uae30 \ub300\uc778\uad00\uacc4\uc640 \uc6b0\uc815\uc744 \ub2e4\ub8e8\ub294 \uc18c\uc124\uc9d1\uc73c\ub85c \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\ubcf4\ub2e4 \ub192\uc73c\uba70, \ubaa8\ud5d8 \uac00\ub4dd\ud55c \ud310\ud0c0\uc9c0 \uc774\uc57c\uae30\ubcf4\ub2e4\ub294 \ud604\uc2e4\uc801 \uac10\uc815 \ud0d0\uad6c\uc5d0 \u
{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 2}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "step": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["step", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [[1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 1, "\uc090\ub9ac\uc090\ub9ac \ub85c\ubd07 \u00b7 \ub450\uadfc\ub450\uadfc \ubbf8\ub798\uacfc\ud559 - \uacfc\ud559 \ubc1c\uc804\uc758 \ubbf8\ub798", ["\ub2c9 \uc544\ub180\ub4dc", "\ud1a0\ub2c8 \ub4dc \uc194\uc2a4"], 0, "", 1, "\uacfc\ud559\uae30\uc220\uacfc \ub85c\ubd07\uc5d0 \ub300\ud55c \ud765\ubbf8\ub85c\uc6b4 \uc2a4\ud1a0\ub9ac\ud154\ub9c1 \ubc29\uc2dd\uc73c\ub85c \uc911\ud559\uad50 1\ud559\ub144 \uc218\uc900\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 2, "\ub85c\ubd07 \uacf5\ud559 -  \uc720\ub2c8\ubc84\uc2dc\ud2f0 16", ["\ud06c\ub9ac\uc2a4 \ud398\ub9ac", "\uc0ac\ub77c \uce74\uc774\uc800"], 0, "", 0, ""], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 3, "\ud1a0\ube44\uc758 \uacfc\uc77c \ub18d\uc7a5 - \uc778\uacf5 \uc9c0\ub2a5\uc758 \ubd84\ub958\uc640 \ucd94\ub9ac = Toby\u2019s Fruit Gardens", ["\ub85c\ucf13 \ubca0\uc774\ube44 \ud074\ub7fd"], 0, "", 0, ""], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 4, "\uccad\uc18c\ub144\uc774 \ud568\uaed8 \uc0b4\uc544\uc57c \ud560 \ub85c\ubd07\uacfc AI - AI \uc2dc\ub300 \ucd5c\uc2e0 \ub85c\ubd07\uae30\uc220\uc758 \ubaa8\ub4e0 \uac83", ["\uc804\uc2b9\ubbfc"], 0, "", 0, ""], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 5, "\uc9c0\ub2c8\uc5b4\uc2a4 \ub85c\ubd07\uc544\uc774 1 - \ub2ec\ub824\ub77c, \ub4dc\ub860 \uc5d0\uc774\uc2a4", ["\ub2ec\ucf64\ud329\ud1a0\ub9ac", "\uae40\ubb38\uc2dd", "\ubc15\uc6a9\ub798"], 1, "\ucd08\ub4f1\ud559\uc0dd \ub300\uc0c1 \ud559\uc2b5\ub9cc\ud654\ub85c \ub85c\ubd07, AI, \ub4dc\ub860 \ub4f1\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc18c\uac1c\uae00\uc5d0\uc11c '\ucd08\ub4f1\ud559\uc0dd\ub4e4\uc758 \ud544\uc218 \ud559\uc2b5 \ub0b4\uc6a9'\uc73c\ub85c \uba85\uc2dc\ub418\uc5b4 \uc911\ud559\uad50 1\ud559\ub144 \uc218\uc900\ubcf4\ub2e4 \ub0ae\uc744 \uac00\ub2a5\uc131\uc774 \uc788\uc5b4 \ub09c\uc774\ub3c4 \uc801\ud569\uc131\uc774 \ubd88\ud655\uc2e4\ud569\ub2c8\ub2e4.", 1, "AI\uc640 \ub85c\ubd07\uc5d0 \ub300\ud55c \uae30\ucd08 \uc9c0\uc2dd\uc744 \uc7ac\ubbf8\uc788\uac8c \uc804\ub2ec\ud558\uc5ec \uc911\ud559\uad50 1\ud559\ub144\uc5d0\uac8c \uc801\ud569\ud569\ub2c8\ub2e4."], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 6, "\uba38\ub9ac \uc88b\uc544\uc9c0\ub294 \uacfc\ud559\ub180\uc774 - Science Play = A Little Hands Book:Science Play!", ["\uc9c8 \ud504\ub791\ucf08 \ud558\uc6b0\uc800"], 0, "", 0, ""], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 7, "\uc6b0\ub9ac\ub294 \uc9c0\uae08 \ubbf8\ub798\ub97c \uac77\uace0 \uc788\uc2b5\ub2c8\ub2e4 - \uc778\ubb38\ud559\uacfc \ud568\uaed8\ud558\ub294 \ubbf8\ub798\uacfc\ud559 \uc0b0\ucc45", ["\uae40\uc815\ubbfc"], 0, "", 0, ""], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 8, "\ucd08\ub4f1 \ub180\uc774 \ucf54\ub529 - \uc2a4\uc6e8\ub374 \uc544\uc774\ub4e4\uc774 \ub9e4\uc77c \uc544\uce68 \ud558\ub294 \ub180\uc774 \ucf54\ub529", ["\uce74\ub9b0 \ub258\uace0\uce20", "\ub178\uc900\uad6c"], 0, "", 0, "\ucf54\ub529\uc5d0 \uc911\uc810\uc744 \ub450\uace0 \uc788\uc5b4 AI\uc640 \ub85c\ubd07\uc5d0 \ub300\ud55c \uc9c1\uc811\uc801\uc778 \uad00\uc2ec\uc744 \uc790\uadf9\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4."], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 9, "\ub0b4 \uce5c\uad6c \ub2e4\uc774\ub178\ubd07 1 - \uac70\ub300 \uacf5\ub8e1\uc774 \uae68\uc5b4\ub098\ub2e4", ["N.S. \ube14\ub799\uba3c"], 0, "\ub85c\ubd07\uacfc \uacf5\ub8e1\uc744 \uc18c\uc7ac\ub85c \ud55c \ubaa8\ud5d8 \uc18c\uc124\ub85c \uacfc\ud559\uae30\uc220\u00b7AI \uad00\ub828 \uc9c0\uc2dd \uc804\ub2ec\ubcf4\ub2e4 \uc77d\uae30 \uc990\uac70\uc6c0\uc5d0 \ucd08\uc810\uc774 \ub9de\ucdb0\uc838 \uc788\uc5b4, \uc0ac\uc6a9\uc790\uc758 '\uacfc\ud559\uae30\uc220\u00b7AI \uad00\ub828 \ucc45' \ubaa9\ud45c\uc640 \ubd80\ud569\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", 0, "\ub85c\ubd07\uacfc \uacf5\ub8e1\uc758 \uc774\uc57c\uae30\ub294 \ud765\ubbf8\ub86d\uc9c0\ub9cc, AI\uc640 \ub85c\ubd07 \uae30\uc220\uc5d0 \ub300\ud55c \uad00\uc2ec\uacfc\ub294 \uac70\ub9ac\uac00 \uc788\uc2b5\ub2c8\ub2e4."], [1, "sim_B_\ud55c\ubbf8\uc601_s1_1781706232", 10, "\ucc45 \uc77d\uae30\ub294 \uac8c\uc784\uc774\uc57c - \ub611 \uc0ac\ud68c \uadf8\ub9bc\ucc45 17", ["\ud55c\ubbf8\ud654", "\uc18c\ubcf5\uc774"], 0, "", 0, ""], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 1, "\uc5b4\ub5bb\uac8c \uc0dd\uac01\ud574? \ud55c\uad6d\uc0ac2 - \uc0dd\uac01\uc774 \uae4a\uc5b4\uc9c0\ub294 \uc5f4\uc1f3\ub9d0", ["\uc774\uc18c\uc601", "\uc11c\ud574\uacbd", "\uc774\uc218\uc9c4", "\uc815\uc7ac\uc724"], 1, "\uc9c8\ubb38\uc744 \ud1b5\ud55c \uc0ac\uace0 \uc720\ub3c4\uc640 \ub2e4\uc591\ud55c \uc2dc\uac01 \uc81c\uc2dc\ub85c \ub531\ub531\ud55c \uc124\uba85\uc744 \ud53c\ud558\uace0, \uc774\uc57c\uae30\u00b7\ub9cc\ud654\u00b7\ucf54\ub108 \uad6c\uc131\uc73c\ub85c \ud765\ubbf8 \uc720\uc9c0\uac00 \uac00\ub2a5\ud558\uba70, \ucd08\ub4f1 \uace0\ud559\ub144 \uc218\uc900\uc758 \uc5ed\uc0ac\u00b7\uc0ac\ud68c \ud559\uc2b5 \ubaa9\ud45c\uc5d0 \ubd80\ud569\ud569\ub2c8\ub2e4.", 0, "\uc9c8\ubb38\uc744 \ud1b5\ud574 \ub2e4\uc591\ud55c \uc2dc\uac01\uc744 \uc81c\uc2dc\ud558\uc9c0\ub9cc, \ucd08\ub4f1\ud559\uad50 5\ud559\ub144 \uc544\ub4e4\uc5d0\uac8c\ub294 \ub2e4\uc18c \uc5b4\ub824\uc6b8 \uc218 \uc788\ub294 \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 2, "\ud55c\uad8c\uc73c\ub85c \uc77d\ub294 \ud55c\uad6d\uc0ac -  \uc2dc\ub9ac\uc988 2", ["\ucd5c\ud5a5\uc219"], 0, "", 0, ""], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 3, "\uace0\ub824 \uc2dc\ub300 - \uc0ac \uc5f4\ucc28 3", ["\ubc30\uc6b0\uc131", "\uc1a1\ud638\uc815", "\ubc15\ud604\ucca0"], 0, "\ucd08\ub4f1 \uc800\ud559\ub144 \ub300\uc0c1 \uc2dc\ub9ac\uc988\ub85c \uba85\uc2dc\ub418\uc5b4 \uc788\uc5b4 \ucd08\ub4f1 5\ud559\ub144 \uc544\ub4e4\uc758 \uc218\uc900\ubcf4\ub2e4 \ub0ae\uc73c\uba70, \uc774\uc804 \uc138\uc158\uc5d0\uc11c \uc218\uc900 \ubd88\uc77c\uce58 \uacbd\ud5d8\uc774 \uc788\ub294 \uc0ac\uc6a9\uc790\uc758 pain point\uc640 \ub9de\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", 0, "\ucd08\ub4f1 \uc800\ud559\ub144\uc744 \ub300\uc0c1\uc73c\ub85c \ud55c \ucc45\uc73c\ub85c, \uc544\ub4e4\uc774 \uc77d\uae30\uc5d0\ub294 \ub2e4\uc18c \uc720\uce58\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 4, "\ud1b5\uc77c \uc2e0\ub77c\uc640 \ubc1c\ud574 - \uc0ac \uc5f4\ucc28 2", ["\ubc30\uc6b0\uc131", "\uc1a1\ud638\uc815", "\ubc15\ud604\ucca0", "\ucd5c\uc900\uc11d"], 0, "\ucd08\ub4f1 \uc800\ud559\ub144 \ub300\uc0c1 \uc2dc\ub9ac\uc988\ub85c \uba85\uc2dc\ub418\uc5b4 \uc788\uc5b4 \ucd08\ub4f1 5\ud559\ub144 \uc544\ub4e4\uc758 \uc218\uc900\ubcf4\ub2e4 \ub0ae\uc73c\uba70, \uc218\uc900 \ud310\ub2e8 \uae30\uc900\uc774 \uc5c6\ub294 \uc0ac\uc6a9\uc790\uc758 pain point\ub97c \uace0\ub824\ud560 \ub54c \ubd80\uc801\ud569\ud569\ub2c8\ub2e4.", 0, "\uc800\ud559\ub144\uc744 \uc704\ud55c \ucc45\uc73c\ub85c, \uc544\ub4e4\uc774 \ud765\ubbf8\ub97c \uc783\uc744 \uc218 \uc788\ub294 \uad6c\uc131\uc785\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 5, "\uc0dd\uac01\uc774 \ud06c\ub294 \uc778\ubb38\ud559 6 \uc5ed\uc0ac - \uc65c \uc5ed\uc0ac \uacf5\ubd80\uac00 \uc911\uc694\ud558\ub2e4\uace0 \ud560\uae4c?", ["\ucd5c\uacbd\uc11d", "\uc774\uc9c4\uc544"], 0, "\uc5ed\uc0ac \uacf5\ubd80\uc758 \uc758\ubbf8\uc640 \ubc29\ubc95\ub860\uc744 \ub2e4\ub8e8\ub294 \uba54\ud0c0 \uc218\uc900\uc758 \ub0b4\uc6a9\uc73c\ub85c, \ucd08\ub4f1 5\ud559\ub144 \uc544\ub4e4\uc758 \uc5ed\uc0ac\u00b7\uc0ac\ud68c \uc218\uc5c5 \ubcf4\ucda9\uacfc \ud765\ubbf8 \uc720\ubc1c\uc774\ub77c\ub294 \uc9c1\uc811\uc801\uc778 \ud559\uc2b5 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.", 0, "\uc5ed\uc0ac \uacf5\ubd80\uc758 \uc911\uc694\uc131\uc744 \uc124\uba85\ud558\uc9c0\ub9cc, \uc544\ub4e4\uc774 \ud765\ubbf8\ub97c \ub290\ub07c\uae30\uc5d0\ub294 \ub2e4\uc18c \ub531\ub531\ud55c \ub0b4\uc6a9\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 6, "\ub180\uba74\uc11c \uacf5\ubd80\ud558\ub294 \ub180\uacf5 \ud55c\uad6d\uc0ac : \uace0\ub824 - \ud0dc\uc870 \uc655\uac74 ~ \uacf5\uc591\uc655", ["\uc774\uc815\ubbfc", "\uae40\uc815\ud604", "\uc624\ub3c4\ud654", "\ucd5c\uc9c0\uc740"], 0, "", 1, "\ub180\uc774\ud65c\ub3d9\uc744 \ud1b5\ud574 \uc5ed\uc0ac\uc5d0 \ud765\ubbf8\ub97c \ub290\ub084 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ub418\uc5b4 \uc788\uc5b4 \uc544\ub4e4\uc5d0\uac8c \uc801\ud569\ud569\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 7, "\ub180\uba74\uc11c \uacf5\ubd80\ud558\ub294 \ub180\uacf5 \ud55c\uad6d\uc0ac : \uc870\uc120 (\uc0c1) - \uc870\uc120 \uac74\uad6d ~ \uc601\uc870\u00b7\uc815\uc870 \uc2dc\ub300", ["\uc601\uc218", "\uae40\uc815\ud604", "\uc624\ub3c4\ud654", "\ucd5c\uc9c0\uc740"], 0, "", 1, "\uc5ed\uc0ac\ub97c \ub180\uc774\ub85c \uc811\uadfc\ud558\uc5ec \uc544\ub4e4\uc774 \ud765\ubbf8\ub97c \ub290\ub07c\uba70 \uc77d\uc744 \uc218 \uc788\uc744 \uac83 \uac19\uc2b5\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 8, "Why? \uc640\uc774 \ud55c\uad6d\uc0ac 1-22\uad8c A \uc138\ud2b8 - y? \ud55c\uad6d\uc0ac ", ["\uc774\uadfc\uc678", "\uadf9\ub3d9\ub9cc\ud654\uc5f0\uad6c\uc18c\uc678"], 0, "", 0, ""], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 9, "\ud589\ubcf5\ud55c \ud55c\uad6d\uc0ac \ucd08\ub4f1\ud559\uad50 4 - \uc138\uacc4 \uc18d\uc758 \ucf54\ub9ac\uc544", ["\uc804\uad6d\uc5ed\uc0ac\uad50\uc0ac\ubaa8\uc784"], 1, "\uc5ed\uc0ac \uad50\uc0ac\ub4e4\uc774 \ub9cc\ub4e0 \uc0dd\ub3d9\uac10 \uc788\ub294 \uc774\uc57c\uae30 \ud615\uc2dd\uc73c\ub85c \ub531\ub531\ud55c \uc124\uba85\uc744 \ud53c\ud558\uace0, \ucd08\ub4f1\ud559\uc0dd\uc774 \ube60\uc838\ub4e4\uc5b4 \uc77d\uc744 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ub418\uc5b4 \ucd08\ub4f1 5\ud559\ub144 \uc544\ub4e4\uc758 \ud765\ubbf8 \uc720\ubc1c\uacfc \uc218\uc900\uc5d0 \ubd80\ud569\ud569\ub2c8\ub2e4.", 1, "\uc544\uc774\ub4e4\uc774 \ud765\ubbf8\ub97c \ub290\ub084 \uc218 \uc788\ub294 \uc774\uc57c\uae30\ub97c \ud1b5\ud574 \uc5ed\uc0ac\uc640 \uc18c\ud1b5\ud560 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\uc904 \uac83\uc785\ub2c8\ub2e4."], [2, "sim_B_\ud55c\ubbf8\uc601_s2_1781706290", 10, "\uad50\uacfc\uc11c \uc18d \uccb4\ud5d8\ud559\uc2b5 \uc6b0\ub9ac\ub098\ub77c \ubcf4\ubb3c\uc744 \ucc3e\uc544\ub77c! - \ub294 \uc5ed\uc0ac\uc5ec\ud589 ", ["\ub178\ud76c\uc625", "\uae40\uc138\uc601"], 0, "", 0, ""], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 1, "\uadf8\ub9bc\uc73c\ub85c \ubcf4\ub294 \ud55c\uad6d\uc0ac 5 - \uc870\uc120\uc758 \uac1c\ud56d\ubd80\ud130 \ud604\ub300\uae4c\uc9c0", ["\ud669\uc740\ud76c", "\uc1a1\uc9c4\uc6b1"], 1, "\ucd085~\uc9111 \uc218\uc900\uc758 \uc26c\uc6b4 \uc2a4\ud1a0\ub9ac\ud154\ub9c1\uacfc \uadf8\ub9bc\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \ub450 \uc544\uc774\uac00 \ud568\uaed8 \uc77d\uae30 \uc88b\uc73c\uba70, \uc5ed\uc0ac\u00b7\uc0ac\ud68c \uc7a5\ub974\ub85c \uac00\uce58\uad00 \ud615\uc131\uc5d0 \ub3c4\uc6c0\uc774 \ub418\uace0, \uac00\uc871 \ub300\ud654 \uc8fc\uc81c\ub85c \uc801\ud569\ud558\ub2e4.", 1, "\uc7ac\ubbf8\uc788\uace0 \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \uc5ed\uc0ac\ucc45\uc73c\ub85c, \uac00\uc871\uc774 \ud568\uaed8 \uc77d\uc73c\uba70 \ub300\ud654\ud558\uae30\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 2, "\ud589\ubcf5\ud55c \ud55c\uad6d\uc0ac \ucd08\ub4f1\ud559\uad50 4 - \uc138\uacc4 \uc18d\uc758 \ucf54\ub9ac\uc544", ["\uc804\uad6d\uc5ed\uc0ac\uad50\uc0ac\ubaa8\uc784"], 1, "\uc5ed\uc0ac\ub97c '\ub098 \uc790\uc2e0\uc758 \uc0b6\uacfc \ubc00\uc811\ud55c \uad00\uacc4'\ub85c \uc774\ud574\ud558\uac8c \ud558\ub294 \uad50\uc591\uc11c\ub85c, \ub450 \uc544\uc774 \uc218\uc900\uc5d0 \ub9de\ub294 \ubcf8\uaca9\uc801 \uc5ed\uc0ac \uc774\uc57c\uae30\uc774\uba70 \uac00\uc871 \ub300\ud654\uc640 \uac00\uce58\uad00 \ud615\uc131\uc5d0 \uc801\ud569\ud558\ub2e4.", 1, "\uc544\uc774\ub4e4\uc774 \uc5ed\uc0ac\uc5d0 \ub300\ud55c \ud765\ubbf8\ub97c \ub290\ub07c\uace0, \uac00\uce58\uad00 \ud615\uc131\uc5d0 \ub3c4\uc6c0\uc744 \uc904 \uc218 \uc788\ub294 \ub0b4\uc6a9\uc785\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 3, "\uc0dd\uac01\uc774 \ud06c\ub294 \uc778\ubb38\ud559 6 \uc5ed\uc0ac - \uc65c \uc5ed\uc0ac \uacf5\ubd80\uac00 \uc911\uc694\ud558\ub2e4\uace0 \ud560\uae4c?", ["\ucd5c\uacbd\uc11d", "\uc774\uc9c4\uc544"], 1, "\uc5ed\uc0ac\ub97c '\uc0dd\uac01\ud558\ub294 \uacf5\ubd80'\ub85c \uc811\uadfc\ud558\uac8c \ud558\ub294 \uc778\ubb38 \uad50\uc591\uc11c\ub85c, \ucd085~\uc9111\uc774 \ud568\uaed8 \ubb3b\uace0 \ub2f5\ud560 \uc218 \uc788\ub294 \uc9c8\ubb38 \uc911\uc2ec\uc758 \uad6c\uc131\uc774 \uac00\uc871 \ub300\ud654\uc5d0 \ub9e4\uc6b0 \uc801\ud569\ud558\ub2e4.", 1, "\uc5ed\uc0ac \uacf5\ubd80\uc758 \uc911\uc694\uc131\uc744 \uc544\uc774\ub4e4\uc758 \ub208\ub192\uc774\uc5d0 \ub9de\ucdb0 \uc124\uba85\ud558\uc5ec \ub300\ud654 \uc8fc\uc81c\ub85c \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 4, "\ube5b\ub09c\ub2e4! \ud55c\uad6d\uc0ac \uc778\ubb3c 100 9 - \uc870\uc120 \ud6c4\uae30: \uc120\ube44\ub4e4, \uc0c8 \uc138\uc0c1\uc744 \uafc8\uafb8\ub2e4", ["\ubc15\uc724\uaddc", "\ubc31\ub450\ub9ac"], 1, "\uc778\ubb3c \uc774\uc57c\uae30\ub85c \uc5ed\uc0ac\ub97c \uc27d\uace0 \uc7ac\ubbf8\uc788\uac8c \ud480\uc5b4\ub0b4\uba70 \ucd085~\uc9111 \ubaa8\ub450 \uc77d\uc744 \uc218 \uc788\uace0, \uc5ed\uc0ac \uc18d \uc778\ubb3c\uc758 \uc0b6\uc744 \ud1b5\ud574 \uac00\uce58\uad00 \ud615\uc131\uc5d0 \ub3c4\uc6c0\uc774 \ub418\uc5b4 \uac00\uc871 \ub300\ud654 \uc8fc\uc81c\ub85c \uc88b\ub2e4.", 1, "\uc778\ubb3c \uc774\uc57c\uae30\ub97c \ud1b5\ud574 \ud765\ubbf8\ub86d\uac8c \uc5ed\uc0ac\ub97c \uc811\ud560 \uc218 \uc788\uc5b4 \uac00\uc871 \ub3c5\uc11c\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 5, "\ud1b5\uc77c \uc2e0\ub77c\uc640 \ubc1c\ud574 - \uc0ac \uc5f4\ucc28 2", ["\ubc30\uc6b0\uc131", "\uc1a1\ud638\uc815", "\ubc15\ud604\ucca0", "\ucd5c\uc900\uc11d"], 0, "", 1, "\uc5b4\ub9b0\uc774\ub4e4\uc774 \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\ub294 \uad6c\uc131\uc73c\ub85c, \uac00\uc871\uc774 \ud568\uaed8 \uc77d\uae30 \uc88b\uc740 \ucc45\uc785\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 6, "\uace0\ub824 \uc2dc\ub300 - \uc0ac \uc5f4\ucc28 3", ["\ubc30\uc6b0\uc131", "\uc1a1\ud638\uc815", "\ubc15\ud604\ucca0"], 0, "", 1, "\uc5b4\ub9b0\uc774 \ub208\ub192\uc774\uc5d0 \ub9de\ucd98 \uc7ac\ubbf8\uc788\ub294 \uc5ed\uc0ac \uc774\uc57c\uae30\ub85c \uac00\uc871 \ub3c5\uc11c\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 7, "\uc5b4\ub5bb\uac8c \uc0dd\uac01\ud574? \ud55c\uad6d\uc0ac2 - \uc0dd\uac01\uc774 \uae4a\uc5b4\uc9c0\ub294 \uc5f4\uc1f3\ub9d0", ["\uc774\uc18c\uc601", "\uc11c\ud574\uacbd", "\uc774\uc218\uc9c4", "\uc815\uc7ac\uc724"], 1, "\uc9c8\ubb38\uc744 \ud1b5\ud574 \ub2e4\uc591\ud55c \uc2dc\uac01\uc744 \uc81c\uc2dc\ud558\ub294 \uad6c\uc131\uc73c\ub85c \ucd085~\uc9111\uc774 \ud568\uaed8 '\uc5b4\ub5bb\uac8c \uc0dd\uac01\ud574?'\ub77c\ub294 \uc9c8\ubb38\uc73c\ub85c \ub300\ud654\ud560 \uc218 \uc788\uc73c\uba70, \uac00\uc871 \ub3c5\uc11c \ud6c4 \ud1a0\ub860\uc5d0 \ucd5c\uc801\ud654\ub418\uc5b4 \uc788\ub2e4.", 1, "\ub2e4\uc591\ud55c \uc2dc\uac01\uc744 \uc81c\uc2dc\ud558\uc5ec \uac00\uc871 \uac04\uc758 \ub300\ud654 \uc8fc\uc81c\ub85c \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 8, "\ub180\uba74\uc11c \uacf5\ubd80\ud558\ub294 \ub180\uacf5 \ud55c\uad6d\uc0ac : \uace0\ub824 - \ud0dc\uc870 \uc655\uac74 ~ \uacf5\uc591\uc655", ["\uc774\uc815\ubbfc", "\uae40\uc815\ud604", "\uc624\ub3c4\ud654", "\ucd5c\uc9c0\uc740"], 0, "\ub180\uc774\ud65c\ub3d9\ubd81\uc73c\ub85c \ucd08\ub4f1 \uc800\ud559\ub144 \ub300\uc0c1\uc774\uc5b4\uc11c \uc9111 \uc790\ub140\uc5d0\uac8c\ub294 \uc218\uc900\uc774 \ub0ae\uc744 \uc218 \uc788\uc73c\uba70, \ud65c\ub3d9 \uc911\uc2ec\uc774\ub77c \uac00\uc871\uc774 \ud568\uaed8 \uc77d\uace0 \ub300\ud654\ud558\ub294 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uacfc \ub9de\uc9c0 \uc54a\ub294\ub2e4.", 1, "\ub180\uc774\ud65c\ub3d9\uc744 \ud1b5\ud574 \uc5ed\uc0ac\uc5d0 \ud765\ubbf8\ub97c \ub290\ub084 \uc218 \uc788\uc5b4 \uac00\uc871 \ub3c5\uc11c\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 9, "\ub180\uba74\uc11c \uacf5\ubd80\ud558\ub294 \ub180\uacf5 \ud55c\uad6d\uc0ac : \uc870\uc120 (\uc0c1) - \uc870\uc120 \uac74\uad6d ~ \uc601\uc870\u00b7\uc815\uc870 \uc2dc\ub300", ["\uc601\uc218", "\uae40\uc815\ud604", "\uc624\ub3c4\ud654", "\ucd5c\uc9c0\uc740"], 0, "\ub180\uc774\ud65c\ub3d9\ubd81\uc73c\ub85c \ucd08\ub4f1 \uc800\ud559\ub144 \ub300\uc0c1\uc774\uc5b4\uc11c \uc9111 \uc790\ub140\uc5d0\uac8c\ub294 \uc218\uc900\uc774 \ub0ae\uc744 \uc218 \uc788\uc73c\uba70, \ud65c\ub3d9 \uc911\uc2ec\uc774\ub77c \uac00\uc871\uc774 \ud568\uaed8 \uc77d\uace0 \ub300\ud654\ud558\ub294 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uacfc \ub9de\uc9c0 \uc54a\ub294\ub2e4.", 1, "\uc7ac\ubbf8\uc788\ub294 \ud65c\ub3d9\uc73c\ub85c \uc5ed\uc0ac\uc5d0 \uc811\uadfc\ud560 \uc218 \uc788\uc5b4 \uac00\uc871\uc774 \ud568\uaed8 \uc77d\uae30 \uc88b\uc2b5\ub2c8\ub2e4."], [3, "sim_B_\ud55c\ubbf8\uc601_s3_1781706354", 10, "Why? \uc640\uc774 \ud55c\uad6d\uc0ac 1-22\uad8c A \uc138\ud2b8 - y? \ud55c\uad6d\uc0ac ", ["\uc774\uadfc\uc678", "\uadf9\ub3d9\ub9cc\ud654\uc5f0\uad6c\uc18c\uc678"], 0, "", 0, ""]], "log_mode": "IMMUTABLE", "ncols": 9, "nrows": 30}
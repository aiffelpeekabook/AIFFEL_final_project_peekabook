{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "book_intro": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "category": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "persona_name": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "reflection": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "session_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "summary": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["rank", "persona_name", "session_id", "title", "author", "category", "book_intro", "score", "reason", "summary", "reflection"], "data": [[1, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\ubab8\uac12\uc744 \ub192\uc5ec\ub77c - \uc9c0\uae08 \ub2f9\uc2e0\uc758 \uac00\uce58\uc5d0 \uc801\ud569\ud55c \uc5f0\ubd09\uc744 \ubc1b\uace0 \uc788\ub294\uac00?", ["\ud788\ub77c\uc774 \ub2e4\uce74\uc2dc"], "\uc131\uacf5", "\uc9c0\uae08 \ub2f9\uc2e0\uc758 \ucee4\ub9ac\uc5b4\ub294 \uc5b4\ub5a4 \uc218\uc900\uc778\uac00? \uc694\uc998\uc740 \uacbd\uc81c \ud658\uacbd\uc774 \uc720\ub09c\ud788 \uc88b\uc9c0 \uc54a\ub2e4. \uc0ac\ud68c\uc640 \uc790\uc2e0\uc758 \uc55e\ub0a0\uc774 \ubcf4\uc774\uc9c0 \uc54a\uc544 \ud758\ub7ec\uac00\ub294 \ub300\ub85c \ub530\ub77c\uac00\uace0\ub294 \uc788\uc9c0\ub9cc \uc5b4\ub5bb\uac8c\ub4e0 \ubc29\ubc95\uc744 \ucc3e\uc544\uc57c \ud55c\ub2e4. \ub294 \uc704\uae30\uac10\uc744 \ub290\ub07c\ub294 \uc0ac\ub78c\uc774 \ub9ce\ub2e4. \ud558\uc9c0\ub9cc \uadf8\uc800 \uc2dc\ub300\uc758 \ud750\ub984\uc5d0 \ub0b4\ub9e1\uae30\uae30\ub9cc \ud558\uba74 \uc544\ubb34\uac83\ub3c4 \ubc14\ub00c\uc9c0 \uc54a\ub294\ub2e4. \ud604\uc7ac\uc758 \uace0\ubbfc\uc744 \ud574\uc18c\ud558\uace0 \uc790\uc2e0\uc758 \uc778\uc0dd\uc744 \uac1c\ucc99\ud574 \ub098\uac00\uae30 \uc704\ud574\uc11c\ub294 \uba3c\uc800 \uc791\uc740 \uac78\uc74c\uc774\ub77c\ub3c4 \ud55c \ubc1c\uc9dd\uc744 \ub0b4\ub51b\ub294 \uac83\uc774 \uc911\uc694\ud558\ub2e4. \uadf8 \uccab \uac78\uc74c\uc774 \ubc14\ub85c \uc790\uc2e0\uc758 \ucee4\ub9ac\uc5b4\ub97c \uc9c4\uc9c0\ud558\uac8c \uace0\ubbfc\ud558\ub294 \uc77c\uc774\ub2e4. \ucee4\ub9ac\uc5b4\ub97c \uc313\uae30 \uc704\ud574\uc11c\ub294 \ube44\uc988\ub2c8\uc2a4 \uc2a4\ud0ac\uacfc \uacbd\uc601\uc5d0 \uad00\ud55c \ucd5c\uc18c\ud55c\uc758 \uc9c0\uc2dd\uc744 \uac16\ucd9c \ud544\uc694\uac00 \uc788\ub2e4. \uc774 \ucc45\uc5d0\ub294 \ub3c5\uc790\ub4e4\uc774 \ucee4\ub9ac\uc5b4 \uc124\uacc4 \uc640 \ube44\uc988\ub2c8\uc2a4 \uc2a4\ud0ac \ud68d\ub4dd \uc774\ub77c\ub294 \ub450 \ub9c8\ub9ac \ud1a0\ub07c\ub97c \ub3d9\uc2dc\uc5d0 \uc7a1\uc744 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\ub2e4.", 1, "\ucee4\ub9ac\uc5b4 \uc124\uacc4\uc640 \ube44\uc988\ub2c8\uc2a4 \uc2a4\ud0ac \ud68d\ub4dd\uc744 \ud1b5\ud574 \uc774\uc9c1 \uc900\ube44\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\ub294 \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [2, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uc9c0\uae08 \ud68c\uc0ac\uc640 \uc548\ub155\ud558\uace0 \uc2f6\uc740 \ub0a0", ["\uc608\ub3d9\ud76c"], "CEO/\ube44\uc988\ub2c8\uc2a4\ub9e8\uc744 \uc704\ud55c \ub2a5\ub825\uacc4\ubc1c", "\uc9c0\uae08, \uc774\uc9c1\uc744 \ud574\uc57c \ud560\uae4c?, \ub0b4\uac00 \uac00\uace0 \uc2f6\uc740 \uacf3\uc5d0 \uac08 \uc218 \uc788\uc744\uae4c?, \ud68c\uc0ac \uc9c0\uc6d0\uc740 \uc5b4\ub5bb\uac8c \ud574\uc57c \ud558\uc9c0?, \uc624\ub79c\ub9cc\uc5d0 \uc4f0\ub294 \uc774\ub825\uc11c, \uacbd\ub825\uc9c1\uc740 \uc5b4\ub5bb\uac8c \uc368\uc57c\ud558\ub098?, \uacbd\ub825\uc790\uc758 \uba74\uc811\uc740 \ubb34\uc5c7\uc774 \ub2e4\ub97c\uae4c?, \ud569\uaca9\ud558\uace0 \ub098\uba74 \uc0ac\ud45c\ub3c4 \uc368\uc57c \ud558\uace0 \uc5f0\ubd09\ud611\uc0c1\ub3c4 \ud574\uc57c \ud560 \ud150\ub370. \ub4f1 \uc9c1\uc7a5\uc778\uc774\ub77c\uba74 \ud55c \ubc88\ucbe4 \uace0\ubbfc\ud574\ubcf4\uc558\uc744\uc9d0\ud55c \uc9c8\ubb38\ub4e4\uc5d0 \uc774\uc9c1 \uc120\ubc30\ub4e4\uc774 \ub2f5\ud55c\ub2e4. \uc774\uc9c1 \uc120\ubc30\ub4e4\uc758 \uba58\ud1a0\ub9c1 \uc2a4\ud1a0\ub9ac\ub97c \ubcf4\uba70 \uc774\uc9c1\uc744 \uc0dd\uac01\ud558\ub294 \uc21c\uac04\ubd80\ud130, \uc774\uc9c1\uc744 \uc900\ube44\ud558\uace0, \uacbd\ud5d8\ud558\uace0, \ub9c8\ubb34\ub9ac\ud55c \uadf8 \uc774\ud6c4\uae4c\uc9c0 \ub2f9\uc2e0\uc774 \uacaa\uac8c \ub420 \uc774\uc9c1\uc5d0 \uad00\ud55c \ubaa8\ub4e0 \uac83 \uc744 \ubbf8\ub9ac \uccb4\ud5d8\ud574 \ubcfc \uc218 \uc788\ub294 \uae30\ud68c\ub97c \uc5bb\uac8c \ub420 \uac83\uc774\ub2e4.", 1, "\uc774\uc9c1\uc5d0 \uad00\ud55c \ub2e4\uc591\ud55c \uc9c8\ubb38\uacfc \uacbd\ud5d8\uc744 \ub2e4\ub8e8\uc5b4 \uc774\uc9c1 \uc900\ube44\uc5d0 \uc2e4\uc9c8\uc801\uc778 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [3, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\ub9c8\uc74c\uc5d0 \uafc8\uc744 \ud06c\uac8c \uadf8\ub824\ub77c", ["\uc720\ud76c\ud0dc"], "\uae30\ub3c5\uad50(\uac1c\uc2e0\uad50)", "\uadf8\ub3d9\uc548 \uae30\uc5c5\ud604\uc7a5 \uc704\uc8fc\ub85c \uac15\uc758\ud55c \uac83\uc744 \ud1a0\ub300\ub85c, \ub098\ub984\ub300\ub85c \uc5b4\ub824\uc6e0\ub358 \ubd80\ubd84\uacfc \uace0\ubbfc\ud558\uba74\uc11c \ud574\uacb0\ud574\uc57c\ub9cc \ud588\ub358 \uc0ac\ud56d\ub4e4\uc744 \uad00\uc2ec \uc788\ub294 \ubd84\ub4e4\uacfc \ud6c4\ubc30\ub4e4\uc5d0\uac8c \uc870\uae08\uc774\ub098\ub9c8 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uc73c\uba74 \ud558\ub294 \ub9c8\uc74c\uc744 \ub2f4\uc740 \ucc45. \uc0b6 \uc18d\uc5d0\uc11c \ub3c4\uc804\uacfc \ucc3d\uc758, \uc5f4\uc815\uc801\uc73c\ub85c \ud65c\ub3d9\ud588\ub358 \ub0b4\uc6a9\ub4e4\uc744 \uc774\uc804 \ucc45 \ub9c8\uc74c\uc5d0 \uafc8\uc744 \uadf8\ub824\ub77c \uc5d0 \uc9c4\uc194\ud558\uac8c \uc18c\uac1c\ud588\ub2e4.", 0, "\uae30\uc5c5 \ud604\uc7a5\uc5d0\uc11c\uc758 \uacbd\ud5d8\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ub41c \uad6c\uccb4\uc801\uc778 \ud1b5\ucc30\uc774 \ubd80\uc871\ud569\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [4, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\ub108\ub9cc \ud798\ub4dc\ub0d0? \ub098\ub3c4 \ud798\ub4e4\uc5b4 \uc8fd\uaca0\ub2e4.", ["\ucd5c\uc6c5\uc12d"], "\uc131\uacf5", "\uc774 \ucc45\uc740 \ub2e8\uc9c0 \uac1c\uc778\uc801\uc778 \uc131\ucc30\uacfc \uc131\uc7a5\uc5d0 \uba38\ubb3c\uc9c0 \uc54a\ub294\ub2e4. \uc6b0\ub9ac\ub294 \uc11c\ub85c\uc758 \uc0b6 \uc18d\uc5d0\uc11c \uc601\uac10\uc744 \ubc1b\uc744 \uc218 \uc788\uace0, \uc791\uc740 \ud589\ub3d9\uc73c\ub85c \ub204\uad70\uac00\uc5d0\uac8c \uc6a9\uae30\ub97c \uc904 \uc218 \uc788\ub2e4. \ud55c \uc0ac\ub78c\uc758 \ubcc0\ud654\ub294 \ub610 \ub2e4\ub978 \uc0ac\ub78c\uc758 \ubcc0\ud654\ub97c \uc774\ub04c\uc5b4 \ub0bc \uc218 \uc788\ub2e4. \uadf8\uac83\uc774 \ubc14\ub85c \uc6b0\ub9ac\uac00 \ud568\uaed8 \uc0b4\uc544\uac00\ub294 \uc774\uc720\uc774\ub2e4. \uc774 \ucc45\uc744 \uc5b4\ub5bb\uac8c \uc77d\uc5b4\uc57c \ud560\uae4c? \uc774 \ucc45\uc740 \ub2e8\uc21c\ud788 \uc77d\ub294 \ucc45 \uc774 \uc544\ub2c8\ub2e4. \uc0dd\uac01\ud558\uace0, \ub290\ub07c\uace0, \uc2e4\ud589\ud558\ub294 \ucc45\uc774\ub2e4. \uac01 \uc7a5\ub9c8\ub2e4 \ud3ec\ud568\ub41c \uc9c8\ubb38\uc5d0 \ub2f5\ud574\ubcf4\uace0, \ucc45\uc5d0\uc11c \uc81c\uc2dc\ud558\ub294 \uc791\uc740 \uc2e4\ucc9c\ub4e4\uc744 \uc2dc\ub3c4\ud574\ubcf4\uc790. \uc644\ubcbd\ud558\uac8c \ud574\uc57c \ud55c\ub2e4. \ubd80\ub2f4\uc744 \uac00\uc9c8 \ud544\uc694\ub294 \uc5c6\ub2e4. \uc791\uc740 \ud55c \uac78\uc74c\uc774 \uc313\uc5ec \ud070 \ubcc0\ud654\ub97c \ub9cc\ub4e4\uc5b4\ub0b8\ub2e4. \ub610\ud55c, \uc774 \ucc45\uc740 \ub2f9\uc2e0\uc758 \uc0b6\uc758 \uc5b4\ub290 \uc21c\uac04\uc774\ub4e0 \ub2e4\uc2dc \uaebc\ub0b4\uc5b4\ubcfc \uc218 \uc788\ub294 \uce5c\uad6c \uac19\uc740 \uc874\uc7ac\uac00 \ub418\uace0\uc790 \ud55c\ub2e4. \ud798\ub4e0 \uc21c\uac04\uc5d0\ub294 \uc704\ub85c\ub97c, \uae38\uc744 \uc783\uc740 \uc21c\uac04\uc5d0\ub294 \ubc29\ud5a5\uc744 \uc81c\uc2dc\ud558\ub294 \ub3c4\uad6c\ub85c \ud65c\uc6a9\ud574\ubcf4\ub77c.", 0, "\uac1c\uc778\uc801\uc778 \uc131\ucc30\uacfc \uc131\uc7a5\uc5d0 \uc911\uc810\uc744 \ub450\uace0 \uc788\uc5b4 \uc774\uc9c1 \uc900\ube44\uc640\ub294 \uc9c1\uc811\uc801\uc778 \uc5f0\uad00\uc774 \uc5c6\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [5, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "1%\uc758 \uac00\ub2a5\uc131\uc744 \uc131\uacf5\uc73c\ub85c \ubc14\uafbc \uc0ac\ub78c\ub4e4", ["\uc774\ub300\ud76c"], "\uc131\uacf5", "\uc9c1\uc7a5\uc744 \uc783\uace0, \uc0c1\ucc98\ub97c \ubc1b\uace0, \uac11\uc791\uc2a4\ub7ec\uc6b4 \uc0ac\uace0\uc640 \ubcd1\uc73c\ub85c \uace0\ud1b5\ub2f9\ud558\uace0, \uafc8\uc744 \uc783\uace0 \ubc29\ud669\ud558\ub294 \uc774\ub4e4\uc744 \uc704\ud55c \ucc45\uc774\ub2e4. \uace0\ub09c\uacfc \uc2ac\ud514 \uc18d\uc5d0\uc11c\ub3c4 \ud3ec\uae30\ud558\uc9c0 \uc54a\uace0 1 \uc758 \uac00\ub2a5\uc131\uc5d0 \ub3c4\uc804\ud558\uc5ec \uc131\uacf5\uc744 \uc774\ub8ec \uc5ed\uc0ac\uc18d\uc758 \uc2e4\uc81c \uc778\ubb3c\ub4e4\uc758 \uc774\uc57c\uae30\ub97c \ud1b5\ud574 \ud76c\ub9dd\uc744 \uc804\ud55c\ub2e4. \uc0c1\uc0c1\ud574\uc11c \ub9cc\ub4e4\uc5b4\ub0b8 \uc774\uc57c\uae30\uac00 \uc544\ub2c8\ub77c \uc2e4\uc81c\uc758 \uc774\uc57c\uae30\uc774\uae30 \ub54c\ubb38\uc5d0 \ud6e8\uc52c \ub354 \uae4a\uac8c \ub2e4\uac00\uc62c \uac83\uc774\ub2e4. 1 \uc758 \uac00\ub2a5\uc131\ub9cc \uc788\uc5b4\ub3c4 \ub204\uad6c\ub098 \uc131\uacf5\ud560 \uc218 \uc788\ub2e4\ub294 \uba54\uc2dc\uc9c0\ub97c \uc804\ud558\uba70, \uc131\uacf5\uc758 \uae38\ub85c \uc548\ub0b4\ud55c\ub2e4.", 0, "\uc131\uacf5 \uc0ac\ub840\ub97c \ub2e4\ub8e8\uc9c0\ub9cc, \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ub41c \uad6c\uccb4\uc801\uc778 \uc870\uc5b8\uc774 \ubd80\uc871\ud569\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [6, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uc124\ub798\ub294 \ucde8\uc5c5 \uc900\ube44 - \uc2dc\uc791\ubd80\ud130 \ubc14\ub974\uac8c", ["\uc6b0\uc124\ub798"], "\ucde8\uc5c5/\uc0c1\uc2dd/\uc801\uc131", "5,000\uc5ec \uac74\uc758 \uc0c1\ub2f4\uc744 \ud1b5\ud574 \ucde8\uc900\uc0dd\ub4e4\uc774 \uc790\uc2e0\uc758 \uc0b6 \uc804\ubc18\uc5d0 \ub300\ud574 \uae4a\uc774 \uace0\ubbfc\ud558\uace0 \uc6d0\ud558\ub294 \uc0b6\uc744 \uc0b4 \uc218 \uc788\ub3c4\ub85d \uc800\uc790\uac00 \uc9c1\uc811 \uac1c\ubc1c\ud55c 7\ub2e8\uacc4 \ucde8\uc5c5\uc900\ube44 \ud504\ub85c\uc138\uc2a4. 1\ub2e8\uacc4 \uc790\uae30 \uc774\ud574 2\ub2e8\uacc4 \uc9c1\ubb34 \uc870\uc0ac 3\ub2e8\uacc4 \ubaa9\ud45c \uc124\uc815 4\ub2e8\uacc4 \ucde8\uc5c5 \uc804\ub7b5 5\ub2e8\uacc4 \uc2e4\ucc9c \uc810\uac80 6\ub2e8\uacc4 \uc11c\ub958 \uc791\uc131 7\ub2e8\uacc4 \uba74\uc811 \uc900\ube44 \ucc45\uc5d0 \uc218\ub85d\ub41c \ud504\ub85c\uc138\uc2a4\ub97c \ub530\ub77c \ucc28\uadfc\ucc28\uadfc \uc900\ube44\ud558\ub2e4 \ubcf4\uba74 \uc5b4\ub290\uc0c8 \ucde8\uc5c5\uc758 \ubb38\ud131\uc5d0 \uc11c \uc788\ub294 \uc790\uc2e0\uc744 \ubc1c\uacac\ud558\uac8c \ub420 \uac83\uc774\ub2e4.", 1, "\ucde8\uc5c5 \uc900\ube44\ub97c \uc704\ud55c \uccb4\uacc4\uc801\uc778 \ud504\ub85c\uc138\uc2a4\ub97c \uc81c\uacf5\ud558\uc5ec \uc774\uc9c1 \uc900\ube44\uc5d0 \uc2e4\uc9c8\uc801\uc778 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [7, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uc7ac\uac1c\ubc1c\u318d\uc7ac\uac74\ucd95 \uac10\uc815\ud3c9\uac00\ub860", ["\uc774\ucca0\ud604"], "\uacbd\uc0c1\uacc4\uc5f4", "\uc800\uc790\uac00 \uc2e4\ubb34\uc5d0\uc11c \uc775\ud788\uace0 \ubc30\uc6b4 \ub178\ud558\uc6b0\uac00 \uace0\uc2a4\ub780\ud788 \ub179\uc544\uc788\ub2e4. \uc6b0\uc120 \uadf8\ub294 \uac01 \uc5c5\ubb34\uc758 \uac1c\ub150\uacfc \ubc30\uacbd\uc744 \uc815\ub9ac\ud558\uace0 \uc788\uc5b4 \ucc45\uc744 \uc811\ud558\ub294 \ub3c5\uc790\ub4e4\uc758 \uc774\ud574\ub97c \uc27d\uac8c \ud55c\ub2e4. \ub610\ud55c \uc0c1\ud669\ubcc4\ub85c \uac00\uc815\ud558\uace0 \uacbd\uc6b0\ubcc4 \uc5c5\ubb34\ucc98\ub9ac \uae30\uc900\uc744 \uc124\uba85\ud558\uace0 \uc788\ub2e4. \uc774 \ucc45\uc740 \uc5ec\uae30\uc11c \uba48\ucd94\uc9c0 \uc54a\ub294\ub2e4. \ud55c \uc0ac\uc548\uc5d0 \ub300\ud55c \uc5ec\ub7ec \uc774\ub860\uc744 \uc18c\uac1c\ud558\uba74\uc11c \uc800\uc790\uc758 \uac80\ud1a0\uc758\uacac\uc744 \uc0bd\uc785\ud568\uc73c\ub85c\uc368 \ub3c5\uc790\ub4e4\ub85c \ud558\uc5ec\uae08 \ud48d\ubd80\ud55c \uac04\uc811\uacbd\ud5d8\ub4e4\uc744 \ud558\uac8c \ub9cc\ub4e0\ub2e4. \uc544\uc6b8\ub7ec \uc2e4\ubb34\uc5d0\uc11c \ub193\uce58\uc9c0 \ub9d0\uace0 \ucc59\uaca8\uc57c \ud560 \uc720\uc758\uc0ac\ud56d\ub4e4\ub3c4 \uaf3c\uaf3c\ud558\uac8c \uc218\ub85d\ud568\uc73c\ub85c\uc368 \uc804\ubb38\uac00\uac00 \uc544\ub2cc \uc0ac\ub78c\ub4e4\ub3c4 \uc27d\uac8c \uc54c\uc544\ubcfc \uc218 \uc788\ub3c4\ub85d \ud588\ub2e4.", 0, "\uc804\ubb38\uc801\uc778 \ub0b4\uc6a9\uc73c\ub85c \uc774\uc9c1 \uc900\ube44\uc640\ub294 \uad00\ub828\uc774 \uc5c6\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [8, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uc140\ud504 \ucf54\uce6d\uc758 \uae30\uc220 - \ud3ec\ucd98 100\ub300 \uae30\uc5c5 CEO\uc640 \uc784\uc6d0\uc9c4\uc774 \ud65c\uc6a9\ud558\ub294 \uc790\uae30 \uc8fc\ub3c4 \uc131\uacf5\ubc95", ["\uc774\uc815\uc219"], "\uc131\uacf5", "\uc801\uc808\ud55c \uc2dc\uae30\uc758 \ud604\uba85\ud55c \uc870\uc5b8\uc740 \uc0ac\ub78c\uc744 \uc131\uc7a5\uc2dc\ud0a4\ub294 \uc6d0\ub3d9\ub825\uc774 \ub418\ub294\ub370, \uac00\ub2a5\ud558\ub2e4\uba74 \ub098\ub97c \uac00\uc7a5 \uc798 \uc544\ub294 \uc2a4\uc2a4\ub85c\uac00 \uc790\uc2e0\uc758 \ucf54\uce58\uac00 \ub418\ub294 \uac83\uc774 \uc131\uacf5\uc744 \uc704\ud55c \uac00\uc7a5 \ud655\uc2e4\ud55c \ubc1c\ud310\uc774 \ub420 \uac83\uc774\ub2e4. \ube44\uc988\ub2c8\uc2a4 \ud604\uc7a5\uc5d0\uc11c \uc2b9\ub9ac\uc758 \uacbd\ud5d8\uc744 \uac00\uc9c0\uace0 \uc788\ub294 \uc800\uc790\ub294 \ube44\uc988\ub2c8\uc2a4\ub9e8\uc774 \uacaa\uc744 \uc218 \uc788\ub294 \ubaa8\ub4e0 \uacbd\uc6b0\uc758 \uc218\ub97c \ub9dd\ub77c\ud558\uc5ec \uc131\uacfc\ub97c \ud5a5\uc0c1\uc2dc\ud0a4\uace0, \uc790\uae30 \uc790\uc2e0\uc758 \ud798\uc73c\ub85c, \uc790\uae30 \uc790\uc2e0\uc758 \ud589\ub3d9\uc73c\ub85c \uc131\uc7a5\ud560 \uc218 \uc788\ub294 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud55c\ub2e4. \uadf8\ub294 \uc5c5\ubb34 \ud604\uc7a5\uc5d0\uc11c \uacaa\uc744 \uc218 \uc788\ub294 \uc2dc\ud589\ucc29\uc624\ub4e4\uc744 \uc9c1\uc811 \ubd80\ub52a\ud788\uba70 \uadf9\ubcf5\ud574\uc628 \uacbd\ud5d8\uc744 \ud1b5\ud574 \ud604\uc5c5\uc5d0 \uc788\ub294 \uc0ac\ub78c\ub4e4\uc774\ub098 \uc0ac\ud68c\uc0dd\ud65c\uc744 \uc900\ube44\ud558\ub294 \uc774\ub4e4\uc5d0\uac8c \ubcf4\ub2e4 \ud6a8\uc728\uc801\uc73c\ub85c \ubaa9\ud45c\uc5d0 \ub2e4\uac00\uac08 \uc218 \uc788\ub294 \uae38\uc744 \uc54c\ub824\uc900\ub2e4. \uc140\ud504\ucf54\uce6d\uc740 \uc790\uc2e0\uc5d0 \ub300\ud55c \uad00\uc2ec\uacfc \uc560\uc815\uc774 \ubc14\ud0d5\uc774 \ub418\ub294 \uac83\uc73c\ub85c, \ucc45\uc5d0\uc11c\ub294 '\ub098'\ub97c \uc774\ud574\ud558\uace0 \ubcc0\ud654\ub97c \ub9cc\ub4e4\uc5b4\uac08 \uc218 \uc788\ub294 \ubc29\ubc95\uc744 \uccb4\uacc4\uc801\uc73c\ub85c \uc804\ud574\uc900\ub2e4.", 1, "\uc790\uae30 \uc8fc\ub3c4\uc801\uc778 \uc131\uc7a5 \ubc29\ubc95\uc744 \uc81c\uc2dc\ud558\uc5ec \uc774\uc9c1 \uc900\ube44\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [9, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uace0\uc6a9\ubd88\uc548\uc5d0\ub3c4 \ud754\ub4e4\ub9ac\uc9c0 \uc54a\ub294 \ud798! \ucee4\ub9ac\uc5b4 GPS - \ub450 \ubc88\uc9f8 \uc77c\uc790\ub9ac\ub97c \uc704\ud55c \ud50c\ub79c B\ub97c \uc138\uc6cc\ub77c!", ["\uae40\uacbd\ud76c", "\uae40\uc18c\ud604", "\uc774\ubbfc\uc544"], "\uc911\ub144\uc758 \uc790\uae30\uacc4\ubc1c", "\ub0b4\uc77c\uc774\ub77c\ub3c4, \uc9c1\uc7a5\uc744 \uc783\uc744 \uc218 \uc788\ub2e4 \ud68c\uc0ac\ub97c \ub2e4\ub140\ub3c4 \ubd88\uc548\ud55c \uc9c1\uc7a5\uc778, \uc774\uc81c\ub294 \ub098\ub9cc\uc758 \ud798\uc744 \uae38\ub7ec\uc57c \ud560 \ub54c! \uc624\ub298\ub0a0 \uc9c1\uc7a5\uc778\ub4e4\uc740 \ud558\ub8e8\ud558\ub8e8\ub97c \ubd88\uc548\uac10 \uc18d\uc5d0 \uc0b4\uace0 \uc788\ub2e4. \uacbd\uae30 \uce68\uccb4 \uc7a5\uae30\ud654\uc640 \uce58\uc5f4\ud55c \uacbd\uc7c1 \uc0ac\uc774\uc5d0\uc11c \uc790\uc2e0\uc758 \ubc25\uadf8\ub987\uc744 \uc9c0\ud0a4\ub294 \uc77c\uc740 \uc810\uc810 \ub354 \ud798\ub4e4\uc5b4\uc84c\uace0, \uae30\uc5c5\uc5d0\uc11c \uc815\ub144\uc744 \ucc44\uc6cc\uc57c\uaca0\ub2e4\ub294 \uc0dd\uac01\uc740 \ub108\ubb34\ub098 \ud5c8\ud669\ub41c \uae30\ub300\uac00 \ub418\uc5b4\ubc84\ub838\ub2e4. \ub9e4\uc77c\ub9e4\uc77c \ubd88\uc548\uac10 \uc18d\uc5d0 \ucd9c\ud1f4\uadfc\uc744 \ud558\ub294 \uc9c1\uc7a5\uc778\ub4e4\uc774 \ub9ce\uc9c0\ub9cc \uc5b4\ub5a4 \ub300\uc548\ub3c4 \ucc3e\uae30 \uc5b4\ub824\uc6b4 \ud604\uc2e4 \uc55e\uc5d0\uc11c \uc790\uc2e0\uc758 \ubbf8\ub798\ub97c \uc0c8\ub86d\uac8c \uad6c\uccb4\uc801\uc73c\ub85c \uadf8\ub824\ub098\uac00\ub294 \uc77c \ub610\ud55c \uacb0\ucf54 \uc27d\uc9c0 \uc54a\ub2e4. \uc774 \ucc45\uc740 \ubbf8\ub798\uc5d0 \ub300\ud55c \uc5b4\ub5a4 \ub300\ucc45\uc774\ub098 \uc900\ube44 \uc5c6\uc774 \ud68c\uc0ac\ub97c \ub2e4\ub2c8\ub294 \uc9c1\uc7a5\uc778\ub4e4\uc5d0\uac8c \uc790\uc2e0\uc758 \ud604\uc7ac\ub97c \uaf3c\uaf3c\ud788 \uc0b4\ud3b4\ubcf4\uace0, \uc880 \ub354 \uc131\uacf5\uc801\uc778 \ub0b4\uc77c\uc744 \uac00\uafd4\ub098\uac00\uae30 \uc704\ud55c \ub2e4\uc591\ud55c \uc815\ubcf4\ub97c \uc81c\uacf5\ud55c\ub2e4. \uacbd\ub825\uad00\ub9ac, \uc740\ud1f4\uc124\uacc4 \ub4f1 \uac01 \ubd84\uc57c \uc804\ubb38\uac00\ub4e4\uc774 \ud568\uaed8 \uc900\ube44\ud55c \ucee4\ub9ac\uc5b4 GPS \ub294 \ubcf4\ub2e4 \uc548\uc815\uc801\uc778 \uacbd\ub825 \uad00\ub9ac\uc640 \uc804\uc9c1, \uc740\ud1f4\uc5d0 \ub300\ud55c \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc744 \uc120\uc0ac\ud560 \uac83\uc774\ub2e4.", 1, "\ucee4\ub9ac\uc5b4 \uad00\ub9ac\uc640 \uc804\uc9c1\uc5d0 \ub300\ud55c \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc744 \uc81c\uacf5\ud558\uc5ec \uc774\uc9c1 \uc900\ube44\uc5d0 \uc720\uc6a9\ud569\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."], [10, "A_\ucd5c\uc7ac\uc6d0", "8fa61928", "\uae08\uc735\uad8c \ucde8\uc5c5 \uac00\uc774\ub4dc - \uae08\uc735 \ub9ac\ub354\ub97c \uafc8\uafb8\ub294 20\ub300\ub97c \uc704\ud55c", ["\uc2e0\uc7ac\ubbfc"], "\ucde8\uc5c5/\uc9c4\ub85c/\uc720\ub9dd\uc9c1\uc5c5", "\ucde8\uc5c5 \uc900\ube44\uc0dd \uc911\uc5d0\uc11c\ub3c4 \ud2b9\ud788 \uae08\uc735\uad8c \ucde8\uc5c5\uc744 \ubaa9\ud45c\ub85c \ud558\ub294 \uc0ac\ub78c\uc744 \uc704\ud55c \ub0b4\uc6a9\uc744 \ub2f4\uace0 \uc788\ub2e4. \uc800\uc790\uac00 \ucde8\uc5c5\uc744 \uc900\ube44\ud55c 2\ub144\uc774 \ub118\ub294 \uae30\uac04\uc5d0 \ucc45\uacfc \uc778\ud130\ub137, \uc8fc\ubcc0 \uc0ac\ub78c\ub4e4\uc744 \ud1b5\ud574 \uc5bb\uc740 \uc815\ubcf4\uc640 \uc2a4\uc2a4\ub85c \ubd80\ub52a\uccd0 \uc54c\uac8c \ub41c \uacbd\ud5d8\uc744 \uc815\ub9ac\ud588\ub2e4. 1\uc7a5\uc5d0\uc11c\ub294 \uae30\ubcf8\uc801\uc73c\ub85c \uae08\uc735\uad8c\uc774\ub780 \uc5b4\ub5a4 \uacf3\uc778\uc9c0, \uc5b4\ub5a4 \uc77c\uc744 \ud558\ub294\uc9c0, \ud544\uc694\ud55c \uc790\uaca9\uc99d\uc740 \ubb34\uc5c7\uc778\uc9c0, \uc5b4\ub5a4 \ub9c8\uc74c\uac00\uc9d0\uc744 \uc694\uad6c\ud558\ub294\uc9c0\ub97c \uc5ee\uc5c8\ub2e4. 2, 3, 4\uc7a5\uc5d0\uc11c\ub294 \ubcf8\uaca9\uc801\uc73c\ub85c \ucde8\uc5c5\uc5d0 \ud544\uc694\ud55c \uc11c\ub958\uc804\ud615, \ud544\uae30\uc804\ud615, \uba74\uc811\uc804\ud615\uc5d0 \ub300\ud55c \uc0c1\uc138\ud55c \ub0b4\uc6a9\uc744 \ub2e4\ub8e8\uc5c8\ub2e4. \ub9c8\uc9c0\ub9c9\uc73c\ub85c 5\uc7a5\uc5d0\uc11c\ub294 \ud604\uc7ac \uae08\uc735\uad8c\uc5d0 \uc885\uc0ac\ud558\ub294 \uc0ac\ub78c\uc73c\ub85c\uc368 \uae08\uc735\uad8c\uc758 \ubbf8\ub798\uc640 \uc2e0\uc785\uc0ac\uc6d0\uc774 \uac00\uc838\uc57c\ud560 \ub9c8\uc74c\uac00\uc9d0\uc5d0 \ub300\ud574 \uc5b8\uae09\ud558\uace0 \uc788\ub2e4.", 0, "\uae08\uc735\uad8c\uc5d0 \ud2b9\ud654\ub41c \ub0b4\uc6a9\uc73c\ub85c, \uc77c\ubc18\uc801\uc778 \uc774\uc9c1 \uc900\ube44\uc640\ub294 \uad00\ub828\uc774 \uc5c6\uc2b5\ub2c8\ub2e4.", "\uc0ac\uc6a9\uc790\ub294 \ud604\uc7ac \uc774\uc9c1\uc744 \uc900\ube44\ud558\uba74\uc11c \ucee4\ub9ac\uc5b4 \ubc29\ud5a5\uc744 \ub2e4\uc2dc \uc7a1\uace0 \uc2f6\uc5b4\ud558\uace0, \ub9c9\ub9c9\ud55c \uae30\ubd84\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub41c \ud1b5\ucc30\uc744 \uc5bb\uace0\uc790 \ucc45\uc744 \ucc3e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc120\ud638\ud558\ub294 \ucc45\uc740 \ud575\uc2ec\uc801\uc778 \ub0b4\uc6a9\uc774 \ub2f4\uae34 \uac00\ubcbc\uc6b4 \uc2a4\ud0c0\uc77c\ub85c, \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\uc5b4\ubcf4\ub294 \uac83\uc744 \uc88b\uc544\ud569\ub2c8\ub2e4. \uc774\uc804\uc5d0 \uc77d\uc740 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uc5d0\uc11c \uc790\uc2e0\uc758 \uacbd\ud5d8\uacfc \uc2e4\ud328\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \ud1b5\ud574 \ud070 \ub3c4\uc6c0\uc774 \ub418\uc5c8\uae30\uc5d0, \ube44\uc2b7\ud55c \ub9e5\ub77d\uc758 \uc2e4\uc0dd\ud65c\uc5d0 \uc801\uc6a9 \uac00\ub2a5\ud55c \ucc45\uc744 \uc120\ud638\ud569\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uc694\uad6c\ub97c \ubc14\ud0d5\uc73c\ub85c, \uc2e4\uc6a9\uc801\uc774\uace0 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucee4\ub9ac\uc5b4 \uad00\ub828 \ub3c4\uc11c\ub97c \ucd94\ucc9c\ud560 \uc218 \uc788\uc744 \uac83\uc785\ub2c8\ub2e4.", "\ud604\uc7ac \uc774\uc9c1 \uc900\ube44\uc640 \uad00\ub828\ud558\uc5ec \uc2e4\uc9c8\uc801\uc774\uace0 \uc720\uc6a9\ud55c \uc870\uc5b8\uc744 \uc81c\uacf5\ud558\ub294, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub41c \ub0b4\uc6a9\uc758 \ucc45\uc744 \uc6d0\ud568. \uc0ac\uc6a9\uc790\ub294 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 '\uc544\ud504\ub2c8\ucf00\uc774\uc158'\uacfc \uc720\uc0ac\ud55c \ud615\uc2dd\uc758 \ucc45\uc744 \uc120\ud638\ud558\uba70, \uc790\uc2e0\uc758 \uacbd\ud5d8\ub2f4\uacfc \uc2e4\uc6a9\uc801\uc778 \ud301\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c \uc11c\uc0ac\ub97c \uae30\ub300\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c. \uac00\ubcbc\uc6b4 \ub9c8\uc74c\uc73c\ub85c \uc811\uadfc\ud560 \uc218 \uc788\ub294 \ucc45\uc744 \uc6d0\ud558\uae30 \ub54c\ubb38\uc5d0, \ubcf5\uc7a1\ud55c \uc774\ub860\ubcf4\ub2e4\ub294 \uac04\ub2e8\uba85\ub8cc\ud55c \uc5b8\uc5b4\ub85c \uc4f0\uc778 \uc2e4\uc6a9\uc11c\uc801\uc744 \ucc3e\uace0 \uc788\uc744 \uac83\uc73c\ub85c \ucd94\ub860\ub428. \ube60\ub974\uac8c \uc5ec\ub7ec \uad8c\uc744 \uc77d\ub294 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub824\ud588\uc744 \ub54c, \uc9e7\uace0 \uac04\uacb0\ud55c \ucc55\ud130 \uad6c\uc131\uc744 \uc9c0\ub2cc \ucc45\uc774 \ud604\uc7ac\uc758 \ub3c5\uc11c \uc694\uad6c\uc5d0 \uc801\ud569\ud560 \uac83\uc784. \uc774\uc9c1 \uc900\ube44 \uacfc\uc815\uc5d0\uc11c\uc758 \ubd88\uc548\uac10\uc744 \ud574\uc18c\ud558\uae30 \uc704\ud574, \uae0d\uc815\uc801\uc774\uace0 \ud76c\ub9dd\uc801\uc778 \uacb0\ub9d0\uc744 \uac00\uc9c4 \uc11c\uc0ac\ub97c \uc120\ud638\ud560 \uac00\ub2a5\uc131\uc774 \ub192\uc74c."]], "log_mode": "IMMUTABLE", "ncols": 11, "nrows": 10}
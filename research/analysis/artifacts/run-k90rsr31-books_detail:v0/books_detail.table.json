{"_type": "table", "column_types": {"params": {"type_map": {"author": {"params": {"allowed_types": [{"wb_type": "none"}, {"params": {"element_type": {"wb_type": "string"}, "length": 1}, "wb_type": "list"}]}, "wb_type": "union"}, "judge_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "judge_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "persona_name": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "rank": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "self_reason": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "self_score": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "session_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thread_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "title": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["persona_name", "session_id", "thread_id", "rank", "title", "author", "judge_score", "judge_reason", "self_score", "self_reason"], "data": [["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 1, "\uc54c\uc3ed\ub2ec\uc3ed \uacbd\uc81c\uae30\uc0ac \uad50\uacfc\uc11c\ub85c \ub2e4\uc2dc \uc77d\uae30 2 - \uae30\uc5c5\u00b7\uae08\uc735\u00b7\uacbd\uc81c\uc0c1\uc2dd\ud3b8", ["\uae40\uc7ac\uc77c", "\uc9c0\ud638\uc9c4"], 0, "\uacbd\uc81c \uc6a9\uc5b4 \uc774\ud574\uc5d0\ub294 \ub3c4\uc6c0\uc774 \ub418\uc9c0\ub9cc, \uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80\uacfc \uacbd\uc81c\uc801 \uae30\ubc18\uc744 \uc7a1\uc73c\ub824\ub294 \uc2e4\uc9c8\uc801 \ubaa9\ud45c(reading_goal)\uc640 \uc9c1\uc811 \uc5f0\uacb0\ub418\uc9c0 \uc54a\uc73c\uba70 \uc7ac\ud14c\ud06c \uc2e4\ud589 \ubc29\ubc95\uc774 \ubd80\uc7ac\ud568.", 0, "\uc5b4\ub9b0\uc774\uc640 \uc5b4\ub978 \ubaa8\ub450\ub97c \ub300\uc0c1\uc73c\ub85c \ud558\uc5ec \uacbd\uc81c \uc6a9\uc5b4\ub97c \uc27d\uac8c \uc124\uba85\ud558\uc9c0\ub9cc, \uc2e4\uc0dd\ud65c\uc5d0 \uc9c1\uc811\uc801\uc73c\ub85c \uc5f0\uacb0\ub418\ub294 \ub0b4\uc6a9\uc774 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 2, "\ubd80\uc790\ub4e4\uc758 \ubd80\ub3d9\uc0b0 \ud22c\uc790\uae30\uc220\uc744 \ud6d4\uccd0\ub77c", ["\uc870\uc7ac\uae38"], 1, "\uc7ac\ud14c\ud06c \uc804 \uacfc\uc815(\ub3c8 \ubaa8\uc73c\uae30\u00b7\ubd88\ub9ac\uae30\u00b7\uad74\ub9ac\uae30)\uc744 \ud48d\ubd80\ud55c \uc0ac\ub840\ub85c \uc124\uba85\ud558\uace0 \ucd08\ubcf4\uc790 \ud544\uc218 \uae08\uc735\uc0c1\ud488\uc744 \ub2e4\ub8e8\uc5b4 \ud604\uc7ac\uc758 \uc7ac\uc815 \uc810\uac80\uacfc \uacbd\uc81c\uc801 \uae30\ubc18 \ub9c8\ub828\uc774\ub77c\ub294 \ubaa9\ud45c\uc5d0 \uc9c1\uc811 \ubd80\ud569\ud568.", 1, "\uc7ac\ud14c\ud06c \ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uae30\ucd08 \uc0c1\uc2dd\uacfc \uc0ac\ub840 \uc911\uc2ec\uc758 \uc811\uadfc\uc774 \uc774\uc9c1 \uc900\ube44\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 3, "\uacbd\uc81c \uc9c0\uc2dd\uc758 \ud798 - \uacbd\uc81c\ub97c \uc54c\uc544\uc57c \uc138\uc0c1\uc774 \ubcf4\uc778\ub2e4", ["\ubc15\uc720\uc5f0"], 1, "\uacbd\uc81c \uae30\ubcf8 \uc6a9\uc5b4\ubd80\ud130 \ucd5c\uc2e0 \uac1c\ub150\uae4c\uc9c0 \uc77c\uc0c1 \uc0ac\ub840\ub85c \uc27d\uac8c \ud480\uc5b4\ub0b4\uba70, \ube44\uc988\ub2c8\uc2a4\ub9e8\uc774 \uad81\uae08\ud574\ud558\ub294 \uacbd\uc81c \ubb38\uc81c\ub97c \ub2e4\ub8e8\uc5b4 \ud575\uc2ec\uc774 \ubd84\uba85\ud558\uace0 \uc2e4\uc0dd\ud65c \uc5f0\uacb0\uc131\uc774 \ub192\uc740 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uacfc \ud604\uc7ac \uc0c1\ud669\uc5d0 \ubd80\ud569\ud568.", 0, "\uacbd\uc81c\uc758 \uae30\ubcf8 \uc9c0\uc2dd\ubd80\ud130 \uc5b4\ub824\uc6b4 \uac1c\ub150\uae4c\uc9c0 \uc124\uba85\ud558\uc9c0\ub9cc, \ub2e4\uc18c \ubcf5\uc7a1\ud560 \uc218 \uc788\uc5b4 \ubd80\ub2f4\uc2a4\ub7ec\uc6b8 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 4, "\uc0bc\uc131\uc0dd\uba85 \uc7ac\ubb34\uc124\uacc4\ucd1d\uc11c \uc138\ud2b8", ["\uc0bc\uc131\uc0dd\uba85 FP\uc13c\ud130"], 0, "8\uad8c \uc138\ud2b8\ub85c \uad6c\uc131\ub418\uc5b4 '\ub108\ubb34 \ub450\uaecd\uac70\ub098 \ud559\uc220\uc801\uc778 \ucc45\uc740 \ubd80\ub2f4'\uc774\ub77c\ub294 \ub09c\uc774\ub3c4 \uc120\ud638\ub3c4\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, CEO\u00b7\uac1c\uc778\uc0ac\uc5c5\uc790 \ub300\uc0c1 \ub0b4\uc6a9\uc774 \ud3ec\ud568\ub418\uc5b4 \ud604\uc7ac \ub9c8\ucf00\ud130 \uc2e0\ubd84\uacfc\uc758 \uc9c1\uc811\uc131\uc774 \ub0ae\uc74c.", 0, "\ub0b4\uc6a9\uc774 \ubc29\ub300\ud558\uace0 \uc5ec\ub7ec \uad8c\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc5b4, \ud604\uc7ac \uc0c1\ud669\uc5d0 \ub9de\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 5, "\ub514\uc9c0\ud138 \uc2dc\ub300\uc758 \uc885\ud6a1\ubb34\uc9c4 \uc7ac\ud14c\ud06c", ["\uc624\uc815\uc120"], 1, "\uc0dd\ud65c \uc18d\uc5d0\uc11c \uc2e4\ucc9c \uac00\ub2a5\ud55c \uc7ac\ud14c\ud06c \uc804\ub7b5\uc744 \ub9de\ucda4\ud615\uc73c\ub85c \uc81c\uc2dc\ud558\uace0 \uc608\uae08\uc5d0\uc11c \ud22c\uc790\uae4c\uc9c0 \uc54c\uae30 \uc27d\uac8c \ud480\uc5b4\ub0b4\uc5b4, \uc2e4\uc0dd\ud65c \uc5f0\uacb0\uc131\uacfc \ud575\uc2ec \uba85\ud655\uc131\uc774\ub77c\ub294 \ub3c5\uc11c \uc2a4\ud0c0\uc77c \uc120\ud638\ub3c4\ub97c \ucda9\uc871\ud568.", 1, "\uc2e4\uc0dd\ud65c\uc5d0\uc11c \uc801\uc6a9\ud560 \uc218 \uc788\ub294 \uc7ac\ud14c\ud06c \uc804\ub7b5\uc744 \ub2e4\ub8e8\uace0 \uc788\uc5b4, \ud604\uc7ac\uc758 \ud544\uc694\uc5d0 \uc798 \ub9de\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 6, "\uc54c\uace0 \ubcf4\uba74 \uc7ac\ubbf8\uc788\ub294 \uacbd\uc81c\uc9c0\uc2dd - \ucd5c\uc2e0 \uacbd\uc81c\uc6a9\uc5b4 173\uac00\uc9c0", ["\uc870\uc131\uc885"], 0, "\uacbd\uc81c \uc6a9\uc5b4 173\uac1c\ub97c \ubb38\ub2f5 \ud615\uc2dd\uc73c\ub85c \uc124\uba85\ud558\ub294 \uc785\ubb38\uc11c\uc774\uc9c0\ub9cc, \uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80\uacfc \uacbd\uc81c\uc801 \uae30\ubc18 \ub9c8\ub828\uc774\ub77c\ub294 \uad6c\uccb4\uc801 \ubaa9\ud45c(reading_goal)\uc640 \uc9c1\uc811 \uc5f0\uacb0\ub418\uc9c0 \uc54a\uc74c.", 0, "\uacbd\uc81c \uc6a9\uc5b4\ub97c \ubb38\ub2f5 \ud615\uc2dd\uc73c\ub85c \uc124\uba85\ud558\uc9c0\ub9cc, \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc774 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 7, "\uc27d\uac8c \ubc30\uc6b0\ub294 \uacbd\uc81c\ud559 \ud50c\ub7ec\uc2a4 - \uae40\uc0c1\ud0dd \uad50\uc218\uc758 \uacbd\uc81c\uc6d0\ub860 \uccab\uac78\uc74c", ["\uae40\uc0c1\ud0dd"], 0, "\uacbd\uc81c\ud559 \uc6d0\ub860 \uac1c\uc815\ud310\uc73c\ub85c \ubbf8\uc2dc\u00b7\uac70\uc2dc\uacbd\uc81c \uc774\ub860\uc744 \ub2e4\ub8e8\ub294 \uad50\uacfc\uc11c\uc801 \uc131\uaca9\uc774 \uac15\ud558\uc5ec, '\ub108\ubb34 \ud559\uc220\uc801\uc778 \ucc45\uc740 \ubd80\ub2f4'\uc774\ub77c\ub294 \ub09c\uc774\ub3c4 \uc120\ud638\ub3c4\uc640 '\uc2e4\uc0dd\ud65c\uc5d0 \uc5f0\uacb0\ub418\ub294 \uae00' \uc120\ud638\uc640 \ub9de\uc9c0 \uc54a\uc74c.", 0, "\uacbd\uc81c\ud559\uc758 \ud575\uc2ec \uac1c\ub150\uc744 \ub2e4\ub8e8\uc9c0\ub9cc, \uc774\uc9c1 \uc900\ube44\uc5d0 \ud544\uc694\ud55c \uc2e4\uc6a9\uc801\uc778 \ub0b4\uc6a9\uc774 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 8, "\uacbd\uc81c\uc758 \uad50\uc591\uc744 \uc77d\ub294\ub2e4 : \uace0\uc804\ud3b8 - \uc758 \uad50\uc591\uc744 \uc77d\ub294\ub2e4 \uc2dc\ub9ac\uc988 ", ["\ud64d\ud6c8", "\uae40\uc9c4\ubc29", "\ubc15\ub9cc\uc12d", "\ub958\ub3d9\ubbfc", "\ubc15\uc885\ud604"], 0, "", 0, ""], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 9, "\ub73b\uc73c\ub85c \uc77d\ub294 \ud55c\uad6d\uacbd\uc81c\uc0ac", ["\uc870\uc900\ud604"], 0, "\ud55c\uad6d\uacbd\uc81c\uc0ac\uc758 \ud750\ub984\uc744 \uc5ed\uc0ac\uc801\uc73c\ub85c \uc124\uba85\ud558\ub294 \ucc45\uc73c\ub85c, \uc774\uc9c1 \uc900\ube44 \uc911 \uac1c\uc778\uc758 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80\uacfc \uacbd\uc81c\uc801 \uae30\ubc18\uc744 \uc7a1\uc73c\ub824\ub294 \uc2e4\uc9c8\uc801 \ubaa9\ud45c(reading_goal)\uc640 \uc9c1\uc811 \uc5f0\uacb0\ub418\uc9c0 \uc54a\uc74c.", 0, "\uc5ed\uc0ac\uc801\uc778 \ub0b4\uc6a9\uc744 \ub2e4\ub8e8\uace0 \uc788\uc5b4, \ud604\uc7ac\uc758 \uc7ac\uc815\uc801 \uae30\ubc18\uc744 \ub2e4\uc9c0\ub294 \ub370\ub294 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, "sim_A_\ucd5c\uc7ac\uc6d0_s1_1781815549", 10, "\uc0dd\uc560 \uccab \uc7ac\ud14c\ud06c \uc218\uc5c5 - \ub3c8 \ub54c\ubb38\uc5d0 \ubd88\uc548\ud55c \ub2f9\uc2e0\uc744 \uc704\ud55c", ["\ubc29\uc9c0\uc5f0"], 1, "\uc7ac\uc815\uc801 \ub2a5\ub825 \uc810\uac80\uacfc \ud604\uc2e4\uc801 \ubaa9\ud45c \uc138\uc6b0\uae30, \uc218\uc785\u00b7\uc9c0\ucd9c\u00b7\uc790\uc0b0\u00b7\ubd80\ucc44 \ubd84\uc11d \ub4f1\uc744 \uc0ac\ub840\uc640 \ud568\uaed8 \ub2e4\ub8e8\uc5b4 \ud604\uc7ac\uc758 \uc7ac\uc815 \uc0c1\ud669 \uc810\uac80\uacfc \uacbd\uc81c\uc801 \uae30\ubc18 \ub9c8\ub828\uc774\ub77c\ub294 \ubaa9\ud45c\uc5d0 \uc815\ud655\ud788 \ubd80\ud569\ud558\uba70, \uc9c0\uce58\uace0 \ub9c9\ub9c9\ud55c \uc0c1\ud0dc\uc758 \ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uce5c\uc808\ud55c \uc548\ub0b4\uc11c\uc784.", 1, "\uc7ac\uc815\uc801 \ub2a5\ub825\uc744 \uc810\uac80\ud558\uace0 \ubaa9\ud45c\ub97c \uc138\uc6b0\ub294 \uacfc\uc815\uc774 \uc774\uc9c1 \uc900\ube44\uc5d0 \ud070 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 1, "\ub9c8\uc74c\uc774 \ud5a5\ud55c \uadf8\uacf3\uc5d0\uc11c \ub2e4\uc2dc \ud0dc\uc5b4\ub098\ub2e4", ["\uc724\uacbd\uc219"], 1, "\uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c\uc744 \uc704\ub85c\ud558\ub294 \uc5d0\uc138\uc774(reading_goal \u2713), \uc778\ubb38\uc801 \uc0ac\uc0c9\uc744 \ub2f4\uc740 \ub9c8\uc74c \uce58\uc720 \uc5d0\uc138\uc774(preferred_genre \u2713), \uc5d0\ud53c\uc18c\ub4dc \uc911\uc2ec\uc758 \uac00\ubccd\uace0 \uae4a\uc774 \uc788\ub294 \uad6c\uc131(reading_style \u2713, difficulty_level \u2713), \ud1f4\uadfc \ud6c4 \ud63c\uc790 \uc0ac\uc0c9\ud558\uae30\uc5d0 \uc801\ud569(current_context \u2713)", 1, "\uc77c\uc0c1\uc5d0\uc11c\uc758 \ub9c8\uc74c \uce58\uc720\ub97c \ub2e4\ub8ec \uc5d0\uc138\uc774\ub85c, \uc9c0\uce5c \ub9c8\uc74c\uc5d0 \uc704\ub85c\ub97c \uc904 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 2, "\ubcc4\ub09c \uac00\ub974\uce68 4 - \uac00\ub984\uce68\uc740 \uc0ac\ub791\uc774\ub2e4", ["\uae40\ucd98\ud604"], 0, "\ud559\uad50 \uc544\uc774\ub4e4\uacfc \ubd80\ubaa8\ub97c \uc8fc \ub300\uc0c1\uc73c\ub85c \ud558\ub294 \ub0b4\uc6a9\uc73c\ub85c 32\uc138 \uc2a4\ud0c0\ud2b8\uc5c5 \ub9c8\ucf00\ud130\uc758 \ud604\uc7ac \uc0c1\ud669\uacfc \ub9de\uc9c0 \uc54a\uc74c(current_context \u2717), \uacf5\ubd80 \uc9c0\uce5c \uc544\uc774\ub4e4 \uc704\ub85c\uac00 \uc911\uc2ec\uc774\ub77c \uc0ac\uc6a9\uc790\uc758 \ub3c5\uc11c \ubaa9\uc801\uacfc \uac70\ub9ac \uc788\uc74c(reading_goal \u2717)", 0, "\uc8fc\ub85c \uc544\uc774\ub4e4\uacfc \ubd80\ubaa8\ub2d8\uc744 \uc704\ud55c \uc774\uc57c\uae30\ub85c, \uc0ac\uc6a9\uc790\uc758 \ud604\uc7ac \uac10\uc815\uc801 \ubd80\ub2f4\uc744 \ub35c\uc5b4\uc8fc\ub294 \ub370\ub294 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 3, "\ub0b4\uac00 \ub418\uace0 \uc2f6\uc740 \uc0ac\ub78c", ["\uae40\uc838\ub2c8"], 1, "\uc5b4\ub978\uc758 \uc790\uae30 \uc131\ucc30\uc744 \ub2e4\ub8e8\ub294 \uc5d0\uc138\uc774\ub85c \uacbd\uc81c \uacf5\ubd80 \ud53c\ub85c\uc5d0\uc11c \ubc97\uc5b4\ub098 \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\uac8c \ud568(reading_goal \u2713), \uc778\ubb38\uc801 \uc5d0\uc138\uc774(preferred_genre \u2713), \ub2f4\ubc31\ud55c \uad6c\uc131\uc73c\ub85c \uae4a\uc774 \uc788\ub294 \uc0ac\uc0c9 \uac00\ub2a5(reading_style \u2713, difficulty_level \u2713), \ud63c\uc790\ub9cc\uc758 \uc2dc\uac04\uc5d0 \uc790\uc2e0\uc744 \uc54c\uc544\uac00\ub294 \ub0b4\uc6a9\uc774 \ud604\uc7ac \uc0c1\ud669\uacfc \ubd80\ud569(current_context \u2713)", 1, "\uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\ub294 \ub0b4\uc6a9\uc744 \ub2f4\uace0 \uc788\uc5b4, \uae4a\uc774 \uc788\ub294 \uc0ac\uc0c9\uc744 \ud560 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 4, "\uc0ac\ub791\ud558\ub77c \ub2e4\uc2dc \ud55c\ubc88 \ub354", ["\uae40\uc9c0\uc5f0"], 1, "\ub9c8\uc74c\uc774 \uc9c0\uce5c \uc0c1\ud0dc\uc5d0\uc11c \uc704\ub85c\uc640 \ud76c\ub9dd\uc744 \uc8fc\ub294 \uc5d0\uc138\uc774(reading_goal \u2713), \uc778\ubb38\uc801 \uc131\ucc30\uacfc \uac10\uc815 \uce58\uc720\ub97c \ub2f4\uc740 \uc5d0\uc138\uc774(preferred_genre \u2713), \uc794\uc794\ud55c \ud544\uce58\uc758 \uac00\ubccd\uace0 \uae4a\uc774 \uc788\ub294 \uad6c\uc131(reading_style \u2713, difficulty_level \u2713), \ud63c\uc790 \uc131\ucc30\ud558\uba70 \uc704\ub85c\ubc1b\uae30\uc5d0 \uc801\ud569(current_context \u2713)", 1, "\ud76c\ub9dd\uc801\uc778 \uba54\uc2dc\uc9c0\ub97c \ub2f4\uace0 \uc788\uc5b4, \ud798\ub4e0 \uc2dc\uac04\uc744 \uacaa\uace0 \uc788\ub294 \uc0ac\uc6a9\uc790\uc5d0\uac8c \uc704\ub85c\uac00 \ub420 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 5, "\uc4f0\ub514\uc4f4 \uc624\ub298\uc5d0, \ud718\ud551\ud06c\ub9bc - \ud1a0\ub2e5\ud1a0\ub2e5 \uc704\ub85c\ud574\uc8fc\uc5b4 \ub9c8\uc74c\uc774 \ubabd\uae00\ubabd\uae00\ud574\uc9c0\ub294 \ucc45", ["\uae40\ud1a0\ub07c"], 0, "", 0, ""], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 6, "Calm \uc774\ud1a0\ub85d \uace0\uc694\ud55c \uc2dc\uac04", [], 0, "\uc774\ubbf8\uc9c0\uc640 \uc190\uae00\uc528 \uc911\uc2ec\uc758 \uba85\uc0c1\uc11c\ub85c \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uae4a\uc774 \uc788\ub294 \uae00 \uc77d\uae30\ub97c \uc120\ud638\ud558\ub294 \uc0ac\uc6a9\uc790\uc640 \ub9de\uc9c0 \uc54a\uc74c(reading_style \u2717, difficulty_level \u2717), \uc778\ubb38\u00b7\ucca0\ud559 \uc5d0\uc138\uc774 \uc7a5\ub974\uc640\ub3c4 \uac70\ub9ac \uc788\uc74c(preferred_genre \u2717)", 1, "\ub9c8\uc74c\uc744 \uc548\uc815\uc2dc\ud0a4\uace0 \uce58\uc720\ubc1b\uace0 \uc2f6\uc744 \ub54c \uc77d\uae30 \uc88b\uc740 \ucc45\uc73c\ub85c, \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 7, "\ucca0\ud5599\ub2e8\uc758 \ud790\ub9c1\ub178\ud2b8 - \uc0b6\uc758 \uc5f4\uc815\uacfc \uc9c0\ud61c\uc640 \ud589\ubcf5\uc744 \uc8fc\ub294", ["\uc774\ucc3d\ud638"], 0, "", 1, "\uae4a\uc774 \uc788\ub294 \uc0ac\uc720\uc640 \ud1b5\ucc30\uc744 \uc81c\uacf5\ud560 \uc218 \uc788\uc5b4, \uc0ac\uc6a9\uc790\uc758 \ub3c5\uc11c \uc2a4\ud0c0\uc77c\uc5d0 \uc798 \ub9de\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 8, "\uc624\ud6c4 \ub2e4\uc12f \uc2dc \ubc18", ["\uc870\uc131\uc6d0"], 1, "\ud734\uba38\ub2c8\uc998\uc801 \uc11c\uc815\uacfc \ud615\uc774\uc0c1\ud559\uc801 \uc0ac\uc0c9\uc744 \ub2f4\uc740 \uc5d0\uc138\uc774(preferred_genre \u2713, reading_style \u2713), \ub9c8\uc74c\uc744 \uce58\uc720\ud558\uace0 \uc5ec\uc720\ub86d\uac8c \ud558\ub294 \ub0b4\uc6a9(reading_goal \u2713), \uc12c\uc138\ud55c \uac10\uc131\uacfc \uc815\uc2e0\uc801 \ud48d\uc694\ub85c\uc6c0\uc73c\ub85c \uac00\ubccd\uac8c \uc77d\uc744 \uc218 \uc788\uc74c(difficulty_level \u2713), \ud1f4\uadfc \ud6c4 \ud63c\uc790 \uc790\uc5f0\uacfc \uc778\uc0dd\uc744 \uc131\ucc30\ud558\uae30\uc5d0 \uc801\ud569(current_context \u2713)", 1, "\uc790\uc5f0\uacfc \uc778\uc0dd\uc758 \uc758\ubbf8\ub97c \ub418\uc9da\uc5b4\ubcf4\ub294 \ub0b4\uc6a9\uc73c\ub85c, \uc0ac\uc0c9\ud558\uae30 \uc88b\uc740 \uc5d0\uc138\uc774\uc77c \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 9, "\uc9c4\uc9dc \uc5b4\ub978\uc774 \ub41c\ub2e4\ub294 \uac83\uc740", ["\ucd5c\uc900\ubc30"], 1, "\uae4a\uc774 \uc788\ub294 \uc131\ucc30\uacfc \uc601\uc131\uc744 \ub2f4\uc740 \uc778\ubb38 \uc5d0\uc138\uc774(preferred_genre \u2713, reading_style \u2713), \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\uba70 \uc9c0\ud61c\ub97c \uc5bb\ub294 \ub0b4\uc6a9\uc73c\ub85c \uacbd\uc81c \uacf5\ubd80 \ud53c\ub85c \ud574\uc18c(reading_goal \u2713), \ub530\ub73b\ud55c \uac10\uc131\uc758 \uc5d0\uc138\uc774 \uc218\uc900 \ub09c\uc774\ub3c4(difficulty_level \u2713), \ud63c\uc790 \ucc45 \uc77d\uace0 \uc0b0\ucc45\ud558\uba70 \uc131\ucc30\ud558\ub294 \ud604\uc7ac \uc0c1\ud669\uacfc \ubd80\ud569(current_context \u2713)", 1, "\uc0b6\uc758 \uc9c0\ud61c\ub97c \ubc30\uc6b0\uace0 \uc131\ucc30\ud560 \uc218 \uc788\ub294 \ub0b4\uc6a9\uc73c\ub85c, \uc0ac\uc6a9\uc790\uc758 \ud604\uc7ac \uc0c1\ud669\uc5d0 \uc801\ud569\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, "sim_A_\ucd5c\uc7ac\uc6d0_s2_1781815606", 10, "\ub4e4\uaf43 \uac19\uc740 \uac15\ubb3c\uc774", ["\uc815\ud558\uc131"], 1, "\uc790\uc5f0 \uc18d\uc5d0\uc11c \uc0b6\uc744 \ubc18\ucd94\ud558\ub294 \uae4a\uc774 \uc788\ub294 \uc778\ubb38 \uc5d0\uc138\uc774(preferred_genre \u2713, reading_style \u2713), \ubc14\uc05c \uc77c\uc0c1\uc5d0\uc11c \ubc97\uc5b4\ub098 \uc5ec\uc720\ub97c \ucc3e\uac8c \ud568(reading_goal \u2713), \uc18c\ubc15\ud55c \uac10\uc131\uc758 \uac00\ubcbc\uc6b4 \uad6c\uc131(difficulty_level \u2713), \ud1f4\uadfc \ud6c4 \ud63c\uc790 \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\uae30\uc5d0 \uc801\ud569(current_context \u2713)", 1, "\uc18c\uc18c\ud55c \uae30\uc068\uacfc \uc5ec\uc720\ub97c \ucc3e\ub294 \ub0b4\uc6a9\uc744 \ub2f4\uace0 \uc788\uc5b4, \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 1, "\ucee4\ubba4\ub2c8\ucf00\uc774\uc158 \ud2b9\uac15 - \ub300\ud55c\ubbfc\uad6d \ud575\uc2ec\uc778\uc7ac\ub97c \uc704\ud55c", ["\uae40\uc601\ubbfc"], 1, "\uc9c1\uc7a5 \uc18c\ud1b5 \uac1c\uc120\uc774\ub77c\ub294 \uba85\ud655\ud55c \ubaa9\ud45c, \uc2ec\ub9ac\ud559 \uae30\ubc18 \ubd84\uc11d, \uc0ac\ub840 \uc911\uc2ec \uad6c\uc131, \uc77c\ubc18 \uad50\uc591\uc11c \uc218\uc900\uc73c\ub85c \ubaa8\ub450 \ubd80\ud569\ud558\uba70 \ud604\uc7ac \uc9c1\uc7a5 \uad00\uacc4 \uace0\ubbfc\uacfc \uc815\ud655\ud788 \ub9de\uc74c.", 1, "\uc0ac\ub840 \uc911\uc2ec\uc73c\ub85c \uc18c\ud1b5\uc758 \ub2e8\uc808\uacfc \uac08\ub4f1\uc744 \ub2e4\ub8e8\uace0 \uc788\uc5b4 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \uc774\ud574\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 2, "\ub098\ub97c \ubcc0\ud654\uc2dc\ud0a4\ub294 \ud798, \uc778\ub9e5 - \ubaa8\ub4e0 \ubb38\uc81c\ub294 \uc778\uac04\uad00\uacc4\uc5d0 \uc788\ub2e4", ["\uc774\ud615\uc12d"], 0, "\uc778\uac04\uad00\uacc4 \ud615\uc131\uc5d0 \ucd08\uc810\uc744 \ub9de\ucd94\uace0 \uc788\uc5b4 \uc9c1\uc7a5 \uc18c\ud1b5 \uc2ec\ub9ac\ud559\uc774\ub77c\ub294 \uad6c\uccb4\uc801 \ubaa9\ud45c\uc640 \uac70\ub9ac\uac00 \uc788\uc73c\uba70, \ub9c8\uc74c\uac00\uc9d0 \ubcc0\ud654 \uc911\uc2ec\uc73c\ub85c \uc2ec\ub9ac\ud559\uc801 \ubd84\uc11d\uc774 \uc57d\ud568.", 1, "\uc131\uacf5\ud55c \uc0ac\ub78c\ub4e4\uc758 \uc0ac\ub840\ub97c \ud1b5\ud574 \uc778\uac04\uad00\uacc4 \ud615\uc131\uc5d0 \ud544\uc694\ud55c \ub178\ub825\uc744 \uc54c\ub824\uc8fc\uc5b4 \ud765\ubbf8\ub85c\uc6b8 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 3, "\uc0c1\ub300\uc801\uc774\uba70 \uc808\ub300\uc801\uc778 \uc778\uac04\uad00\uacc4 \uc9c0\uc2dd\ud2b9\uac15 - \ub0a8\ud3b8\uc774 \ubabb\ub9c8\ub545\ud55c \uc544\ub0b4\uc640 \ubc18\ud56d\ud558\ub294 \ub0a8\ud3b8\uc758 \uc2ec\ub9ac\ud559 = \u307e\u305f\u307e\u305f\u30ef\u30eb\u306e\u77e5\u60e0\u672c", ["\uce74\ub3c4 \uc544\ud0a4\uc624"], 0, "", 0, ""], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 4, "\uba38\ud53c\uc758 \ubc95\uce59 55\uac00\uc9c0 - \uc131\uacf5\uc801\uc778 \uc778\uac04\uad00\uacc4\ub97c \uc704\ud55c", ["\uba38\ud53c\uc774\ub860\uc5f0\uad6c\ud68c"], 0, "\uc778\uac04\uad00\uacc4 \uc77c\ubc18\uc5d0 \ub300\ud55c \uad11\ubc94\uc704\ud55c \ub0b4\uc6a9\uc73c\ub85c \uc9c1\uc7a5 \uc18c\ud1b5 \uc2ec\ub9ac\ud559\uc774\ub77c\ub294 \uad6c\uccb4\uc801 \ubaa9\ud45c\uc640 \ub9de\uc9c0 \uc54a\uc73c\uba70, \uc18c\uac1c\uae00\uc5d0 \uc2ec\ub9ac\ud559\uc801 \uadfc\uac70\ub098 \ubd84\uc11d\uc774 \uba85\uc2dc\ub418\uc9c0 \uc54a\uc74c.", 0, "\uc778\uac04\uad00\uacc4\uc758 \uc5b4\ub824\uc6c0\uc744 \ub2e4\ub8e8\uc9c0\ub9cc \uc0ac\ub840\uac00 \ubd80\uc871\ud574 \uc2e4\uc9c8\uc801\uc778 \ub3c4\uc6c0\uc774 \uc801\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 5, "\uc2ec\ub9ac\ud559 \uce75\ud14c\uc77c", ["\ub098\uc774\ud1a0 \uc694\uc2dc\ud788\ud1a0"], 1, "\uc2ec\ub9ac\ud559\uc790\ub4e4\uc758 \uc2e4\ud5d8 \uae30\ubc18 \uc778\uac04 \uc2ec\ub9ac \ubd84\uc11d, \uc9c1\uc7a5 \uad00\uacc4(\ub3d9\ub8cc\u00b7\uc0c1\uc0ac) \uc774\ud574\uc5d0 \uc9c1\uc811 \uad00\ub828, \uc0ac\ub840 \uc911\uc2ec \uad6c\uc131\uc73c\ub85c \ubaa8\ub4e0 \uc870\uac74 \ucda9\uc871.", 0, "\uc2ec\ub9ac\ud559\uc801 \ubd84\uc11d\uc774 \uae4a\uc5b4 \ubd80\ub2f4\uc2a4\ub7ec\uc6b8 \uc218 \uc788\uc5b4 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \uc774\ud574\uc5d0 \uc801\ud569\ud558\uc9c0 \uc54a\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 6, "\uc774\uc81c\ub294 \uac10\uc131\ucf54\uce6d", ["\uc774\ud0dc\ud638"], 0, "\ucf54\uce6d \uc0c1\ub2f4 \uae30\ubc18\uc73c\ub85c \uad00\uacc4\u00b7\uc815\uc11c \ubb38\uc81c \ud574\uacb0\uc5d0 \ucd08\uc810\uc744 \ub9de\ucd94\uace0 \uc788\uc5b4, \uc9c1\uc7a5 \uc18c\ud1b5\uc744 \uc2ec\ub9ac\ud559\uc73c\ub85c \uc774\ud574\ud558\ub824\ub294 \uad6c\uccb4\uc801 \ubaa9\ud45c\uc640 \uac70\ub9ac\uac00 \uc788\uc74c.", 0, "\ucf54\uce6d \uc0c1\ub2f4\uc744 \ubc14\ud0d5\uc73c\ub85c \ud558\uc9c0\ub9cc \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5\uc5d0 \ub300\ud55c \uad6c\uccb4\uc801\uc778 \uc0ac\ub840\uac00 \ubd80\uc871\ud560 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 7, "\ub098\ub294 \ub108\uc640 \ud1b5\ud558\uace0 \uc2f6\ub2e4 - \uc0c1\ub300\ub97c \ub2e8\ubc88\uc5d0 \uc0ac\ub85c\uc7a1\ub294 \uc18c\ud1b5\uc758 \uae30\uc220", ["\uc6b0\uc601\ubbf8"], 1, "\uc9c1\uc7a5\uacfc \uc77c\uc0c1\uc758 \uc18c\ud1b5 \uac08\ub4f1 \ud574\uacb0, \ub2e4\uc591\ud55c \uc0ac\ub840 \uc911\uc2ec, \uc774\ubbf8\uc9c0 \ucee8\uc124\ud134\ud2b8\uc758 \uc0dd\uc0dd\ud55c \uae30\ub85d\uc73c\ub85c \uc77d\uae30 \uc26c\uc6b4 \uad6c\uc131\uc774 \ubaa8\ub450 \ubd80\ud569\ud568.", 1, "\uc9c1\uc7a5 \ub0b4 \uac08\ub4f1\uacfc \uc18c\ud1b5 \ube44\uacb0\uc744 \ub2e4\ub8e8\uc5b4 \ud765\ubbf8\ub86d\uac8c \uc77d\uc744 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 8, "\uac00\uc7a5 \ub4e3\uace0 \uc2f6\uc740 \ud55c \ub9c8\ub514 yes!", ["\uae40\ud0dc\uc6d0"], 1, "\ub1cc\uacfc\ud559\u00b7\uc2ec\ub9ac\ud559 \uae30\ubc18 \uc9c1\uc7a5 \ucee4\ubba4\ub2c8\ucf00\uc774\uc158, \uc800\uc790\uc758 \uc9c1\uc811 \uacbd\ud5d8\uacfc \uad6c\uccb4\uc801 \uc0ac\ub840(\ud611\uc0c1\u00b7\ud68c\uc758\u00b7\uc0c1\uc0ac \uad00\uacc4), \uc2e4\ubb34 \uc801\uc6a9 \uc911\uc2ec\uc73c\ub85c \ubaa9\ud45c\uc640 \uc644\ubcbd\ud788 \ubd80\ud569.", 1, "\ube44\uc988\ub2c8\uc2a4 \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc758 \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \uc18c\ud1b5\uc758 \ubb38\uc81c\ub97c \ud574\uacb0\ud560 \uc218 \uc788\uc744 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 9, "\ub370\uc77c \uce74\ub124\uae30 \uc778\uac04\uad00\uacc4\ub860", ["\ub370\uc77c \uce74\ub124\uae30"], 0, "80\ub144 \uc804 \uc800\uc791\uc73c\ub85c \ud604\ub300 \uc9c1\uc7a5 \uc0c1\ud669 \ubc18\uc601 \ubd80\uc871, '\ub2e4\ub4e4 \uc77d\ub294 \ubed4\ud55c \ubca0\uc2a4\ud2b8\uc140\ub7ec' \uae30\uc900\uc5d0 \uc815\ud655\ud788 \ud574\ub2f9\ud558\uba70 \uc0ac\uc6a9\uc790\uc758 \uba85\uc2dc\uc801 \uac70\ubd80 \ub300\uc0c1.", 1, "\uc774\ud574\ud558\uae30 \uc26c\uc6b4 \uc0ac\ub840 \uc911\uc2ec\uc758 \ub0b4\uc6a9\uc73c\ub85c \uc9c1\uc7a5 \ub0b4 \uc778\uac04\uad00\uacc4\uc5d0 \ub3c4\uc6c0\uc774 \ub420 \uac83 \uac19\uc544\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, "sim_A_\ucd5c\uc7ac\uc6d0_s3_1781815670", 10, "\uc644\ubcbd\ud55c \uc18c\ud1b5\ubc95 - \uc77c, \uad00\uacc4, \uac08\ub4f1\uc774 \uc220\uc220 \ud480\ub9ac\ub294 \ucee4\ubba4\ub2c8\ucf00\uc774\uc158\uc758 \ubc95\uce59", ["\uc720\uacbd\ucca0"], 1, "\uc9c1\uc7a5 \uc18c\ud1b5\uc758 10\uac00\uc9c0 \ubc95\uce59, \uc0c1\uc0ac\u00b7\ub3d9\ub8cc \uac08\ub4f1 \uc911\uc2ec, \uc2ec\ub9ac\ud559 \uae30\ubc18 \ubd84\uc11d, \ud604\uc7a5 \uc0ac\ub840 \ud48d\ubd80\ub85c \uc9c1\uc7a5 \uad00\uacc4 \uc774\ud574\ub77c\ub294 \ubaa9\ud45c\uc5d0 \uc815\ud655\ud788 \ubd80\ud569.", 1, "\uc0ac\ub840\uc640 \uc194\ub8e8\uc158\uc744 \ud1b5\ud574 \uc18c\ud1b5\uc758 \ubc95\uce59\uc744 \ubc30\uc6b8 \uc218 \uc788\uc5b4 \uc9c1\uc7a5 \ub0b4 \uc18c\ud1b5 \uc774\ud574\uc5d0 \uc801\ud569\ud560 \uac83 \uac19\uc544\uc694."]], "log_mode": "IMMUTABLE", "ncols": 10, "nrows": 30}
{"_type": "table", "column_types": {"params": {"type_map": {"crs": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "persona_name": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "session_id": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "thought": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}, "turn": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "number"}]}, "wb_type": "union"}, "user": {"params": {"allowed_types": [{"wb_type": "none"}, {"wb_type": "string"}]}, "wb_type": "union"}}}, "wb_type": "typedDict"}, "columns": ["persona_name", "session_id", "turn", "crs", "thought", "user"], "data": [["A_\ucd5c\uc7ac\uc6d0", 1, 1, "\ucc45\uc744 \uc77d\uace0 \uc2f6\uc73c\uc2e0 \uc774\uc720\uac00 \uc788\uc73c\uc2e0\uac00\uc694? \uc608\ub97c \ub4e4\uc5b4, \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uac70\ub098, \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uace0 \uc2f6\uac70\ub098, \ud2b9\uc815\ud55c \uc8fc\uc81c\uc5d0 \ub300\ud574 \uae4a\uc774 \uc54c\uc544\ubcf4\uace0 \uc2f6\uc73c\uc2e0 \uac74\uac00\uc694?", "\ub098\ub294 \uc774\uc9c1 \uc900\ube44 \uc911\uc774\uace0 \uc7ac\uc815 \uc0c1\ud669\uc744 \uc810\uac80\ud558\uace0 \uc2f6\uc5b4\uc11c \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\ub2e4", "\uc74c... \uc9c0\uae08 \uc774\uc9c1 \uc900\ube44 \uc911\uc774\ub77c\uc11c \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uace0 \uc2f6\uc5b4\uc11c\uc694. \uadf8\ub798\uc11c \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, 2, "\uc774\uc9c1 \uc900\ube44\uc640 \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uae30 \uc704\ud574 \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uc73c\uc2dc\uad70\uc694. \ud639\uc2dc \uc774\ub7f0 \ubaa9\ud45c\uc640 \uad00\ub828\ud574\uc11c \ud2b9\ubcc4\ud788 \uad00\uc2ec \uc788\ub294 \uc8fc\uc81c\ub098 \uc7a5\ub974\uac00 \uc788\uc73c\uc2e0\uac00\uc694? \uc608\ub97c \ub4e4\uc5b4, \uacbd\uc81c, \ud22c\uc790, \uc790\uc0b0 \uad00\ub9ac \uac19\uc740 \ubd84\uc57c\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uc73c\uc2e0\uc9c0 \uad81\uae08\ud569\ub2c8\ub2e4.", "\ub098\ub294 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uace0 \uc774\uc9c1 \uc900\ube44 \uc911\uc774\ub77c\uc11c \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \ucc45\uc744 \ucc3e\uace0 \uc2f6\ub2e4", "\ub124, \uacbd\uc81c\ub098 \uc7ac\ud14c\ud06c \uac19\uc740 \ubd84\uc57c\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uc544\uc694. \uadf8\ub7f0 \uc8fc\uc81c\ub85c \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \ucc45\uc744 \ucc3e\uace0 \uc2f6\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, 3, "\uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uae30 \uc704\ud55c \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \ucc3e\uace0 \uacc4\uc2e0\ub370, \uadf8\ub7f0 \uc8fc\uc81c\uc758 \ucc45\uc744 \uc77d\uc744 \ub54c \uc5b4\ub290 \uc815\ub3c4\uc758 \ub09c\uc774\ub3c4\ub97c \uc120\ud638\ud558\uc2dc\ub098\uc694? \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc774 \uc88b\uc73c\uc2e0\uac00\uc694, \uc544\ub2c8\uba74 \uc870\uae08 \ub354 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ub2e4\ub8e8\ub294 \ucc45\ub3c4 \uad1c\ucc2e\uc73c\uc2e0\uac00\uc694?", "\ub098\ub294 \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud558\uace0 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc\uc11c \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \ucc45\uc774 \ud544\uc694\ud558\ub2e4", "\uadf8\ub0e5 \ub108\ubb34 \ub450\uaecd\uac70\ub098 \ud559\uc220\uc801\uc778 \ucc45\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc\uc694. \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ucc45\uc774 \uc88b\uaca0\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 1, 4, "\uc548\ub155\ud558\uc138\uc694! \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uace0 \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uc73c\uc2dc\uad70\uc694. \ud639\uc2dc \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 \uacbd\uc81c\ub098 \uc7ac\ud14c\ud06c \uad00\ub828 \ucc45\uc774 \uc788\uc73c\uc2e0\uac00\uc694? \ucc45 \uc81c\ubaa9\uacfc \uac04\ub2e8\ud55c \uc18c\uac10\ub3c4 \ud568\uaed8 \ub9d0\uc500\ud574\uc8fc\uc2dc\uba74 \uc88b\uaca0\uc2b5\ub2c8\ub2e4!", "\ub098\ub294 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c\uc5d0 \uad00\uc2ec\uc774 \uc788\uc9c0\ub9cc, \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 \ucc45\uc774 \ubcc4\ub85c \uc5c6\uc5b4\uc11c \ucd94\ucc9c\uc744 \ubc1b\uace0 \uc2f6\ub2e4", "\uc74c... \uc0ac\uc2e4 \uc774\uc804\uc5d0 \uc77d\uc5c8\ub358 \ucc45\uc740 \ubcc4\ub85c \uc5c6\uc5b4\uc694. \uadf8\ub798\uc11c \ucd94\ucc9c\ubc1b\uace0 \uc2f6\uc740 \ub9c8\uc74c\uc774 \ucee4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, 1, "\ucc45\uc744 \uc77d\uace0 \uc2f6\uc73c\uc2e0 \uc774\uc720\uac00 \uc788\uc73c\uc2e0\uac00\uc694? \uc608\ub97c \ub4e4\uc5b4, \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uac70\ub098 \ud790\ub9c1\uc744 \uc6d0\ud558\uc2dc\ub294\uc9c0 \uad81\uae08\ud574\uc694. \uc5b4\ub5a4 \ubaa9\ud45c\uac00 \uc788\uc73c\uc2e0\uc9c0 \uc774\uc57c\uae30\ud574\uc8fc\uc2dc\uba74 \uc88b\uaca0\uc5b4\uc694!", "\ub098\ub294 \uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uce5c \ub9c8\uc74c\uc744 \ub2ec\ub798\uc904 \ucc45\uc744 \ucc3e\uace0 \uc2f6\uc5b4\uc11c \ud790\ub9c1\uc774 \ud544\uc694\ud558\ub2e4", "\uc74c... \uc694\uc998 \uacbd\uc81c \uacf5\ubd80\ub85c \uc880 \uc9c0\uccd0\uc11c, \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ucc45\uc744 \uc77d\uace0 \uc2f6\uc5b4\uc694. \uadf8\ub798\uc11c \ud790\ub9c1\uc774 \ub418\ub294 \uadf8\ub7f0 \ucc45\uc774 \uc88b\uaca0\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, 2, "\uc548\ub155\ud558\uc138\uc694! \uc774\uc804\uc5d0 \uc774\uc9c1 \uc900\ube44 \uc911\uc774\uba70 \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uae30 \uc704\ud574 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c \ubd84\uc57c\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uc740 \uac83\uc73c\ub85c \uae30\uc5b5\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uc811\uadfc\ud558\uae30 \uc26c\uc6b4 \ucc45\uc744 \ucc3e\uace0 \uacc4\uc168\uc8e0. \uc774\ubc88\uc5d0\ub3c4 \ube44\uc2b7\ud55c \uc885\ub958\uc758 \ub3c4\uc11c\ub97c \ucc3e\uace0 \uacc4\uc2e0\uac00\uc694? yes/no\ub85c \ub2f5\ud574\uc8fc\uc2dc\uba74 \uc88b\uaca0\uc2b5\ub2c8\ub2e4.", "\ub098\ub294 \uacbd\uc81c \uacf5\ubd80\ub85c \uc9c0\uccd0\uc11c \ub9c8\uc74c\uc744 \ub2ec\ub798\uc904 \ucc45\uc744 \ucc3e\uace0 \uc788\uc5b4\uc11c, \uc774\uc804\uacfc\ub294 \uc870\uae08 \ub2e4\ub978 \ubc29\ud5a5\uc758 \ucc45\uc774 \ud544\uc694\ud558\ub2e4", "\uc544\ub2c8\uc694, \uc774\ubc88\uc5d0\ub294 \uc880 \ub2e4\ub978 \ubc29\ud5a5\uc758 \ucc45\uc744 \ucc3e\uace0 \uc788\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, 3, "\uadf8\ub807\uad70\uc694! \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \ucc45\uc744 \uc6d0\ud558\uc2e0\ub2e4\uba74, \ub3c5\uc11c\ub97c \ud560 \ub54c \uc5b4\ub5a4 \uc2a4\ud0c0\uc77c\uc744 \uc120\ud638\ud558\uc2dc\ub098\uc694? \uc608\ub97c \ub4e4\uc5b4, \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\ub294 \uac78 \uc88b\uc544\ud558\uc2dc\ub098\uc694, \uc544\ub2c8\uba74 \uac00\ubccd\uace0 \ube60\ub978 \uc804\uac1c\ub85c \uc77d\ub294 \uac78 \uc120\ud638\ud558\uc2dc\ub098\uc694?", "\ub098\ub294 \uae4a\uc774 \uc788\ub294 \uc0ac\uc0c9\uc774 \uac00\ub2a5\ud55c \uae00\uc744 \uc120\ud638\ud558\uace0 \ud63c\uc790 \uc870\uc6a9\ud788 \uc77d\uace0 \uc2f6\uc5b4\uc11c \uadf8\ub7f0 \uc2a4\ud0c0\uc77c\uc758 \ucc45\uc774 \ud544\uc694\ud558\ub2e4", "\uc800\ub294 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\ub294 \uac78 \uc88b\uc544\ud574\uc694. \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc774 \ud544\uc694\ud558\uac70\ub4e0\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, 4, "\uadf8\ub807\uad70\uc694! \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\uc73c\uba74\uc11c \uc0ac\uc0c9\ud560 \uc218 \uc788\ub294 \uc2dc\uac04\uc744 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud558\uc2dc\ub294\uad70\uc694. \uadf8\ub7ec\uba74 \ucc45\uc758 \ub09c\uc774\ub3c4\ub294 \uc5b4\ub5a4 \uc815\ub3c4\uac00 \uc88b\uc73c\uc2e0\uac00\uc694? \ub108\ubb34 \uc5b4\ub835\uc9c0 \uc54a\uc73c\uba74\uc11c\ub3c4 \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc8fc\ub294 \ucc45\uc774 \uc88b\uc73c\uc2e0\uac00\uc694, \uc544\ub2c8\uba74 \uc880 \ub354 \ub3c4\uc804\uc801\uc778 \ub0b4\uc6a9\uc744 \uc6d0\ud558\uc2dc\ub098\uc694?", "\ub098\ub294 \uae4a\uc774 \uc788\ub294 \ub0b4\uc6a9\uc744 \ucc9c\ucc9c\ud788 \uc77d\uace0 \uc2f6\uace0, \ud604\uc7ac \uc0c1\ud669\uc5d0\uc11c \ud3b8\uc548\ud55c \ucc45\uc744 \uc6d0\ud574\uc11c \uc5d0\uc138\uc774 \uc218\uc900\uc758 \uac00\ubcbc\uc6b4 \ucc45\uc774 \ud544\uc694\ud558\ub2e4", "\uadf8\ub0e5 \uc5d0\uc138\uc774 \uc218\uc900\uc73c\ub85c \uac00\ubccd\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc774 \uc88b\uaca0\uc5b4\uc694. \ub108\ubb34 \uc5b4\ub835\uc9c0 \uc54a\uc73c\uba74\uc11c\ub3c4 \uc0dd\uac01\ud560 \uac70\ub9ac\ub97c \uc8fc\uba74 \uc88b\uaca0\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 2, 5, "\ucd5c\uadfc\uc5d0 \ub9c8\uc74c\uc744 \ud3b8\uc548\ud558\uac8c \ud574\uc904 \uc218 \uc788\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc77d\uc5b4\ubcf8 \uc801\uc774 \uc788\uc73c\uc2e0\uac00\uc694? \uc5b4\ub5a4 \ucc45\uc774\uc5c8\uace0, \uadf8 \ucc45\uc744 \ud1b5\ud574 \uc5b4\ub5a4 \uac10\uc815\uc744 \ub290\ub07c\uc168\ub294\uc9c0 \uad81\uae08\ud569\ub2c8\ub2e4.", "\ub098\ub294 \ud790\ub9c1 \uc5d0\uc138\uc774\ub97c \uc77d\uace0 \uc2f6\uace0, \ucd5c\uadfc\uc5d0 \uc77d\uc740 \ucc45\uc5d0 \ub300\ud55c \uc774\uc57c\uae30\ub97c \ub098\ub204\uace0 \uc2f6\uc9c0 \uc54a\uc544\uc11c \ub300\ub2f5\ud558\uae30 \uc5b4\ub824\uc6cc.", "\ucd5c\uadfc\uc5d0 \uc77d\uc740 \ud790\ub9c1 \uc5d0\uc138\uc774\ub294 \uc5c6\uc5b4\uc694. \uadf8\ub798\uc11c \uc0c8\ub85c\uc6b4 \ucc45\uc744 \ucc3e\uace0 \uc788\ub294 \uac70\uc608\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, 1, "\ucc45\uc744 \uc77d\uace0 \uc2f6\uc73c\uc2e0 \uc774\uc720\uac00 \ubb34\uc5c7\uc778\uc9c0 \uad81\uae08\ud574\uc694. \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\uc744 \uc5bb\uace0 \uc2f6\uc73c\uc2e0 \uac74\uac00\uc694, \uc544\ub2c8\uba74 \uc5b4\ub5a4 \ud2b9\uc815\ud55c \ubaa9\ud45c\uac00 \uc788\uc73c\uc2e0\uac00\uc694?", "\ub098\ub294 \uc9c1\uc7a5 \uad00\uacc4\uc640 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud558\uace0 \uc2f6\uc5b4\uc11c \uc2ec\ub9ac\ud559 \uad00\ub828 \ucc45\uc744 \uc77d\uace0 \uc2f6\ub2e4", "\uc74c... \uc800\ub294 \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\uc640 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc2ec\ub9ac\ud559\uc801\uc73c\ub85c \uc774\ud574\ud558\uace0 \uc2f6\uc5b4\uc11c \ucc45\uc744 \uc77d\uace0 \uc2f6\uc5b4\uc694. \uc0c8\ub85c\uc6b4 \uc9c0\uc2dd\ub3c4 \uc5bb\uace0, \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \ubc30\uc6b8 \uc218 \uc788\uc73c\uba74 \uc88b\uaca0\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, 2, "\uc548\ub155\ud558\uc138\uc694! \uc774\uc804\uc5d0 \uc774\uc9c1 \uc900\ube44 \uc911 \uc7ac\uc815\uc801\uc778 \uae30\ubc18\uc744 \ub2e4\uc9c0\uace0 \uc2e4\uc0dd\ud65c\uc5d0 \ub3c4\uc6c0\uc774 \ub418\ub294 \uacbd\uc81c\uc640 \uc7ac\ud14c\ud06c \uad00\ub828 \ub3c4\uc11c\ub97c \ucc3e\uc73c\uc168\ub358 \uae30\ub85d\uc774 \uc788\uc2b5\ub2c8\ub2e4. \uc131\uc778 \uc77c\ubc18 \uc218\uc900\uc758 \ub09c\uc774\ub3c4\ub85c \uc27d\uac8c \uc77d\uc744 \uc218 \uc788\ub294 \ucc45\uc744 \uc120\ud638\ud558\uc2e0\ub2e4\uace0 \ud558\uc168\ub294\ub370, \uc774\ubc88\uc5d0\ub3c4 \ube44\uc2b7\ud55c \uc885\ub958\uc758 \ucc45\uc744 \ucc3e\uace0 \uacc4\uc2e0\uac00\uc694? Yes \ub610\ub294 No\ub85c \ub2f5\ubcc0\ud574 \uc8fc\uc2dc\uba74 \uc88b\uaca0\uc2b5\ub2c8\ub2e4.", "\ub098\ub294 \uc2ec\ub9ac\ud559\uacfc \ud589\ub3d9\uacbd\uc81c\ud559\uc5d0 \uad00\uc2ec\uc774 \uc788\uace0 \ud604\uc7ac \uc8fc\ub9d0\uc5d0 \uc5ec\uc720\ub86d\uac8c \uc77d\uace0 \uc2f6\uc5b4\uc11c \uad00\ub828\ub41c \ucc45\uc744 \ucc3e\uace0 \uc788\ub2e4", "\uc544\ub2c8\uc694, \uc774\ubc88\uc5d0\ub294 \uc2ec\ub9ac\ud559 \ucabd\uc73c\ub85c \ucc3e\uace0 \uc2f6\uc5b4\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, 3, "\uadf8\ub807\uad70\uc694! \uc2ec\ub9ac\ud559 \ubd84\uc57c\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uc73c\uc2dc\uad70\uc694. \uc2e4\uc81c \uc0ac\ub840\ub97c \ud1b5\ud574 \ubc30\uc6b0\uace0 \uc2f6\uc73c\uc2dc\ub2e4\uace0 \ud558\uc168\ub294\ub370, \uadf8\ub7f0 \uc810\uc5d0\uc11c \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\ubcf4\ub2e4\ub294 \uc911\uac04 \uc815\ub3c4\uc758 \ub09c\uc774\ub3c4\uac00 \uc801\ub2f9\ud558\uc2e4\uae4c\uc694, \uc544\ub2c8\uba74 \uc880 \ub354 \uc2ec\ub3c4 \uc788\ub294 \ub0b4\uc6a9\uc744 \uc6d0\ud558\uc2e4\uae4c\uc694?", "\ub098\ub294 \uc2ec\ub9ac\ud559\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uace0 \uc0ac\ub840 \uc911\uc2ec\uc73c\ub85c \ubc30\uc6b0\uace0 \uc2f6\uc5b4\uc11c \uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uc758 \ucc45\uc744 \uc6d0\ud55c\ub2e4", "\uc801\ub2f9\ud55c \ub09c\uc774\ub3c4\uac00 \uc88b\uc744 \uac83 \uac19\uc544\uc694. \ub108\ubb34 \uc5b4\ub824\uc6b4 \ub0b4\uc6a9\uc740 \ubd80\ub2f4\uc2a4\ub7ec\uc6cc\uc11c\uc694."], ["A_\ucd5c\uc7ac\uc6d0", 3, 4, "\ucd5c\uadfc\uc5d0 \uc77d\uc5c8\ub358 \uc2ec\ub9ac\ud559 \uad00\ub828 \ucc45\uc774 \uc788\ub2e4\uba74, \uc5b4\ub5a4 \ucc45\uc774\uc5c8\ub294\uc9c0 \uadf8\ub9ac\uace0 \uadf8 \ucc45\uc5d0\uc11c \ud2b9\ud788 \ud765\ubbf8\ub86d\uac8c \ub290\uaf08\ub358 \ub0b4\uc6a9\uc774\ub098 \uc0ac\ub840\uac00 \uc788\uc5c8\ub294\uc9c0 \uad81\uae08\ud569\ub2c8\ub2e4. \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\uc640 \uc18c\ud1b5 \ubc29\uc2dd\uc744 \uc774\ud574\ud558\ub294 \ub370 \ub3c4\uc6c0\uc774 \ub418\uc5c8\ub358 \ubd80\ubd84\uc774 \uc788\uc5c8\ub294\uc9c0\ub3c4 \ud568\uaed8 \ub9d0\uc500\ud574 \uc8fc\uc2dc\uba74 \uc88b\uaca0\uc2b5\ub2c8\ub2e4!", "\ub098\ub294 \uc2ec\ub9ac\ud559\uc5d0 \uad00\uc2ec\uc774 \ub9ce\uace0 \uc9c1\uc7a5 \ub0b4 \uad00\uacc4\ub97c \uc774\ud574\ud558\uace0 \uc2f6\uc5b4\uc11c \ucd5c\uadfc \uc77d\uc740 \ucc45\uc758 \ub0b4\uc6a9\uc744 \uacf5\uc720\ud558\uace0 \uc2f6\ub2e4", "\ucd5c\uadfc\uc5d0 '\uc0ac\ub78c\uc740 \ubb34\uc5c7\uc73c\ub85c \uc0ac\ub294\uac00'\ub77c\ub294 \ucc45\uc744 \uc77d\uc5c8\uc5b4\uc694. \uadf8 \uc548\uc5d0\uc11c \uc0ac\ub78c\ub4e4\uc758 \ub3d9\uae30\uc640 \uad00\uacc4\uac00 \uc5b4\ub5bb\uac8c \ud615\uc131\ub418\ub294\uc9c0\ub97c \ub2e4\ub8ec \ubd80\ubd84\uc774 \ud2b9\ud788 \ud765\ubbf8\ub85c\uc6e0\uc5b4\uc694. \uc9c1\uc7a5\uc5d0\uc11c\uc758 \uc18c\ud1b5 \ubc29\uc2dd\uc5d0 \ub300\ud55c \uc774\ud574\uc5d0 \ub3c4\uc6c0\uc774 \ub9ce\uc774 \ub418\uc5c8\ub358 \uac83 \uac19\uc544\uc694."]], "log_mode": "IMMUTABLE", "ncols": 6, "nrows": 13}